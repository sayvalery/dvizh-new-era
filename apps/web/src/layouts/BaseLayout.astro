---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: string
  jsonLd?: object
}

const { title, description, ogImage, ogType = 'website', jsonLd } = Astro.props
const siteTitle = title ? `${title} — ДВИЖ` : 'ДВИЖ'
const canonicalUrl = Astro.url.href
const defaultOgImage = `${Astro.site}og-default.jpg`
const resolvedOgImage = ogImage || defaultOgImage
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="ДВИЖ — Блог" href="/rss.xml" />

    <!-- Preload critical font (body text only — heading fonts load via @font-face) -->
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:site_name" content="ДВИЖ" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script>
      import Alpine from 'alpinejs'
      window.Alpine = Alpine
      Alpine.start()
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
