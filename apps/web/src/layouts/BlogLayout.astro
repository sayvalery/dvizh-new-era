---
import BaseLayout from './BaseLayout.astro'
import NavBar from '../components/ui/NavBar.astro'
import Footer from '../components/layout/Footer.astro'
import Drawer from '../components/ui/Drawer.astro'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: string
  jsonLd?: any
}
---

<BaseLayout {...Astro.props}>
  <NavBar
    logo={{ label: 'ДВИЖ Инсайты', href: '/blog' }}
    items={[
      { label: 'Блог', href: '/blog' },
      { label: 'Словарь девелопера', href: '/slovar-developera' },
    ]}
    secondaryLink={{ label: '← dvizh.io', href: '/' }}
  />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <Drawer />
</BaseLayout>
