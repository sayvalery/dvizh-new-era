---
import BaseLayout from './BaseLayout.astro'
import NavBar from '../components/ui/NavBar.astro'
import type { NavItem } from '../components/ui/NavBar.astro'
import { getCategories } from '../lib/payload'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const { docs: categories } = await getCategories().catch(() => ({ docs: [] as any[] }))

const navItems: NavItem[] = categories.map((cat: any) => ({
  label: cat.title,
  href: `/category/${cat.slug}`,
}))
---

<BaseLayout {...Astro.props}>
  <NavBar
    logo={{ label: 'ДВИЖ Инсайты', href: '/blog' }}
    items={navItems}
    secondaryLink={{ label: '← dvizh.io', href: '/' }}
  />
  <main class="flex-1">
    <slot />
  </main>
  <footer class="border-t border-gray-200 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-8 flex items-center justify-between">
      <p class="text-sm text-gray-500">© {new Date().getFullYear()} ДВИЖ Инсайты</p>
      <a href="/" class="text-sm text-gray-500 hover:text-gray-900">На сайт dvizh.io →</a>
    </div>
  </footer>
</BaseLayout>
