---
import BaseLayout from './BaseLayout.astro'
import { getCategories } from '../lib/payload'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const { docs: categories } = await getCategories().catch(() => ({ docs: [] }))
---

<BaseLayout {...Astro.props}>
  <header class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <a href="/blog" class="font-bold text-xl">ДВИЖ Инсайты</a>
        <nav class="hidden md:flex items-center gap-4">
          {categories.map((cat: any) => (
            <a href={`/category/${cat.slug}`} class="text-sm text-gray-600 hover:text-gray-900">
              {cat.title}
            </a>
          ))}
        </nav>
      </div>
      <a href="/" class="text-sm text-gray-500 hover:text-gray-900">
        ← dvizh.io
      </a>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-gray-200 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-8 flex items-center justify-between">
      <p class="text-sm text-gray-500">© {new Date().getFullYear()} ДВИЖ Инсайты</p>
      <a href="/" class="text-sm text-gray-500 hover:text-gray-900">На сайт dvizh.io →</a>
    </div>
  </footer>
</BaseLayout>
