---
/**
 * FormBlock — форма внутри статьи
 *
 * Отображает один из пресетов Form на сером фоне.
 *
 * CMS-поля (блок 'form' в BlogPosts → content):
 *   preset      → 'lead' | 'subscribe' | 'demo' | 'research' (обязательно)
 *   title       → заголовок над формой
 *   description → описание под заголовком
 *
 * Рендерится через BlockRenderer.astro при blockType === 'form'.
 */
import Form from '../ui/Form.astro'

interface Props {
  block: any
}

const { block } = Astro.props
---

<div class="my-8 p-6 bg-gray-50 rounded-xl">
  {block.title && <h3 class="text-lg font-semibold mb-2">{block.title}</h3>}
  {block.description && <p class="text-sm text-gray-600 mb-4">{block.description}</p>}
  <Form preset={block.preset} />
</div>
