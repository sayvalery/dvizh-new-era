---
/**
 * QuoteBlock — цитата внутри статьи
 *
 * Оформлена как blockquote с чёрной боковой полосой.
 *
 * CMS-поля (блок 'quote' в BlogPosts → content):
 *   text    → текст цитаты (обязательно)
 *   author  → имя автора
 *   company → название компании
 *   photo   → upload (Media). photo.url — абсолютный URL
 *
 * Рендерится через BlockRenderer.astro при blockType === 'quote'.
 */
interface Props {
  block: any
}

const { block } = Astro.props
const photoUrl = block.photo?.url ?? null
---

<blockquote class="my-8 border-l-4 border-black pl-6">
  <p class="text-lg italic text-gray-700 mb-4">"{block.text}"</p>
  <footer class="flex items-center gap-3">
    {photoUrl && (
      <img src={photoUrl} alt={block.author ?? ''} class="w-10 h-10 rounded-full object-cover" />
    )}
    <div>
      {block.author && <p class="font-medium text-sm">{block.author}</p>}
      {block.company && <p class="text-sm text-gray-500">{block.company}</p>}
    </div>
  </footer>
</blockquote>
