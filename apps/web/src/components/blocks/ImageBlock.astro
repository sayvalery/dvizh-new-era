---
/**
 * ImageBlock — изображение с подписью внутри статьи
 *
 * CMS-поля (блок 'image' в BlogPosts → content):
 *   image   → upload (Media). image.url — абсолютный URL (Payload serverURL включён)
 *   caption → подпись под картинкой
 *   alt     → alt-текст (если не задан — берётся из image.alt или caption)
 *
 * Рендерится через BlockRenderer.astro при blockType === 'image'.
 */
interface Props {
  block: any
}

const { block } = Astro.props
const { image, caption, alt } = block

const imageUrl = image?.url ?? null
const imageAlt = alt || image?.alt || caption || ''
---

{imageUrl && (
  <figure class="my-8">
    <img
      src={imageUrl}
      alt={imageAlt}
      class="w-full rounded-lg"
      loading="lazy"
    />
    {caption && <figcaption class="text-sm text-gray-500 mt-2 text-center">{caption}</figcaption>}
  </figure>
)}
