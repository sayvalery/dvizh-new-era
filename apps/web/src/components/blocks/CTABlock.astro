---
/**
 * CTABlock — CTA-баннер внутри статьи
 *
 * Тёмный баннер с заголовком, описанием и кнопкой.
 * Кнопка может открывать дровер с формой или вести по ссылке.
 *
 * CMS-поля (блок 'cta' в BlogPosts → content):
 *   heading      → текст заголовка (обязательно)
 *   description  → текст под заголовком
 *   buttonText   → текст кнопки (обязательно)
 *   buttonAction → 'sidebarForm' | 'link'
 *   formPreset   → 'lead' | 'subscribe' | 'demo' | 'research' (если buttonAction = sidebarForm)
 *   link         → URL (если buttonAction = link)
 *
 * Рендерится через BlockRenderer.astro при blockType === 'cta'.
 */
interface Props {
  block: any
}

const { block } = Astro.props
---

<div class="my-8 p-8 bg-black text-white rounded-xl">
  {block.heading && <h3 class="text-xl font-bold mb-2">{block.heading}</h3>}
  {block.description && <p class="text-sm text-gray-300 mb-4">{block.description}</p>}

  {block.buttonAction === 'link' ? (
    <a
      href={block.link ?? '#'}
      class="inline-block bg-white text-black px-5 py-2 rounded font-medium text-sm hover:bg-gray-100"
    >
      {block.buttonText}
    </a>
  ) : (
    <button
      x-data
      @click={`$dispatch('open-drawer', { preset: '${block.formPreset ?? 'lead'}' })`}
      class="inline-block bg-white text-black px-5 py-2 rounded font-medium text-sm hover:bg-gray-100"
    >
      {block.buttonText}
    </button>
  )}
</div>
