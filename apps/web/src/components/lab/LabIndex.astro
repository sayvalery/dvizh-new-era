---
/**
 * Lab: Index — список экспериментальных страниц
 * Доступна только в dev-режиме: preview.dvizh.cc/lab/
 */
import SiteLayout from '../../layouts/SiteLayout.astro'

const pages = [
  {
    title: 'New Components',
    description: 'Компоненты с обновлённым стилем — хранятся отдельно, не затрагивая текущий UI Kit',
    href: '/lab/new-components',
    style: 'UI Components',
  },
  {
    title: 'Glassmorphism',
    description: 'CSS backdrop-blur + прозрачность — разные варианты эффекта стекла на градиентном фоне',
    href: '/lab/glass',
    style: 'CSS / Glassmorphism',
  },
  {
    title: 'Fluted Glass',
    description: 'Mesh gradient + рифлёное стекло в одном WebGL-шейдере — 0 зависимостей, ~3% GPU, 60fps',
    href: '/lab/fluted-glass',
    style: 'WebGL / Shader',
  },
  {
    title: 'Logo Animations',
    description: 'CSS-анимации логотипов — 3D-барабан (цилиндр) и поток с эффектом глубины, 0 JS',
    href: '/lab/logo-animations',
    style: 'CSS / Animation',
  },
  {
    title: 'Product Page',
    description: 'Электронная регистрация — split-layout, serif headings, generous spacing',
    href: '/lab/product',
    style: 'Product / SaaS landing',
  },
  {
    title: 'About Page',
    description: 'О компании — editorial style, narrative structure, timeline',
    href: '/lab/about',
    style: 'Editorial / Narrative',
  },
]
---

<SiteLayout title="Lab — Экспериментальные страницы">
  <section class="pt-32 pb-24">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-sm font-medium tracking-widest uppercase text-brand mb-6">Lab</p>
      <h1 class="text-4xl lg:text-6xl font-medium leading-tight tracking-tight text-gray-900 mb-4" style="font-family: 'Georgia', 'Times New Roman', serif;">
        Экспериментальные страницы
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mb-16">
        Тестовые страницы с адаптацией визуальных паттернов Linear.app для контента ДВИЖ. Только для dev-режима.
      </p>

      <div class="space-y-6">
        {pages.map(page => (
          <a href={page.href} class="block p-8 bg-gray-50 rounded-2xl border border-gray-100 hover:border-gray-300 transition-colors group">
            <div class="flex items-start justify-between">
              <div>
                <h2 class="text-xl font-semibold text-gray-900 group-hover:text-brand transition-colors">
                  {page.title}
                </h2>
                <p class="text-gray-500 mt-2">{page.description}</p>
              </div>
              <span class="text-xs font-medium text-gray-400 bg-gray-100 px-3 py-1 rounded-full shrink-0 ml-4">
                {page.style}
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</SiteLayout>
