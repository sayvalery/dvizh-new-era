---
/**
 * Lab New: FeatureCard — карточка с цветным фоном, заголовком и подзаголовком
 */
interface Props {
  /** Заголовок */
  title: string
  /** Подзаголовок */
  subtitle: string
  /** Цвет фона */
  color?: string
  /** Инверсия цвета */
  inverted?: boolean
  /** Фоновое изображение */
  image?: string
  /** Позиция фонового изображения (center, right, left, top, bottom, или комбинация) */
  imagePosition?: 'center' | 'right' | 'left' | 'top' | 'bottom' | 'top right' | 'top left' | 'right top' | 'bottom right' | 'right bottom' | 'bottom left' | 'left bottom'
}

const { title, subtitle, color = "#202b32", inverted = false, image = "", imagePosition = "center" } = Astro.props

// Определяем светлый фон или тёмный
const isLightBg = color === '#f2f2f2' || color === '#F2F2F2'
// На светлых карточках текст снизу, на тёмных — сверху
const alignClass = isLightBg ? 'justify-end' : 'justify-start'
// Цвет текста: на светлом фоне тёмный, на тёмном — белый
const textColor = inverted ? (isLightBg ? 'text-gray-900' : 'text-white') : (isLightBg ? 'text-gray-900' : 'text-white')
// Стиль для фона: цвет или изображение
const backgroundStyle = image
  ? `background-color: ${color}`
  : `background-color: ${color}`
---

<div
  class="feature-card-hover relative overflow-hidden rounded-[18px] h-[414px] w-full transition-all duration-400 ease-out"
  style={backgroundStyle}
>
  {image && (
    <div class="feature-card-bg-image absolute inset-0" style={`background-image: url('${image}'); background-size: cover; background-position: ${imagePosition};`} />
  )}
  <div class={`feature-card-bg relative h-full flex flex-col p-6 ${alignClass}`}>
    <div class={`feature-card-content relative z-10 flex flex-col gap-1 text-left transition-all duration-400 ease-out ${textColor}`}>
      <h3 class="feature-card-title text-[17.6px] font-semibold transition-all duration-400 ease-out">
        {title}
      </h3>
      <p class="feature-card-desc text-[17.6px] opacity-90 transition-all duration-400 ease-out">
        {subtitle}
      </p>
    </div>
  </div>
</div>

<style>
  .feature-card-hover {
    position: relative;
  }

  .feature-card-hover::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.7rem;
    pointer-events: none;
    opacity: 0.2;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.15),
      inset 0 0 0 2px rgba(255, 255, 255, 0.08);
  }

  /*
    Сохраненные hover-эффекты (отключены):
    .feature-card-hover:hover { transform: translateY(-8px); }
    .feature-card-hover:hover::after { opacity: 0.5; }
    .feature-card-hover:hover .feature-card-bg-image { transform: scale(1.03); }
    .feature-card-hover:hover .feature-card-bg { transform: scale(1.01); }
    .feature-card-hover:hover .feature-card-title { transform: translateY(-0.5px); }
    .feature-card-hover:hover .feature-card-desc { opacity: 1; }
  */
</style>
