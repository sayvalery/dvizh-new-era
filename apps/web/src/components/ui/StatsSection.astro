---
/**
 * StatsSection — секция с метриками/преимуществами в виде сетки
 *
 * @example
 * ```astro
 * // Без заголовка — только карточки по центру
 * <StatsSection
 *   items={[
 *     { value: '44 million', label: 'Transactions every 24 hours' },
 *     { value: '$119 trillion', label: 'Assets under holding' },
 *     { value: '46,000', label: 'New users annually' },
 *   ]}
 * />
 *
 * // С заголовком слева
 * <StatsSection
 *   title="Девелоперы с ДВИЖом"
 *   items={[...]}
 * />
 * ```
 */

interface StatItem {
  /** Основное значение (цифра или текст) */
  value?: string
  /** Описание/подпись */
  label: string
  /** Текст под карточкой (показывается под цифрой/значением) */
  sublabel?: string
  /** Опциональная иконка (HTML) */
  icon?: string
}

interface Props {
  /** Массив метрик/преимуществ */
  items: StatItem[]
  /** Количество колонок на десктопе (2-4) */
  cols?: 2 | 3 | 4
  /** Крупный заголовок слева (опционально) */
  title?: string
  /** Дополнительные CSS классы */
  class?: string
}

const { items, cols = 4, title, class: className = '' } = Astro.props

const gridCols = {
  2: 'lg:grid-cols-2',
  3: 'lg:grid-cols-3',
  4: 'lg:grid-cols-4',
}[cols]
---

<section class:list={['bg-white py-24 sm:py-32', className]}>
  <div class="mx-auto max-w-[1440px] px-4">
    {title && (
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-semibold font-heading text-gray-900 mb-16">
        {title}
      </h2>
    )}
    <dl class:list={['grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-16 text-center', gridCols]}>
      {items.map((item) => (
        <div class="mx-auto flex max-w-xs flex-col gap-y-4">
          {item.icon ? (
            <div class="text-gray-400 mb-2" set:html={item.icon} />
          ) : (
            <div class="w-[120px] h-[120px] sm:w-[160px] sm:h-[160px] lg:w-[200px] lg:h-[200px] bg-gray-200 rounded-[20px] mx-auto mb-2" />
          )}
          {item.value && (
            <dd class="order-first text-3xl font-semibold text-gray-900 sm:text-5xl">
              {item.value}
            </dd>
          )}
          <dt class="text-base/7 text-gray-600">{item.label}</dt>
          {item.sublabel && (
            <div class="text-base/7 text-gray-500 mt-2">{item.sublabel}</div>
          )}
        </div>
      ))}
    </dl>
  </div>
</section>
