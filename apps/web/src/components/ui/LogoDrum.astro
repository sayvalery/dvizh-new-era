---
/**
 * LogoDrum — 3D-барабан с логотипами (чистый CSS)
 *
 * Анимация: CSS 3D-цилиндр, вращается вокруг оси X вверх.
 * Логотипы повторяются, чтобы заполнить барабан с равным расстоянием.
 * Каждый проходит через «фокусную зону» — sharp и яркий,
 * за пределами — уходит в blur и прозрачность.
 *
 * Логотипы отображаются в натуральных пропорциях SVG.
 * Ноль JavaScript. Ноль библиотек. Чистые CSS transforms + filter.
 *
 * @example
 * ```astro
 * <LogoDrum
 *   logos={['/logo1.svg', '/logo2.svg', '/logo3.svg']}
 *   duration={25}
 * />
 * ```
 */

interface Props {
  /** Массив URL логотипов (SVG рекомендуется) */
  logos: string[]
  /** Длительность полного оборота в секундах */
  duration?: number
  /** Радиус цилиндра в px */
  radius?: number
  /** Угловой шаг между логотипами в градусах (меньше = плотнее) */
  angleGap?: number
  /** Дополнительные CSS классы */
  class?: string
}

const {
  logos,
  duration = 25,
  radius = 380,
  angleGap = 22,
  class: className = ''
} = Astro.props

// Сколько слотов помещается на барабане
const totalSlots = Math.floor(360 / angleGap)

// Заполняем слоты, повторяя логотипы по кругу
const items: string[] = []
for (let i = 0; i < totalSlots; i++) {
  items.push(logos[i % logos.length])
}
---

<div class:list={['logo-drum', className]}>
  <div class="logo-drum-rotor" style={`animation-duration: ${duration}s;`}>
    {items.map((logo, i) => (
      <div
        class="logo-drum-face"
        style={`
          transform: rotateX(${i * angleGap}deg) translateZ(${radius}px);
          animation-duration: ${duration}s;
          animation-delay: ${(-i / totalSlots * duration).toFixed(2)}s;
        `}
      >
        <img
          src={logo}
          alt=""
          class="logo-drum-img"
          loading="eager"
        />
      </div>
    ))}
  </div>
</div>

<style>
  .logo-drum {
    perspective: 1200px;
    perspective-origin: center 50%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-drum-rotor {
    position: relative;
    width: 240px;
    height: 80px;
    transform-style: preserve-3d;
    animation-name: drum-spin;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  @keyframes drum-spin {
    from { transform: rotateX(0deg); }
    to { transform: rotateX(360deg); }
  }

  .logo-drum-face {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    animation-name: face-depth;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  @keyframes face-depth {
    0%, 8% {
      opacity: 1;
    }
    14% {
      opacity: 0.3;
    }
    20%, 80% {
      opacity: 0;
      visibility: hidden;
    }
    86% {
      opacity: 0.3;
    }
    92%, 100% {
      opacity: 1;
    }
  }

  .logo-drum-img {
    height: auto;
    max-height: 60px;
    width: auto;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
    filter: brightness(0) invert(1);
  }
</style>
