---
/**
 * Form — контактная форма с пресетами
 *
 * Пресеты полей:
 *   lead      → name, phone
 *   subscribe → email
 *   demo      → name, email, phone, company
 *   research  → name, email, company
 *
 * Лейауты:
 *   stacked (по умолчанию) — лейбл сверху, инпут снизу
 *   labels-left             — лейбл слева, инпут справа. Для дровера
 *   inline                  — горизонтальная форма в одну строку. Для hero-секций
 *
 * Варианты:
 *   light (по умолчанию) — для белого/светлого фона
 *   dark                  — для тёмного фона (FormClosing и т.п.)
 *
 * Примеры:
 *   <Form preset="demo" />
 *   <Form preset="lead" layout="labels-left" />
 *   <Form preset="lead" layout="inline" variant="dark" />
 *
 * Отправка: POST /api/form-submissions на CMS.
 */
const CMS_URL = import.meta.env.CMS_URL || 'http://localhost:3002'
const CLIENT_CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? ''

interface Props {
  preset: 'lead' | 'subscribe' | 'demo' | 'research'
  layout?: 'stacked' | 'labels-left' | 'inline'
  /** light — для светлого фона, dark — для тёмного (FormClosing и т.п.) */
  variant?: 'light' | 'dark'
  submitLabel?: string
  class?: string
}

const { preset, layout = 'stacked', variant = 'light', submitLabel, class: className } = Astro.props

const isDark = variant === 'dark'

const inputClasses = isDark
  ? 'w-full bg-white/[0.12] border-0 rounded-2xl px-5 py-3.5 text-[15px] text-white placeholder:text-white/50 focus:outline-none focus:ring-2 focus:ring-white/30 focus:bg-white/[0.18] transition-all duration-300 focus:scale-[1.01] focus:shadow-lg focus:shadow-white/10'
  : 'w-full bg-black/[0.04] border-0 rounded-2xl px-5 py-3.5 text-[15px] text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-brand/40 focus:bg-white transition-all duration-300 focus:scale-[1.01] focus:shadow-lg focus:shadow-brand/15'

const labelClasses = isDark
  ? 'text-[13px] font-medium text-white/60 pl-1'
  : 'text-[13px] font-medium text-gray-500 pl-1'

const btnClasses = isDark
  ? 'bg-white text-gray-900 hover:bg-white hover:scale-[1.03] hover:shadow-xl hover:shadow-white/20'
  : 'bg-brand text-white hover:bg-brand hover:scale-[1.03] hover:shadow-xl hover:shadow-brand/25'

const successClasses = isDark ? 'text-green-400' : 'text-green-600'
const errorClasses = isDark ? 'text-red-400' : 'text-red-600'

const fields: Record<string, string[]> = {
  lead:     ['name', 'phone'],
  subscribe:['email'],
  demo:     ['name', 'email', 'phone', 'company'],
  research: ['name', 'email', 'company'],
}

const fieldLabels: Record<string, string> = {
  name:    'Ваше имя',
  email:   'Email',
  phone:   'Телефон',
  company: 'Компания',
}

const defaultSubmitLabels: Record<string, string> = {
  lead:      'Отправить',
  subscribe: 'Подписаться',
  demo:      'Получить демо',
  research:  'Получить исследование',
}

const btnLabel = submitLabel ?? defaultSubmitLabels[preset] ?? 'Отправить'
const formFields = fields[preset] ?? ['name', 'email']
---

<form
  class:list={[className]}
  data-preset={preset}
  data-cms-url={CLIENT_CMS_URL}
>
  {layout === 'inline' ? (
    <div class="flex flex-col sm:flex-row gap-3 items-start">
      {formFields.map((field) => (
        <input
          id={`field-${preset}-${field}`}
          type={field === 'email' ? 'email' : 'text'}
          name={field}
          required={field === 'email' || field === 'name'}
          placeholder={fieldLabels[field]}
          class:list={['flex-1', inputClasses]}
        />
      ))}
      <button
        type="submit"
        class:list={['w-full sm:w-auto whitespace-nowrap px-7 py-3.5 rounded-2xl text-[15px] font-medium active:scale-[0.98] transition-all duration-300 ease-out disabled:opacity-50', btnClasses]}
      >
        {btnLabel}
      </button>
    </div>
  ) : layout === 'labels-left' ? (
    <div class="space-y-3">
      {formFields.map((field) => (
        <div class="flex flex-col gap-1.5">
          <label
            for={`field-${preset}-${field}`}
            class={labelClasses}
          >
            {fieldLabels[field]}
          </label>
          <input
            id={`field-${preset}-${field}`}
            type={field === 'email' ? 'email' : 'text'}
            name={field}
            required={field === 'email' || field === 'name'}
            placeholder={fieldLabels[field]}
            class={inputClasses}
          />
        </div>
      ))}
    </div>
  ) : (
    <div class="space-y-3">
      {formFields.map((field) => (
        <div class="flex flex-col gap-1.5">
          <label
            for={`field-${preset}-${field}`}
            class={labelClasses}
          >
            {fieldLabels[field]}
          </label>
          <input
            id={`field-${preset}-${field}`}
            type={field === 'email' ? 'email' : 'text'}
            name={field}
            required={field === 'email' || field === 'name'}
            placeholder={fieldLabels[field]}
            class={inputClasses}
          />
        </div>
      ))}
    </div>
  )}

  <div class="hidden">
    <input name="_honeypot" tabindex="-1" autocomplete="off" />
  </div>

  {layout !== 'inline' && (
    <button
      type="submit"
      class:list={['mt-5 w-full py-3.5 rounded-2xl text-[15px] font-medium active:scale-[0.98] transition-all duration-300 ease-out disabled:opacity-50', btnClasses]}
    >
      {btnLabel}
    </button>
  )}

  <p class:list={['form-success hidden mt-3 text-sm', successClasses]}>Спасибо! Мы свяжемся с вами.</p>
  <p class:list={['form-error hidden mt-3 text-sm', errorClasses]}>Ошибка отправки. Попробуйте ещё раз.</p>
</form>

<script>
  document.querySelectorAll('form[data-preset]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const f = e.target as HTMLFormElement
      const cmsUrl = f.dataset.cmsUrl
      const preset = f.dataset.preset

      const honeypot = (f.querySelector('[name="_honeypot"]') as HTMLInputElement)?.value
      if (honeypot) return

      const data: Record<string, string> = { preset: preset ?? '' }
      new FormData(f).forEach((val, key) => {
        if (key !== '_honeypot') data[key] = val as string
      })
      data.page = window.location.href

      const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement
      btn.disabled = true

      try {
        const res = await fetch(`${cmsUrl}/api/form-submissions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
        if (res.ok) {
          f.querySelector('.form-success')?.classList.remove('hidden')
          f.reset()
        } else {
          throw new Error('Server error')
        }
      } catch {
        f.querySelector('.form-error')?.classList.remove('hidden')
      } finally {
        btn.disabled = false
      }
    })
  })
</script>
