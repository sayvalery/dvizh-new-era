---
/**
 * Form — контактная форма с пресетами
 *
 * Пресеты полей:
 *   lead      → name, email, company
 *   subscribe → email
 *   demo      → name, email, phone, company
 *   research  → name, email, company
 *
 * Лейауты:
 *   stacked (по умолчанию) — лейбл сверху, инпут снизу. Для inline на странице.
 *   labels-left             — лейбл слева 1/3, инпут справа 2/3. Для дровера и боковых панелей.
 *
 * Примеры:
 *   <Form preset="demo" />
 *   <Form preset="lead" layout="labels-left" />
 *   <Form preset="subscribe" submitLabel="Подписаться" />
 *
 * Отправка: POST /api/form-submissions на CMS. Результат в коллекции FormSubmissions.
 * Открыть дровер с формой: @click="$dispatch('open-drawer', { preset: 'demo' })"
 */
const CMS_URL = import.meta.env.CMS_URL || 'http://localhost:3002'

interface Props {
  preset: 'lead' | 'subscribe' | 'demo' | 'research'
  layout?: 'stacked' | 'labels-left'
  submitLabel?: string
  class?: string
}

const { preset, layout = 'stacked', submitLabel, class: className } = Astro.props

const fields: Record<string, string[]> = {
  lead:     ['name', 'email', 'company'],
  subscribe:['email'],
  demo:     ['name', 'email', 'phone', 'company'],
  research: ['name', 'email', 'company'],
}

const fieldLabels: Record<string, string> = {
  name:    'Имя',
  email:   'Email',
  phone:   'Телефон',
  company: 'Компания',
}

const defaultSubmitLabels: Record<string, string> = {
  lead:      'Отправить',
  subscribe: 'Подписаться',
  demo:      'Запросить демо',
  research:  'Получить исследование',
}

const btnLabel = submitLabel ?? defaultSubmitLabels[preset] ?? 'Отправить'
const formFields = fields[preset] ?? ['name', 'email']
---

<form
  class:list={[className]}
  data-preset={preset}
  data-cms-url={CMS_URL}
>
  {layout === 'labels-left' ? (
    <div class="divide-y divide-gray-100">
      {formFields.map((field) => (
        <div class="grid grid-cols-3 gap-4 items-start py-4">
          <label
            for={`field-${preset}-${field}`}
            class="text-sm font-medium text-gray-700 pt-2"
          >
            {fieldLabels[field]}
          </label>
          <div class="col-span-2">
            <input
              id={`field-${preset}-${field}`}
              type={field === 'email' ? 'email' : 'text'}
              name={field}
              required={field === 'email' || field === 'name'}
              placeholder={fieldLabels[field]}
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black"
            />
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="space-y-3">
      {formFields.map((field) => (
        <div>
          <label
            for={`field-${preset}-${field}`}
            class="block text-sm font-medium mb-1"
          >
            {fieldLabels[field]}
          </label>
          <input
            id={`field-${preset}-${field}`}
            type={field === 'email' ? 'email' : 'text'}
            name={field}
            required={field === 'email' || field === 'name'}
            placeholder={fieldLabels[field]}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black"
          />
        </div>
      ))}
    </div>
  )}

  <div class="hidden">
    <input name="_honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <button
    type="submit"
    class="mt-4 w-full bg-black text-white py-2.5 rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors disabled:opacity-50"
  >
    {btnLabel}
  </button>

  <p class="form-success hidden mt-3 text-sm text-green-600">Спасибо! Мы свяжемся с вами.</p>
  <p class="form-error hidden mt-3 text-sm text-red-600">Ошибка отправки. Попробуйте ещё раз.</p>
</form>

<script>
  document.querySelectorAll('form[data-preset]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const f = e.target as HTMLFormElement
      const cmsUrl = f.dataset.cmsUrl
      const preset = f.dataset.preset

      const honeypot = (f.querySelector('[name="_honeypot"]') as HTMLInputElement)?.value
      if (honeypot) return

      const data: Record<string, string> = { preset: preset ?? '' }
      new FormData(f).forEach((val, key) => {
        if (key !== '_honeypot') data[key] = val as string
      })
      data.page = window.location.href

      const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement
      btn.disabled = true

      try {
        const res = await fetch(`${cmsUrl}/api/form-submissions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
        if (res.ok) {
          f.querySelector('.form-success')?.classList.remove('hidden')
          f.reset()
        } else {
          throw new Error('Server error')
        }
      } catch {
        f.querySelector('.form-error')?.classList.remove('hidden')
      } finally {
        btn.disabled = false
      }
    })
  })
</script>
