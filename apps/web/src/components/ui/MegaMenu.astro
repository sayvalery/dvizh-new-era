---
/**
 * MegaMenu — LEGACY. Сохранён для истории, не используется.
 *
 * Исходная навигация с мега-дропдауном на всю ширину.
 * Заменена на per-item hover-попапы в NavBar.astro.
 *
 * Если понадобится вернуть — интегрировать обратно в NavBar:
 *   1. Добавить megaOpen в header x-data
 *   2. Разместить этот компонент под <nav> внутри hover-зоны
 *   3. Вернуть секции в navItems через prop `sections`
 */

import BlogCard from './BlogCard.astro'

export interface NavChild {
  label: string
  href: string
  description?: string
}

export interface NavSection {
  title: string
  items: NavChild[]
}

interface BlogPost {
  title: string
  slug: string
  cover?: { url?: string; alt?: string }
  category?: string
}

interface Props {
  sections: NavSection[]
  blogPosts?: BlogPost[]
}

const { sections, blogPosts = [] } = Astro.props
---

<!-- Mega menu dropdown — используется x-show="megaOpen" из родительского x-data -->
<div
  x-cloak
  x-show="megaOpen"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 -translate-y-1"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 -translate-y-1"
  class="border-t border-gray-100"
>
  <div class="mx-auto max-w-[1440px] px-4 py-8">
    <div class="grid grid-cols-4 gap-8">
      {sections.map(section => (
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">{section.title}</p>
          <ul class="space-y-1">
            {section.items.map(child => (
              <li>
                <a href={child.href} class="block text-sm text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-md px-2 py-1.5 -mx-2">
                  {child.label}
                  {child.description && (
                    <span class="block text-xs text-gray-400 mt-0.5">{child.description}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      {blogPosts.length > 0 && (
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Блог</p>
          <div class="space-y-4">
            {blogPosts.map(post => (
              <BlogCard
                title={post.title}
                slug={post.slug}
                cover={post.cover}
                category={post.category}
                class="border-0 shadow-none hover:shadow-none"
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</div>
