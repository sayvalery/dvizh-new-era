---
/**
 * DvizhAdvantages — секция преимуществ/планов
 *
 * @example
 * ```astro
 * <DvizhAdvantages
 *   title="Почему выбирают ДВИЖ"
 *   description="Выберите решение, которое подходит вашему бизнесу"
 *   plans={[...]}
 * />
 * ```
 */

interface PlanFeature {
  label: string
}

interface Plan {
  id: string
  name: string
  price: string
  period: string
  description: string
  features: PlanFeature[]
  isDark?: boolean
  buttonHref?: string
}

interface Props {
  /** Основной заголовок */
  title: string
  /** Массив планов */
  plans: Plan[]
  /** Дополнительные CSS классы */
  class?: string
}

const {
  title,
  plans = [],
  class: className = ''
} = Astro.props

const checkIcon = 'M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z clip-rule="evenodd" fill-rule="evenodd"'
---

<div class:list={['relative isolate bg-white px-6 py-24 sm:py-32 lg:px-8', className]}>
  <!-- Декоративный градиент -->
  <div aria-hidden="true" class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl">
    <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="mx-auto aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-30"></div>
  </div>

  <!-- Заголовок -->
  <div class="mx-auto max-w-4xl text-center">
    <p class="mt-2 text-balance text-5xl font-semibold tracking-tight text-gray-900 sm:text-6xl">{title}</p>
  </div>

  <!-- Планы -->
  <div class="mx-auto mt-16 grid max-w-lg grid-cols-1 items-center gap-y-6 sm:mt-20 sm:gap-y-0 lg:max-w-4xl lg:grid-cols-2">
    {plans.map((plan, index) => {
      const isFirst = index === 0
      const isDark = plan.isDark || !isFirst
      const badgeClass = isDark ? 'text-brand-400' : 'text-brand'
      const titleClass = isDark ? 'text-brand-400' : 'text-brand'
      const textClass = isDark ? 'text-gray-300' : 'text-gray-600'
      const iconClass = isDark ? 'text-brand-400' : 'text-brand'
      const bgClass = isFirst
        ? 'rounded-3xl rounded-t-3xl bg-white/60 p-8 ring-1 ring-gray-900/10 sm:mx-8 sm:rounded-b-none sm:p-10 lg:mx-0 lg:rounded-bl-3xl lg:rounded-tr-none'
        : 'relative rounded-3xl bg-gray-900 p-8 shadow-2xl ring-1 ring-gray-900/10 sm:p-10'
      const buttonClass = isFirst
        ? 'mt-8 block rounded-md px-3.5 py-2.5 text-center text-sm font-semibold text-brand ring-1 ring-inset ring-gray-200 hover:ring-gray-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand sm:mt-10'
        : 'mt-8 block rounded-md bg-brand px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand sm:mt-10'

      return (
        <div class={bgClass}>
          <h3 id={plan.id} class:list={['text-base/7 font-semibold', badgeClass]}>{plan.name}</h3>
          <p class="mt-4 flex items-baseline gap-x-2">
            <span class:list={['text-5xl font-semibold tracking-tight', isDark ? 'text-white' : 'text-gray-900']}>{plan.price}</span>
            <span class="text-base text-gray-500">{plan.period}</span>
          </p>
          <p class:list={['mt-6 text-base/7', textClass]}>{plan.description}</p>
          <ul role="list" class:list={['mt-8 space-y-3 text-sm/6', textClass, 'sm:mt-10']}>
            {plan.features.map((feature) => (
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class:list={['h-6 w-5 flex-none', iconClass]}>
                  <path d={checkIcon} clip-rule="evenodd" fill-rule="evenodd" />
                </svg>
                {feature.label}
              </li>
            ))}
          </ul>
          <a href={plan.buttonHref || '#'} aria-describedby={plan.id} class={buttonClass}>
            {plan.buttonText}
          </a>
        </div>
      )
    })}
  </div>
</div>
