---
/**
 * ClearGlassBg — прозрачное стекло поверх изображения
 *
 * Берёт <img> из родительского контейнера, загружает как WebGL-текстуру
 * и рендерит с эффектом рифлёного стекла (displacement рёбер).
 * Картинка видна через стекло, слегка искажённая.
 *
 * 0 зависимостей, один draw call, ~3% GPU (только когда активен).
 *
 * @example
 * ```astro
 * <!-- Всегда видно -->
 * <div class="relative overflow-hidden">
 *   <img src="photo.jpg" />
 *   <ClearGlassBg />
 * </div>
 *
 * <!-- На ховер родителя -->
 * <div class="relative overflow-hidden">
 *   <img src="photo.jpg" />
 *   <ClearGlassBg trigger="hover" />
 * </div>
 *
 * <!-- Программное управление -->
 * <div class="relative overflow-hidden" data-glass-target>
 *   <img src="photo.jpg" />
 *   <ClearGlassBg trigger="event" />
 * </div>
 * <!-- JS: el.dispatchEvent(new CustomEvent('clear-glass', { detail: { active: true } })) -->
 * ```
 */

interface Props {
  /** Количество рёбер (дефолт: 8) */
  ribs?: number
  /** Количество рёбер на мобильных (<768px). Если не задан — то же что ribs */
  ribsMobile?: number
  /** Сила искажения (дефолт: 0.007) */
  strength?: number
  /** Скорость движения рёбер (дефолт: 0.6) */
  speed?: number
  /** Интенсивность зерна 0-1 (дефолт: 0) */
  grain?: number
  /** Интенсивность теней на рёбрах 0-1 (дефолт: 0) */
  shadows?: number
  /** Режим активации (дефолт: always) */
  trigger?: 'always' | 'hover' | 'event'
  /** Длительность fade in/out, ms (дефолт: 300) */
  duration?: number
  /** CSS-класс контейнера */
  class?: string
}

const {
  ribs = 4,
  ribsMobile,
  strength = 0.005,
  speed = 0.3,
  grain = 0,
  shadows = 0,
  trigger = 'always',
  duration = 300,
  class: className = ''
} = Astro.props
---

<div
  class:list={['clear-glass-bg', className]}
  style="position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:1"
  data-ribs={ribs}
  data-strength={strength}
  data-speed={speed}
  data-grain={grain}
  data-shadows={shadows}
  data-trigger={trigger}
  data-duration={duration}
>
  <canvas class="clear-glass-canvas" style="width:100%;height:100%;display:block;opacity:0"></canvas>
</div>

<script>
  function initClearGlass() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    document.querySelectorAll('.clear-glass-bg').forEach((container) => {
      const canvas = container.querySelector('.clear-glass-canvas') as HTMLCanvasElement
      if (!canvas || canvas.dataset.init) return
      canvas.dataset.init = '1'

      // Find the image in parent container
      const imgEl = container.parentElement?.querySelector('img') as HTMLImageElement | null
      if (!imgEl) return

      const gl = canvas.getContext('webgl', { alpha: false, antialias: false })
      if (!gl) return

      // --- Config from data attributes ---
      const ribCount = parseFloat(container.dataset.ribs || '8')
      const ribStrength = parseFloat(container.dataset.strength || '0.007')
      const speedVal = parseFloat(container.dataset.speed || '0.6')
      const grainVal = parseFloat(container.dataset.grain || '0')
      const shadowsVal = parseFloat(container.dataset.shadows || '0')
      const trigger = container.dataset.trigger || 'always'
      const fadeDuration = parseInt(container.dataset.duration || '300')

      canvas.style.transitionDuration = `${fadeDuration}ms`

      gl.getExtension('OES_standard_derivatives')

      const VERT = `
        attribute vec2 a_position;
        void main() { gl_Position = vec4(a_position, 0.0, 1.0); }
      `

      const FRAG = `
        #extension GL_OES_standard_derivatives : enable
        precision mediump float;
        uniform vec2 u_resolution;
        uniform float u_time;
        uniform sampler2D u_texture;

        #define RIB_COUNT ${ribCount.toFixed(1)}
        #define RIB_STRENGTH ${ribStrength.toFixed(6)}
        #define RIB_SPEED ${speedVal.toFixed(4)}
        #define GRAIN ${grainVal.toFixed(4)}
        #define SHADOWS ${shadowsVal.toFixed(4)}

        float hash21(vec2 p) {
          p = fract(p * vec2(0.3183099, 0.3678794)) + 0.1;
          p += dot(p, p + 19.19);
          return fract(p.x * p.y);
        }

        float valueNoise(vec2 st) {
          vec2 i = floor(st);
          vec2 f = fract(st);
          vec2 u = f * f * (3.0 - 2.0 * f);
          float a = hash21(i);
          float b = hash21(i + vec2(1.0, 0.0));
          float c = hash21(i + vec2(0.0, 1.0));
          float d = hash21(i + vec2(1.0, 1.0));
          return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
        }

        // UV pass-through: сохраняем оригинальное соотношение сторон img
        // Canvas и img имеют одинаковый размер (оба inset:0 в родителе)

        float smoothFract(float x) {
          float f = fract(x);
          float fw = fwidth(x);
          float edge = abs(f - 0.5) - 0.5;
          float band = smoothstep(-fw, fw, edge);
          return mix(f, 1.0 - f, band);
        }

        void main() {
          vec2 uv = gl_FragCoord.xy / u_resolution;
          uv.y = 1.0 - uv.y;

          // Glass displacement
          float patternX = uv.x * RIB_COUNT + u_time * RIB_SPEED;
          float sf = smoothFract(patternX);
          float safeBase = max(1.5 * sf, 0.001);
          float displacement = -exp(3.0 * log(safeBase)) * RIB_STRENGTH;
          float ribDist = abs(sf - 0.5) * 2.0;
          float shadow = 1.0 - SHADOWS * ribDist * ribDist;

          // Sample texture with displacement (UV 1:1 — same aspect as original img)
          vec2 sampleUV = uv + vec2(displacement, 0.0);
          sampleUV = clamp(sampleUV, 0.0, 1.0);
          vec3 color = texture2D(u_texture, sampleUV).rgb;
          color *= shadow;

          // Grain
          if (GRAIN > 0.0001) {
            vec2 grainUV = gl_FragCoord.xy * 0.8;
            float n1 = valueNoise(grainUV + vec2(u_time * 3.7, 0.0));
            float n2 = valueNoise(grainUV * 1.1 + vec2(0.0, u_time * 2.3));
            float grainVal = mix(n1, n2, 0.5);
            grainVal = grainVal * grainVal * 1.3;
            float gv = grainVal * 2.0 - 1.0;
            vec3 grainColor = vec3(step(0.0, gv));
            float grainMix = GRAIN * abs(gv);
            grainMix = grainMix * sqrt(grainMix);
            color = mix(color, grainColor, 0.35 * grainMix);
          }

          gl_FragColor = vec4(color, 1.0);
        }
      `

      // --- Compile ---
      function compileShader(type: number, src: string): WebGLShader | null {
        const s = gl.createShader(type)
        if (!s) return null
        gl.shaderSource(s, src)
        gl.compileShader(s)
        if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
          console.error('ClearGlassBg shader error:', gl.getShaderInfoLog(s))
          return null
        }
        return s
      }

      const vs = compileShader(gl.VERTEX_SHADER, VERT)
      const fs = compileShader(gl.FRAGMENT_SHADER, FRAG)
      if (!vs || !fs) return

      const program = gl.createProgram()!
      gl.attachShader(program, vs)
      gl.attachShader(program, fs)
      gl.linkProgram(program)
      if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
        console.error('ClearGlassBg link error:', gl.getProgramInfoLog(program))
        return
      }
      gl.useProgram(program)

      // --- Fullscreen quad ---
      const buf = gl.createBuffer()
      gl.bindBuffer(gl.ARRAY_BUFFER, buf)
      gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW)
      const aPos = gl.getAttribLocation(program, 'a_position')
      gl.enableVertexAttribArray(aPos)
      gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0)

      const uRes = gl.getUniformLocation(program, 'u_resolution')
      const uTime = gl.getUniformLocation(program, 'u_time')
      const uTexture = gl.getUniformLocation(program, 'u_texture')

      // --- Texture setup ---
      const texture = gl.createTexture()!
      gl.bindTexture(gl.TEXTURE_2D, texture)
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE)
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE)
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR)
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR)

      let textureReady = false
      let pendingActivation = false

      function uploadTexture(img: HTMLImageElement) {
        gl.bindTexture(gl.TEXTURE_2D, texture)
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, img)
        textureReady = true
        if (pendingActivation) {
          pendingActivation = false
          activate()
        }
      }

      // Load the image as texture (use relative path to avoid CORS)
      const texImg = new Image()
      texImg.crossOrigin = 'anonymous'
      try {
        const parsed = new URL(imgEl.src)
        texImg.src = parsed.pathname
      } catch {
        texImg.src = imgEl.src
      }
      texImg.onload = () => uploadTexture(texImg)

      // --- Resize ---
      function resize() {
        const dpr = Math.min(window.devicePixelRatio, 2)
        const w = Math.round(canvas.clientWidth * dpr)
        const h = Math.round(canvas.clientHeight * dpr)
        if (canvas.width === w && canvas.height === h) return
        canvas.width = w
        canvas.height = h
        gl.viewport(0, 0, w, h)
      }

      // --- Viewport visibility ---
      let inViewport = true
      const viewObserver = new IntersectionObserver(
        ([entry]) => { inViewport = entry.isIntersecting },
        { threshold: 0 }
      )
      viewObserver.observe(container)

      // --- Render loop (starts/stops on activation) ---
      let active = false
      let rendering = false
      let animFrameId = 0
      const t0 = performance.now()

      function render() {
        if (!rendering) return
        if (inViewport && textureReady) {
          gl.uniform2f(uRes, canvas.width, canvas.height)
          gl.uniform1f(uTime, (performance.now() - t0) / 1000)
          gl.uniform1i(uTexture, 0)
          gl.activeTexture(gl.TEXTURE0)
          gl.bindTexture(gl.TEXTURE_2D, texture)
          gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4)
        }
        animFrameId = requestAnimationFrame(render)
      }

      function startRendering() {
        if (rendering) return
        rendering = true
        resize()
        animFrameId = requestAnimationFrame(render)
      }

      function stopRendering() {
        rendering = false
        cancelAnimationFrame(animFrameId)
      }

      function activate() {
        if (active) return
        if (!textureReady) {
          pendingActivation = true
          return
        }
        active = true
        startRendering()
        canvas.style.opacity = '1'
      }

      function deactivate() {
        if (!active) return
        active = false
        pendingActivation = false
        canvas.style.opacity = '0'
        setTimeout(() => {
          if (!active) stopRendering()
        }, fadeDuration + 50)
      }

      // --- Trigger setup ---
      if (trigger === 'always') {
        if (textureReady) {
          active = true
          startRendering()
          requestAnimationFrame(() => { canvas.style.opacity = '1' })
        } else {
          pendingActivation = true
        }
      } else if (trigger === 'hover') {
        const parent = container.parentElement
        if (parent) {
          parent.addEventListener('mouseenter', activate)
          parent.addEventListener('mouseleave', deactivate)
        }
      } else if (trigger === 'event') {
        const parent = container.parentElement
        if (parent) {
          parent.addEventListener('clear-glass', ((e: CustomEvent) => {
            if (e.detail?.active) activate()
            else deactivate()
          }) as EventListener)
        }
      }

      window.addEventListener('resize', () => { if (rendering) resize() })
    })
  }

  initClearGlass()
  document.addEventListener('astro:after-swap', initClearGlass)
</script>

<style>
  .clear-glass-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .clear-glass-canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0;
    transition-property: opacity;
    transition-timing-function: ease-out;
  }
</style>
