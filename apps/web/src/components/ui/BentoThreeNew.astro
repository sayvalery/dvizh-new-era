---
/**
 * BentoThreeNew — бенто-сетка с 3 карточками (1 большая + 2 маленькие)
 *
 * Адаптивная секция с заголовком и бенто-сеткой.
 * lg+: большая карточка слева, 2 маленькие справа
 * md/sm: та же структура, но уменьшены отступы и размеры
 */

interface TextContent {
  title: string
  description: string
}

interface SmallCard {
  title?: string
  description?: string
}

interface AdaptiveTitle {
  lg: string
  md: string
  sm: string
}

interface Props {
  title: AdaptiveTitle
  bigCard: TextContent
  smallCards: SmallCard[]
  gap?: number
  class?: string
}

const {
  title,
  bigCard,
  smallCards = [],
  gap = 24,
  class: className = ''
} = Astro.props

const componentId = `bento-three-new-${Math.random().toString(36).substr(2, 9)}`
---

<section class:list={['bg-white', className]}>
  <div id={componentId} class="px-[50px] py-[48px] sm:py-[64px]">
    <div class="flex flex-col gap-12 sm:gap-16">
      <!-- Адаптивный заголовок -->
      <h2 class="text-left text-pretty text-4xl font-bold sm:text-5xl lg:text-[48px] tracking-tight" style="color: #32393e">
        <span class="hidden lg:inline">{title.lg}</span>
        <span class="hidden sm:inline lg:hidden">{title.md}</span>
        <span class="inline sm:hidden">{title.sm}</span>
      </h2>

      <!-- Bento grid -->
      <div class="flex flex-col lg:flex-row gap-[24px]">
        <!-- Большая карточка -->
        <div
          class="w-full lg:flex-1 rounded-[32px] bg-[#ececec] p-8 sm:h-[260px] lg:h-[600px]"
        >
          <div class="flex h-full items-end justify-start">
            <div class="flex flex-col gap-0.5 text-left">
              <p class="text-lg font-semibold sm:text-[20px]" style="color: #222">
                {bigCard.title}
              </p>
              <p class="text-base sm:text-[20px]" style="color: #222">
                {bigCard.description}
              </p>
            </div>
          </div>
        </div>

        <!-- Маленькие карточки (lg: вертикально, md/sm: горизонтально) -->
        <div class="w-full lg:flex-1 flex flex-row lg:flex-col gap-[24px]">
          {smallCards.map((card, index) => (
            <div
              key={index}
              class="flex-1 rounded-[32px] bg-[#ececec] p-8 sm:h-[260px] lg:h-[600px]"
            >
              <div class="flex h-full items-end justify-start">
                <div class="flex flex-col gap-0.5 text-left">
                  <p class="text-base sm:text-[20px] font-semibold" style="color: #222">
                    {card.title}
                  </p>
                  <p class="text-base sm:text-[20px]" style="color: #222">
                    {card.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
