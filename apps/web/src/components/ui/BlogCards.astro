---
/**
 * BlogCards — сетка карточек статей блога
 *
 * @example
 * ```astro
 * <BlogCards
 *   title="Из блога"
 *   description="Экспертные советы для роста вашего бизнеса"
 *   :articles="[...]"
 * />
 * ```
 */

interface Author {
  name: string
  role?: string
  avatar?: string
}

interface Article {
  image: string
  imageAlt?: string
  date: string
  category: string
  categoryHref?: string
  title: string
  description: string
  href?: string
  author?: Author
}

interface Props {
  /** Заголовок секции */
  title?: string
  /** Описание секции */
  description?: string
  /** Массив статей */
  articles: Article[]
  /** Дополнительные CSS классы */
  class?: string
}

const {
  title,
  description,
  articles,
  class: className = ''
} = Astro.props
---

<section class:list={['bg-white', className]}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    {(title || description) && (
      <div class="mx-auto max-w-2xl text-center">
        {title && (
          <h2 class="text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
            {title}
          </h2>
        )}
        {description && (
          <p class="mt-2 text-lg/8 text-gray-600">{description}</p>
        )}
      </div>
    )}

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {articles.map((article) => (
        <article class="flex flex-col items-start justify-between">
          <div class="relative w-full">
            <img
              src={article.image}
              alt={article.imageAlt || article.title}
              class="aspect-video w-full rounded-2xl bg-gray-100 object-cover sm:aspect-[2/1] lg:aspect-[3/2]"
            />
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>
          </div>
          <div class="flex max-w-xl grow flex-col justify-between">
            <div class="mt-8 flex items-center gap-x-4 text-xs">
              <time datetime={article.date} class="text-gray-500">{article.date}</time>
              {article.category && (
                <a
                  href={article.categoryHref || '#'}
                  class="relative z-10 rounded-full bg-gray-50 px-3 py-1.5 font-medium text-gray-600 hover:bg-gray-100"
                >
                  {article.category}
                </a>
              )}
            </div>
            <div class="group relative grow">
              <h3 class="mt-3 text-lg/6 font-semibold text-gray-900 group-hover:text-gray-600">
                <a href={article.href || '#'}>
                  {article.title}
                </a>
              </h3>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
