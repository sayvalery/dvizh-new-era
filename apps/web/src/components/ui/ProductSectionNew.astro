---
/**
 * ProductSectionNew — секция с меню продуктов и контентом с изображениями
 *
 * Адаптивная секция с sticky меню и скроллом к секциям.
 *
 * @example
 * ```astro
 * <ProductSectionNew
 *   sections={[
 *     { number: "01", title: "Цифровая ипотека" },
 *   ]}
 *   title={{
 *     lg: "Заголовок для больших экранов",
 *     md: "Заголовок для средних",
 *     sm: "Заголовок для мобильных"
 *   }}
 *   rightContent={{ images: ["/path/to/image.jpg"] }}
 * />
 * ```
 */

interface SectionItem {
  number: string
  title: string
  active?: boolean
}

interface Button {
  label: string
  href: string
}

interface ImageProps {
  src: string
  alt?: string
  width?: number
  height?: number
}

interface RightContent {
  images?: ImageProps[]
  title?: string
  description?: string | string[]
}

interface AdaptiveTitle {
  lg: string
  md: string
  sm: string
}

interface Props {
  sections: SectionItem[]
  title: AdaptiveTitle
  descriptions?: string[]
  primaryButton?: Button
  secondaryButton?: Button
  rightContent: RightContent | RightContent[]
  class?: string
}

const {
  sections,
  title,
  descriptions = [],
  primaryButton,
  secondaryButton,
  rightContent,
  class: className = ''
} = Astro.props

// Поддержка как единого rightContent, так и массива
const rightContents = Array.isArray(rightContent) ? rightContent : [rightContent]

const componentId = `product-section-new-${Math.random().toString(36).substr(2, 9)}`
const sectionsCount = rightContents.length
---

<section
  id={componentId}
  data-component-id={componentId}
  data-sections-count={sectionsCount}
  class:list={['bg-white', 'pb-24', className]}
>
  <div class="px-[50px] py-[50px]">
    <div class="flex flex-col gap-6 md:gap-[52px] lg:flex-row lg:gap-[120px]">
      <!-- Меню секций (sticky на lg+) -->
      <nav
        id={`${componentId}-nav`}
        class="flex justify-start gap-6 overflow-x-auto scrollbar-hide md:overflow-x-auto md:scrollbar-hide lg:sticky lg:top-[50px] lg:flex-col lg:w-[220px] lg:flex-shrink-0 lg:overflow-visible lg:h-fit lg:self-start lg:py-4"
      >
        {sections.map((section, index) => (
          <button
            data-index={index}
            data-scroll
            class="flex-shrink-0 transition-colors hover:opacity-70 text-left items-center gap-3 text-[#858585]"
          >
            <span class="w-3.5 h-3.5 rounded-full bg-gray-200"></span>
            <span class="text-base font-medium text-left">
              {section.title}
            </span>
          </button>
        ))}
      </nav>

      <!-- Контент + Right blocks -->
      <div class="flex-1 flex flex-col">
        <!-- Right blocks -->
        <div class="flex flex-col gap-24" id={`${componentId}-sections`}>
          {rightContents.map((content, index) => (
            <div
              id={`${componentId}-section-${index}`}
              class="flex flex-col gap-6 scroll-mt-[120px]"
            >
              {content.images && content.images.length > 0 && (
                <div class="rounded-[32px] bg-[#ececec] h-[300px] md:h-[300px] lg:h-[400px] flex items-center justify-center">
                  {content.images.map((image) => (
                    <img
                      src={image.src}
                      alt={image.alt || ''}
                      width={image.width}
                      height={image.height}
                      class="w-full h-full object-cover rounded-[32px]"
                      loading="lazy"
                    />
                  ))}
                </div>
              )}

              <!-- Content -->
              <div class="flex-1">
                <h1 class="text-pretty text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-gray-900">
                  {content.title || title.lg}
                </h1>

                {content.description && (
                  <div class="mt-8 space-y-2">
                    {Array.isArray(content.description) ? (
                      content.description.map((desc) => (
                        <div class="flex items-center gap-3">
                          <span class="w-2 h-2 rounded-full bg-[#D9D9D9] flex-shrink-0"></span>
                          <p class="text-base font-medium text-gray-500">
                            {desc}
                          </p>
                        </div>
                      ))
                    ) : (
                      <div class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full bg-[#D9D9D9] flex-shrink-0"></span>
                        <p class="text-base font-medium text-gray-500">
                          {content.description}
                        </p>
                      </div>
                    )}
                  </div>
                )}

                {(primaryButton || secondaryButton) && (
                  <div class="mt-8 flex flex-col sm:flex-row gap-4">
                    {primaryButton && (
                      <a
                        href={primaryButton.href}
                        class="whitespace-nowrap px-7 py-3.5 rounded-2xl bg-brand text-white text-[15px] font-medium hover:bg-brand hover:scale-[1.03] hover:shadow-xl hover:shadow-brand/25 active:scale-[0.98] transition-all duration-300 ease-out"
                      >
                        {primaryButton.label}
                      </a>
                    )}
                    {secondaryButton && (
                      <a
                        href={secondaryButton.href}
                        class="whitespace-nowrap px-7 py-3.5 rounded-2xl bg-black/[0.04] text-[#1b2226] text-[15px] font-medium hover:bg-black/[0.08] hover:scale-[1.03] hover:shadow-xl active:scale-[0.98] transition-all duration-300 ease-out"
                      >
                        {secondaryButton.label}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Ищем элемент с атрибутом data-component-id
      const section = document.querySelector('[data-component-id][data-sections-count]')
      if (!section) {
        console.error('[ProductSectionNew] Component element not found')
        return
      }

      const componentId = section.dataset.componentId
      const sectionsCount = parseInt(section.dataset.sectionsCount)

      console.log('[ProductSectionNew] Initializing, componentId:', componentId, 'sectionsCount:', sectionsCount)

      const nav = document.getElementById(`${componentId}-nav`)
      const buttons = nav?.querySelectorAll('button[data-scroll]')

      console.log('[ProductSectionNew] Nav found:', !!nav, 'Buttons found:', buttons?.length)

      if (!buttons || buttons.length === 0) {
        console.error('[ProductSectionNew] No buttons found!')
        return
      }

      // Устанавливаем первую кнопку активной
      buttons.forEach((btn, idx) => {
        if (idx === 0) {
          btn.classList.remove('text-[#858585]')
          btn.classList.add('text-brand')
        }
      })

      // Обработчик кликов по меню
      buttons.forEach(button => {
        button.addEventListener('click', (e) => {
          e.preventDefault()
          const index = parseInt(button.dataset.index)
          console.log('[ProductSectionNew] Click on button index:', index)

          const targetSection = document.getElementById(`${componentId}-section-${index}`)
          console.log('[ProductSectionNew] Target section:', !!targetSection)

          if (targetSection) {
            const offset = 100
            const elementPosition = targetSection.getBoundingClientRect().top
            const offsetPosition = elementPosition + window.pageYOffset - offset
            window.scrollTo({
              top: offsetPosition,
              behavior: 'smooth'
            })
          }
        })
      })

      // Intersection Observer для автоподсветки
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const sectionId = entry.target.id
            const indexMatch = sectionId.match(new RegExp(`${componentId}-section-(\\d+)`))
            const index = indexMatch ? parseInt(indexMatch[1]) : -1
            console.log('[ProductSectionNew] Intersection:', sectionId, 'index:', index)

            if (index !== -1) {
              buttons.forEach(btn => {
                const btnIndex = parseInt(btn.dataset.index)
                if (btnIndex === index) {
                  btn.classList.remove('text-[#858585]')
                  btn.classList.add('text-brand')
                } else {
                  btn.classList.remove('text-brand')
                  btn.classList.add('text-[#858585]')
                }
              })
            }
          }
        })
      }, {
        threshold: 0.3,
        rootMargin: '-100px 0px -70% 0px'
      })

      // Наблюдаем за секциями
      for (let i = 0; i < sectionsCount; i++) {
        const sectionEl = document.getElementById(`${componentId}-section-${i}`)
        if (sectionEl) {
          observer.observe(sectionEl)
          console.log('[ProductSectionNew] Observing section:', sectionEl.id)
        }
      }

      console.log('[ProductSectionNew] Init complete')
    })
  </script>
</section>
