---
/**
 * ProductSectionNew — секция с меню продуктов и контентом с изображениями
 *
 * Адаптивная секция с заголовками для разных брейкпоинтов (lg+, md, sm).
 * Правый блок содержит изображения.
 *
 * @example
 * ```astro
 * <ProductSectionNew
 *   sections={[
 *     { number: "01", title: "Цифровая ипотека", active: true },
 *   ]}
 *   title={{
 *     lg: "Заголовок для больших экранов",
 *     md: "Заголовок для средних",
 *     sm: "Заголовок для мобильных"
 *   }}
 *   rightContent={{ images: ["/path/to/image.jpg"] }}
 * />
 * ```
 */

interface SectionItem {
  number: string
  title: string
  active?: boolean
}

interface Button {
  label: string
  href: string
}

interface ImageProps {
  src: string
  alt?: string
  width?: number
  height?: number
}

interface RightContent {
  images?: ImageProps[]
  description?: string
}

interface AdaptiveTitle {
  lg: string
  md: string
  sm: string
}

interface Props {
  sections: SectionItem[]
  title: AdaptiveTitle
  descriptions?: string[]
  primaryButton?: Button
  secondaryButton?: Button
  rightContent: RightContent
  class?: string
}

const {
  sections,
  title,
  descriptions = [],
  primaryButton,
  secondaryButton,
  rightContent,
  class: className = ''
} = Astro.props

const componentId = `product-section-new-${Math.random().toString(36).substr(2, 9)}`
---

<section class:list={['bg-white', className]}>
  <div id={componentId} class="px-[50px] py-[50px]">
    <div class="flex flex-col gap-6 md:gap-[52px] lg:flex-row lg:gap-[120px]">
      <!-- Меню секций (md-sm: сверху горизонтально с scroll, lg+: слева вертикально) -->
      <nav class="flex gap-6 overflow-x-auto scrollbar-hide lg:flex-col lg:w-[220px] lg:flex-shrink-0 lg:overflow-visible">
        {sections.map((section, index) => (
          <button
            class:list={[
              'flex-shrink-0 transition-colors hover:opacity-70',
              index === 0 ? 'text-brand' : 'text-[#858585]'
            ]}
          >
            <span class="text-base font-medium">
              {section.title}
            </span>
          </button>
        ))}
      </nav>

      <!-- Контент + Right block -->
      <div class="flex-1 flex flex-col md:flex-col lg:flex-row lg:gap-6">
        <!-- Right block (md-sm: сверху контента, lg+: справа) -->
        {rightContent.images && rightContent.images.length > 0 && (
          <div class="order-1 mb-6 md:mb-6 lg:order-2 lg:mb-0 lg:h-full">
            <div class="rounded-[32px] bg-[#ececec] h-[300px] md:h-[300px] lg:h-full flex items-center justify-center">
              {rightContent.images.map((image) => (
                <img
                  src={image.src}
                  alt={image.alt || ''}
                  width={image.width}
                  height={image.height}
                  class="w-full h-full object-contain rounded-[32px]"
                  loading="lazy"
                />
              ))}
            </div>
          </div>
        )}

        <!-- Left content (md-sm: снизу, lg+: слева) -->
        <div class="order-2 md:order-2 lg:order-1 flex-1 lg:min-w-[420px] lg:max-w-[590px]">
          <!-- Адаптивный заголовок -->
          <h1 class="text-pretty text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-gray-900">
            <span class="hidden lg:inline">{title.lg}</span>
            <span class="hidden md:inline lg:hidden">{title.md}</span>
            <span class="inline md:hidden">{title.sm}</span>
          </h1>

          <!-- Описания -->
          {descriptions.length > 0 && (
            <div class="mt-6 space-y-1">
              {descriptions.map((desc) => (
                <p class="text-pretty text-base font-medium text-gray-500 sm:text-lg/8">
                  {desc}
                </p>
              ))}
            </div>
          )}

          <!-- Кнопки -->
          {(primaryButton || secondaryButton) && (
            <div class="mt-8 flex items-center gap-x-6">
              {primaryButton && (
                <a
                  href={primaryButton.href}
                  class="rounded-md bg-brand px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                >
                  {primaryButton.label}
                </a>
              )}
              {secondaryButton && (
                <a
                  href={secondaryButton.href}
                  class="text-sm/6 font-semibold text-gray-900"
                >
                  {secondaryButton.label} <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
