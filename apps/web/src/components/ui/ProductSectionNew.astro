---
/**
 * ProductSectionNew — секция с меню продуктов и контентом с изображениями
 *
 * Адаптивная секция с заголовками для разных брейкпоинтов (lg+, md, sm).
 * Правый блок содержит изображения.
 *
 * @example
 * ```astro
 * <ProductSectionNew
 *   sections={[
 *     { number: "01", title: "Цифровая ипотека", active: true },
 *   ]}
 *   title={{
 *     lg: "Заголовок для больших экранов",
 *     md: "Заголовок для средних",
 *     sm: "Заголовок для мобильных"
 *   }}
 *   rightContent={{ images: ["/path/to/image.jpg"] }}
 * />
 * ```
 */

interface SectionItem {
  number: string
  title: string
  active?: boolean
}

interface Button {
  label: string
  href: string
}

interface ImageProps {
  src: string
  alt?: string
  width?: number
  height?: number
}

interface RightContent {
  images?: ImageProps[]
  title?: string
  description?: string | string[]
}

interface AdaptiveTitle {
  lg: string
  md: string
  sm: string
}

interface Props {
  sections: SectionItem[]
  title: AdaptiveTitle
  descriptions?: string[]
  primaryButton?: Button
  secondaryButton?: Button
  rightContent: RightContent | RightContent[]
  class?: string
}

const {
  sections,
  title,
  descriptions = [],
  primaryButton,
  secondaryButton,
  rightContent,
  class: className = ''
} = Astro.props

// Поддержка как единого rightContent, так и массива
const rightContents = Array.isArray(rightContent) ? rightContent : [rightContent]

const componentId = `product-section-new-${Math.random().toString(36).substr(2, 9)}`
---

<section class:list={['bg-white', className]}>
  <div id={componentId} class="px-[50px] py-[50px]">
    <div class="flex flex-col gap-6 md:gap-[52px] lg:flex-row lg:gap-[120px]">
      <!-- Меню секций (sm: scroll, md+: scroll, lg+: колонка) -->
      <nav class="flex justify-start gap-6 overflow-x-auto scrollbar-hide md:overflow-x-auto md:scrollbar-hide lg:flex-col lg:w-[220px] lg:flex-shrink-0 lg:overflow-visible">
        {sections.map((section, index) => (
          <button
            class:list={[
              'flex-shrink-0 transition-colors hover:opacity-70 text-left',
              index === 0 ? 'text-brand' : 'text-[#858585]'
            ]}
          >
            <span class="text-base font-medium text-left">
              {section.title}
            </span>
          </button>
        ))}
      </nav>

      <!-- Контент + Right blocks -->
      <div class="flex-1 flex flex-col md:flex-col lg:flex-col lg:gap-6">
        <!-- Right blocks (всегда сверху) -->
        <div class="order-1 mb-6 md:mb-6 lg:mb-6 lg:h-full flex flex-col gap-24">
          {rightContents.map((content) => (
            <div class="flex flex-col gap-6">
              {content.images && content.images.length > 0 && (
                <div class="rounded-[32px] bg-[#ececec] h-[300px] md:h-[300px] lg:h-full flex items-center justify-center">
                  {content.images.map((image) => (
                    <img
                      src={image.src}
                      alt={image.alt || ''}
                      width={image.width}
                      height={image.height}
                      class="w-full h-full object-contain rounded-[32px]"
                      loading="lazy"
                    />
                  ))}
                </div>
              )}

              <!-- Left content для каждого блока -->
              <div class="flex-1">
                <h1 class="text-pretty text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-gray-900">
                  {content.title || title.lg}
                </h1>

                {content.description && (
                  <div class="mt-8 space-y-2">
                    {Array.isArray(content.description) ? (
                      content.description.map((desc) => (
                        <p class="text-base font-medium text-gray-500">
                          {desc}
                        </p>
                      ))
                    ) : (
                      <p class="text-base font-medium text-gray-500">
                        {content.description}
                      </p>
                    )}
                  </div>
                )}

                {(primaryButton || secondaryButton) && (
                  <div class="mt-8 flex items-center gap-x-6">
                    {primaryButton && (
                      <a
                        href={primaryButton.href}
                        class="rounded-md bg-brand px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600"
                      >
                        {primaryButton.label}
                      </a>
                    )}
                    {secondaryButton && (
                      <a
                        href={secondaryButton.href}
                        class="text-sm/6 font-semibold text-gray-900"
                      >
                        {secondaryButton.label} <span aria-hidden="true">→</span>
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
