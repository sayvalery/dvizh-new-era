---
/**
 * FormClosing — панель в конце страницы с формой
 *
 * Тёмный фон с градиентом, заголовок, описание, изображение справа, форма слева.
 *
 * @example
 * ```astro
 * <FormClosing
 *   preset="lead"
 *   title="Начните пользоваться приложением сегодня"
 *   description="Автоматизируйте рабочие процессы и повышайте эффективность."
 *   image="/app-screenshot.png"
 * />
 * ```
 */

import Form from './Form.astro'

interface Props {
  /** Пресет полей формы */
  preset: 'lead' | 'subscribe' | 'demo' | 'research'
  /** Заголовок */
  title: string
  /** Описание */
  description?: string
  /** URL изображения справа */
  image?: string
  /** Alt-текст для изображения */
  imageAlt?: string
  /** Текст на кнопке отправки */
  submitLabel?: string
  /** Дополнительные CSS классы */
  class?: string
}

const {
  preset,
  title,
  description,
  image,
  imageAlt = 'Image',
  submitLabel,
  class: className = ''
} = Astro.props
---

<section class:list={['relative isolate overflow-hidden bg-gray-900 px-6 pt-16 shadow-2xl sm:rounded-3xl sm:px-16 md:pt-24 lg:flex lg:gap-x-20 lg:px-24 lg:pt-0', className]}>
  <!-- Градиентный круг -->
  <svg viewBox="0 0 1024 1024" aria-hidden="true" class="absolute left-1/2 top-1/2 -z-10 size-[64rem] -translate-y-1/2 [mask-image:radial-gradient(closest-side,white,transparent)] sm:left-full sm:-ml-80 lg:left-1/2 lg:ml-0 lg:-translate-x-1/2 lg:translate-y-0">
    <circle r="512" cx="512" cy="512" fill="url(#gradient-circle-closing)" fill-opacity="0.7" />
    <defs>
      <radialGradient id="gradient-circle-closing">
        <stop stop-color="#7775D6" />
        <stop offset="1" stop-color="#E935C1" />
      </radialGradient>
    </defs>
  </svg>

  <div class="mx-auto max-w-xl text-center lg:mx-0 lg:flex-auto lg:py-32 lg:text-left">
    <h2 class="text-balance text-3xl font-semibold text-white sm:text-4xl">
      {title}
    </h2>
    {description && (
      <p class="mt-6 text-pretty text-lg/8 text-gray-300">
        {description}
      </p>
    )}
    <div class="mt-10 flex items-center justify-center gap-x-6 lg:justify-start">
      <Form preset={preset} layout="inline" variant="dark" submitLabel={submitLabel} />
    </div>
  </div>

  <div class="relative mt-16 h-80 lg:mt-8">
    {image ? (
      <img
        src={image}
        alt={imageAlt}
        class="absolute left-0 top-0 w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="absolute left-0 top-0 w-full h-full bg-gray-700" />
    )}
  </div>
</section>
