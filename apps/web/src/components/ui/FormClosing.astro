---
/**
 * FormClosing — панель в конце страницы с формой
 *
 * Тёмный фон с градиентом, заголовок, описание, изображение справа, форма слева.
 *
 * @example
 * ```astro
 * <FormClosing
 *   preset="lead"
 *   title="Начните пользоваться приложением сегодня"
 *   description="Автоматизируйте рабочие процессы и повышайте эффективность."
 *   image="/app-screenshot.png"
 * />
 * ```
 */

import Form from './Form.astro'

interface Props {
  /** Пресет полей формы */
  preset: 'lead' | 'subscribe' | 'demo' | 'research'
  /** Заголовок */
  title: string
  /** Описание */
  description?: string
  /** URL изображения справа */
  image?: string
  /** Alt-текст для изображения */
  imageAlt?: string
  /** Текст на кнопке отправки */
  submitLabel?: string
  /** Цвет фона (hex или Tailwind класс) */
  bgColor?: string
  /** Фоновое изображение всей формы */
  bgImage?: string
  /** Позиция фонового изображения */
  bgImagePosition?: 'center' | 'right' | 'left' | 'top' | 'bottom' | 'top right' | 'top left' | 'right top' | 'bottom right' | 'right bottom' | 'bottom left' | 'left bottom'
  /** Начальный цвет градиентного круга */
  gradientStart?: string
  /** Конечный цвет градиентного круга */
  gradientEnd?: string
  /** Показывать градиентный круг */
  showGradient?: boolean
  /** Цвет текста заголовка и описания */
  textColor?: string
  /** Вариант формы (light/dark) */
  formVariant?: 'light' | 'dark'
  /** Текст о персональных данных */
  privacyText?: string
  /** Дополнительные CSS классы */
  class?: string
}

const {
  preset,
  title,
  description,
  image,
  imageAlt = 'Image',
  submitLabel,
  bgColor,
  bgImage,
  bgImagePosition = 'center',
  gradientStart = '#7775D6',
  gradientEnd = '#E935C1',
  showGradient = true,
  textColor = 'text-white',
  formVariant,
  privacyText,
  class: className = ''
} = Astro.props

// Если bgColor задан как класс (не hex), определяем является ли фон светлым
const isLightBg = bgColor && !bgColor.startsWith('#') && (bgColor.includes('gray-50') || bgColor.includes('gray-100') || bgColor.includes('gray-200') || bgColor.includes('gray-300'))
const formVariantResolved = formVariant ?? (isLightBg ? 'light' : 'dark')
const textColorResolved = textColor === 'text-white' && isLightBg ? 'text-gray-900' : textColor
const descriptionColor = isLightBg ? 'text-gray-600' : 'text-gray-300'
const privacyColor = isLightBg ? 'text-gray-400' : 'text-gray-400'

// Стиль для фона: цвет, изображение или комбинация
const backgroundStyle = bgImage
  ? `background-image: url('${bgImage}'); background-size: cover; background-position: ${bgImagePosition}; ${bgColor ? `background-color: ${bgColor};` : ''}`
  : bgColor?.startsWith('#') || bgColor?.startsWith('rgb')
    ? `background-color: ${bgColor}`
    : ''

// Генерируем уникальный ID для градиента (для поддержки нескольких экземпляров)
const gradientId = `gradient-circle-closing-${Math.random().toString(36).slice(2)}`
---

<section
  class:list={['relative isolate overflow-hidden px-6 pt-[5rem] pb-2 sm:rounded-3xl sm:px-16 sm:pt-[5rem] sm:pb-2 md:pt-[5rem] md:pb-2 lg:flex lg:gap-x-20 lg:px-24 lg:pt-[5rem] lg:pb-2', (!bgImage && (bgColor || 'bg-gray-900')), className]}
  style={backgroundStyle}
>
  <!-- Градиентный круг -->
  {showGradient && (
    <svg viewBox="0 0 1024 1024" aria-hidden="true" class="absolute left-1/2 top-1/2 -z-10 size-[64rem] -translate-y-1/2 [mask-image:radial-gradient(closest-side,white,transparent)] sm:left-full sm:-ml-80 lg:left-1/2 lg:ml-0 lg:-translate-x-1/2 lg:translate-y-0">
      <circle r="512" cx="512" cy="512 fill={`url(#${gradientId})`} fill-opacity="0.7" />
      <defs>
        <radialGradient id={gradientId}>
          <stop stop-color={gradientStart} />
          <stop offset="1" stop-color={gradientEnd} />
        </radialGradient>
      </defs>
    </svg>
  )}

  <div class="mx-auto max-w-3xl text-center lg:mx-0 lg:text-left">
    <h2 class={`text-balance text-3xl font-semibold sm:text-4xl ${textColorResolved}`}>
      {title}
    </h2>
    {description && (
      <p class={`mt-6 text-pretty text-lg/8 ${descriptionColor}`}>
        {description}
      </p>
    )}
    <div class="mt-10 flex items-center justify-center gap-x-6 lg:justify-start">
      <Form preset={preset} layout="inline" variant={formVariantResolved} submitLabel={submitLabel} />
    </div>
    {privacyText && (
      <p class={`mt-4 text-sm ${privacyColor}`}>
        {privacyText}
      </p>
    )}
  </div>

  <div class="relative mt-8 h-80">
    {image ? (
      <img
        src={image}
        alt={imageAlt}
        class="absolute left-0 top-0 w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="absolute left-0 top-0 w-full h-full bg-gray-700" />
    )}
  </div>
</section>
