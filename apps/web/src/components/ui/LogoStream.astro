---
/**
 * LogoStream — поток логотипов с эффектом глубины (чистый CSS)
 *
 * Логотипы появляются крупными слева-снизу,
 * пролетают через фокусную зону, уменьшаются и уходят далеко вправо-вверх.
 *
 * Ноль JavaScript. Ноль библиотек. Чистые CSS transforms + filter.
 */

interface Props {
  /** Массив URL логотипов (SVG рекомендуется) */
  logos: string[]
  /** Длительность полного цикла в секундах */
  duration?: number
  /** Ширина логотипа в px */
  logoWidth?: number
  /** Высота логотипа в px */
  logoHeight?: number
  /** Дополнительные CSS классы */
  class?: string
}

const {
  logos,
  duration = 35,
  logoWidth = 160,
  logoHeight = 56,
  class: className = ''
} = Astro.props

const count = logos.length
---

<div class:list={['logo-stream', className]}>
  {logos.map((logo, i) => (
    <div
      class="logo-stream-item"
      style={`
        animation-duration: ${duration}s;
        animation-delay: ${((-i * duration) / count).toFixed(2)}s;
      `}
    >
      <img
        src={logo}
        alt=""
        style={`width: ${logoWidth}px; height: ${logoHeight}px;`}
        loading="lazy"
      />
    </div>
  ))}
</div>

<style>
  .logo-stream {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .logo-stream-item {
    position: absolute;
    top: 50%;
    left: 35%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation-name: stream-fly;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform, opacity;
    pointer-events: none;
    user-select: none;
  }

  .logo-stream-item img {
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  /*
   * Путь: большой слева-снизу → фокус в начале → долгий уход вправо-вверх
   *
   * Линейная интерполяция позиций. Фокус сдвинут к началу (~15%).
   * Быстрый вход, долгий затухающий выход.
   */
  @keyframes stream-fly {
    0% {
      transform: translate(-50%, -50%) translate(-100px, 200px) scale(1.50);
      opacity: 0;
    }
    11% {
      transform: translate(-50%, -50%) translate(-67px, 136px) scale(1.37);
      opacity: 0.8;
    }
    22% {
      transform: translate(-50%, -50%) translate(-34px, 72px) scale(1.24);
      opacity: 1;
    }
    33% {
      transform: translate(-50%, -50%) translate(-1px, 9px) scale(1.10);
      opacity: 0.7;
    }
    44% {
      transform: translate(-50%, -50%) translate(32px, -54px) scale(0.97);
      opacity: 0.4;
    }
    55% {
      transform: translate(-50%, -50%) translate(65px, -119px) scale(0.84);
      opacity: 0.2;
    }
    66% {
      transform: translate(-50%, -50%) translate(98px, -183px) scale(0.71);
      opacity: 0.1;
    }
    77% {
      transform: translate(-50%, -50%) translate(131px, -247px) scale(0.58);
      opacity: 0.03;
    }
    88% {
      transform: translate(-50%, -50%) translate(164px, -310px) scale(0.44);
      opacity: 0;
    }
    100% {
      transform: translate(-50%, -50%) translate(200px, -380px) scale(0.30);
      opacity: 0;
    }
  }
</style>
