---
/**
 * BentoGrid — сетка карточек (2 колонки)
 *
 * @example
 * ```astro
 * <BentoGrid
 *   items={[
 *     { label: "Releases", title: "Push to deploy", description: "...", image: "/releases.png" },
 *     { label: "Integrations", title: "Connect tools", description: "..." }
 *   ]}
 * />
 * ```
 */

interface BentoItem {
  /** Заголовок карточки */
  title: string
  /** Изображение */
  image?: string
  /** Alt-текст изображения */
  imageAlt?: string
}

interface Props {
  /** Карточки сетки */
  items: BentoItem[]
  /** Дополнительные CSS классы */
  class?: string
}

const {
  items,
  class: className = ''
} = Astro.props

// Скругления углов для карточек
const getCardClass = (index: number) => {
  const classes = ['w-full overflow-hidden rounded-lg bg-white shadow outline outline-1 outline-black/5']

  // Скругляем внешние углы сетки
  if (index === 0) classes.push('lg:rounded-tl-[2rem]', 'max-lg:rounded-t-[2rem]')
  if (index === 1) classes.push('lg:rounded-tr-[2rem]')
  if (index === items.length - 2) classes.push('lg:rounded-bl-[2rem]')
  if (index === items.length - 1) classes.push('lg:rounded-br-[2rem]', 'max-lg:rounded-b-[2rem]')

  return classes.join(' ')
}
---

<div class:list={['grid grid-cols-1 gap-4 lg:grid-cols-2', className]}>
  {items.map((item, index) => (
    <div class="flex p-px">
      <div class={getCardClass(index)}>
        {item.image && (
          <img
            src={item.image}
            alt={item.imageAlt || item.title}
            class="h-80 w-full object-cover"
          />
        )}
        <div class="p-10">
          <p class="text-lg font-medium tracking-tight text-gray-900">{item.title}</p>
        </div>
      </div>
    </div>
  ))}
</div>
