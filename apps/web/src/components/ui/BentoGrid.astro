---
/**
 * BentoGrid — сетка карточек
 *
 * @example
 * ```astro
 * <BentoGrid
 *   columns={3}
 *   items={[
 *     { title: "Push to deploy", image: "/releases.png" },
 *     { title: "Connect tools" },
 *     { title: "Analytics" }
 *   ]}
 * />
 * ```
 */

interface BentoItem {
  /** Заголовок карточки */
  title: string
  /** Изображение */
  image?: string
  /** Alt-текст изображения */
  imageAlt?: string
}

interface Props {
  /** Карточки сетки */
  items: BentoItem[]
  /** Количество колонок: 2 (по умолчанию) или 3 */
  columns?: 2 | 3
  /** Дополнительные CSS классы */
  class?: string
}

const {
  items,
  columns = 2,
  class: className = ''
} = Astro.props

// Классы сетки
const gridClass = columns === 3
  ? 'grid grid-cols-1 gap-4 lg:grid-cols-3'
  : 'grid grid-cols-1 gap-4 lg:grid-cols-2'

// Скругления углов для карточек
const getCardClass = (index: number) => {
  return 'w-full overflow-hidden rounded-[40px] bg-[#F8F8F8]'
}
---

<div class:list={[gridClass, className]}>
  {items.map((item, index) => (
    <div class="flex p-px">
      <div class={getCardClass(index)}>
        {item.image ? (
          <img
            src={item.image}
            alt={item.imageAlt || item.title}
            class="h-80 w-full object-cover"
          />
        ) : (
          <div class="h-80 w-full bg-gray-100" />
        )}
        <div class="p-10">
          <p class="text-lg font-medium tracking-tight text-gray-900">{item.title}</p>
        </div>
      </div>
    </div>
  ))}
</div>
