---
/**
 * BentoGrid — сетка карточек
 *
 * @example
 * ```astro
 * <BentoGrid
 *   columns={3}
 *   items={[
 *     { title: "Push to deploy", image: "/releases.png" },
 *     { title: "Connect tools" },
 *     { title: "Analytics" }
 *   ]}
 * />
 * ```
 */

interface BentoItem {
  /** Заголовок карточки */
  title: string
  /** Изображение */
  image?: string
  /** Alt-текст изображения */
  imageAlt?: string
}

interface Props {
  /** Карточки сетки */
  items: BentoItem[]
  /** Количество колонок: 2 (по умолчанию) или 3 */
  columns?: 2 | 3
  /** Дополнительные CSS классы */
  class?: string
}

const {
  items,
  columns = 2,
  class: className = ''
} = Astro.props

// Классы сетки
const gridClass = columns === 3
  ? 'grid grid-cols-1 gap-4 lg:grid-cols-3'
  : 'grid grid-cols-1 gap-4 lg:grid-cols-2'

// Скругления углов для карточек
const getCardClass = (index: number) => {
  return 'w-full overflow-hidden rounded-[40px] bg-[#F8F8F8]'
}
---

<div class:list={[gridClass, className]}>
  {items.map((item, index) => (
    <div class="flex p-px">
      <div class={getCardClass(index)}>
        <div class="flex flex-col items-start gap-6 px-10 py-8">
          {item.image ? (
            <img
              src={item.image}
              alt={item.imageAlt || item.title}
              class="h-[140px] w-[140px] shrink-0 rounded-lg object-cover"
            />
          ) : (
            <div class="h-[140px] w-[140px] shrink-0 rounded-[24px] border border-dashed border-[#858585]"></div>
          )}
          {/<[a-z][\s\S]*>/i.test(item.title) ? (
            <h3 class="text-xl font-medium tracking-tight text-gray-900" set:html={item.title} />
          ) : (
            <h3 class="text-xl font-medium tracking-tight text-gray-900">{item.title}</h3>
          )}
        </div>
      </div>
    </div>
  ))}
</div>
