---
/**
 * NavBar — навигационная шапка-островок
 *
 * Desktop: per-item hover-попапы (complex с иконками, simple без)
 * Mobile:  аккордеон (accordion-style раскрытие)
 *
 * Прозрачный режим (transparent=true):
 *   clear = true  → островок без фона, белый текст (поверх hero)
 *   clear = false → белый островок с тенью
 *
 * Мега-меню (legacy): сохранено в MegaMenu.astro, здесь не используется.
 * Prop `sections` в NavItem оставлен для обратной совместимости.
 */

import BlogCard from './BlogCard.astro'

export interface NavChild {
  label: string
  href: string
  description?: string
  /** SVG path data (без <svg> обёртки). Пример: '<path stroke-linecap="round" d="M2.25..." />' */
  icon?: string
}

export interface NavSection {
  title: string
  items: NavChild[]
}

export interface NavItem {
  label: string
  href?: string
  children?: NavChild[]
  /** @deprecated — legacy мега-меню. Сохранён в MegaMenu.astro. */
  sections?: NavSection[]
  badge?: 'dot'
}

interface BlogPost {
  title: string
  slug: string
  cover?: { url?: string; alt?: string }
  category?: string
}

interface Props {
  logo: { label: string; href: string; image?: string; imageLight?: string }
  items?: NavItem[]
  blogPosts?: BlogPost[]
  secondaryLink?: { label: string; href: string }
  cta?: { label: string; preset?: string }
  transparent?: boolean
}

const { logo, items = [], blogPosts = [], secondaryLink, cta, transparent = false } = Astro.props
---

<header
  x-data={`{
    mobileOpen: false,
    openMenu: null,
    hoverTimer: null,
    lastY: 0,
    hidden: false,
    openNav(id) { clearTimeout(this.hoverTimer); this.openMenu = id; },
    startClose(id) { this.hoverTimer = setTimeout(() => { if (this.openMenu === id) this.openMenu = null; }, 200); },
    cancelClose() { clearTimeout(this.hoverTimer); },
    get clear() { return ${transparent} && !this.mobileOpen && this.lastY < 450 },
    onScroll() {
      const y = window.scrollY;
      if (y < 100) { this.hidden = false }
      else if (y < this.lastY - 5) { this.hidden = false }
      else if (y > this.lastY + 5) { this.hidden = true }
      this.lastY = y;
    }
  }`}
  x-init="lastY = window.scrollY"
  @scroll.window.throttle.100ms="onScroll()"
  class:list={[transparent ? 'fixed top-0 left-0 right-0 z-40' : 'sticky top-0 z-40']}
  :class="hidden && !mobileOpen && !openMenu ? '-translate-y-full' : 'translate-y-0'"
  class="transition-transform duration-300"
>
  <!-- Gradient blur backdrop (transparent mode) -->
  <div x-show="clear" x-transition.opacity.duration.300ms class="nav-blur-fade"></div>
  <div x-show="clear" x-transition.opacity.duration.300ms class="nav-blur-fade nav-blur-strong"></div>

  <!-- Island wrapper — фон только на самом островке, не на всю ширину -->
  <div class="max-w-[1440px] mx-auto px-4 py-3">
    <nav
      class="flex items-center justify-between -mx-2 px-4 h-14 rounded-2xl transition-all duration-200"
      :class="clear ? '' : 'bg-white/80 backdrop-blur-lg'"
    >
      <!-- Лого -->
      <div class="flex items-center gap-6">
        <a href={logo.href} class="flex-shrink-0">
          {logo.image && logo.imageLight && transparent ? (
            <>
              <img src={logo.image} alt={logo.label} class="h-7 w-auto" x-show="!clear" x-cloak />
              <img src={logo.imageLight} alt={logo.label} class="h-7 w-auto" x-show="clear" />
            </>
          ) : logo.image ? (
            <img src={logo.image} alt={logo.label} class="h-7 w-auto" />
          ) : (
            <span class="font-bold text-xl">{logo.label}</span>
          )}
        </a>

        <!-- Desktop-навигация -->
        <div class="hidden md:flex md:gap-x-0.5">
          {items.map(item => (
            item.children?.length ? (
              /* === DROPDOWN ITEM === */
              <div class="relative">
                <button
                  class="flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors"
                  :class="clear ? 'text-white hover:bg-white/10' : 'text-gray-700 hover:bg-gray-100'"
                  @mouseenter={`openNav('${item.label}')`}
                  @mouseleave={`startClose('${item.label}')`}
                >
                  {item.label}
                  <svg
                    class="w-3.5 h-3.5 transition-transform duration-200"
                    :class={`openMenu === '${item.label}' ? 'rotate-180' : ''`}
                    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <!-- Попап -->
                <div
                  x-cloak
                  x-show={`openMenu === '${item.label}'`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 -translate-y-1"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-1"
                  class="absolute top-full left-0 pt-3 z-50"
                  @mouseenter="cancelClose()"
                  @mouseleave={`startClose('${item.label}')`}
                >
                  {item.children.some(c => c.description) ? (
                    /* COMPLEX — с иконками и описаниями */
                    <div class="w-[440px] overflow-hidden rounded-3xl bg-white shadow-lg ring-1 ring-gray-900/5">
                      <div class="p-4">
                        {item.children.map(child => (
                          <div class="group relative flex items-center gap-4 rounded-lg p-3 text-sm hover:bg-gray-50 transition-colors">
                            {child.icon && (
                              <div class="flex size-10 flex-none items-center justify-center rounded-lg bg-gray-50 group-hover:bg-white transition-colors">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                  aria-hidden="true"
                                  class="size-6 text-gray-500 group-hover:text-brand transition-colors"
                                >
                                  <Fragment set:html={child.icon} />
                                </svg>
                              </div>
                            )}
                            <div class="flex-auto min-w-0">
                              <a href={child.href} class="block font-semibold text-gray-900">
                                {child.label}
                                <span class="absolute inset-0" />
                              </a>
                              {child.description && (
                                <p class="mt-0.5 text-xs text-gray-500 leading-relaxed">{child.description}</p>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  ) : (
                    /* SIMPLE — компактный список */
                    <div class="w-72 overflow-hidden rounded-xl bg-white p-2 shadow-lg ring-1 ring-gray-900/5">
                      {item.children.map(child => (
                        <a
                          href={child.href}
                          class="block rounded-lg px-3 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 transition-colors whitespace-nowrap"
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ) : (
              /* === FLAT LINK === */
              <a
                href={item.href}
                class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors"
                :class="clear ? 'text-white hover:bg-white/10' : 'text-gray-700 hover:bg-gray-100'"
              >
                {item.label}
                {item.badge === 'dot' && (
                  <span
                    class="w-1.5 h-1.5 rounded-full flex-shrink-0 transition-colors"
                    :class="clear ? 'bg-white' : 'bg-red-500'"
                  />
                )}
              </a>
            )
          ))}
        </div>
      </div>

      <!-- Правая часть: телефон + CTA + гамбургер -->
      <div class="flex items-center gap-4">
        {secondaryLink && (
          <a
            href={secondaryLink.href}
            class="hidden md:block text-sm font-medium transition-colors"
            :class="clear ? 'text-white/80 hover:text-white' : 'text-gray-500 hover:text-gray-900'"
          >
            {secondaryLink.label}
          </a>
        )}
        {cta && (
          <button
            class="hidden md:block text-sm font-medium px-4 py-2 rounded-lg transition-all duration-200 hover:opacity-90 active:scale-[0.98]"
            :class="clear ? 'bg-white text-gray-900' : 'bg-black text-white'"
            @click={`$dispatch('open-drawer', { preset: '${cta.preset ?? 'demo'}' })`}
          >
            {cta.label}
          </button>
        )}
        <button
          type="button"
          @click="mobileOpen = true"
          class="md:hidden -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 transition-colors"
          :class="clear ? 'text-white' : 'text-gray-700'"
          aria-label="Открыть меню"
        >
          <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Мобильное меню -->
  <div
    x-cloak
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-50 md:hidden"
  >
    <div class="fixed inset-0 bg-black/10" @click="mobileOpen = false"></div>

    <div
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full"
      class="fixed inset-y-0 left-0 w-full overflow-y-auto bg-white px-6 py-6"
    >
      <div class="flex items-center justify-between mb-6">
        <button
          type="button"
          @click="mobileOpen = false"
          class="-m-2.5 rounded-md p-2.5 text-gray-700"
          aria-label="Закрыть меню"
        >
          <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
        <a href={logo.href} @click="mobileOpen = false">
          {logo.image ? (
            <img src={logo.image} alt={logo.label} class="h-7 w-auto" />
          ) : (
            <span class="font-bold text-xl">{logo.label}</span>
          )}
        </a>
        <div class="w-10"></div>
      </div>

      <!-- Пункты меню -->
      <div class="-my-6 divide-y divide-gray-500/10">
        <div class="space-y-2 py-6">
          {items.map(item => (
            item.children?.length ? (
              /* Аккордеон */
              <div class="-mx-3" x-data="{ expanded: false }">
                <button
                  type="button"
                  @click="expanded = !expanded"
                  class="flex w-full items-center justify-between rounded-lg py-2 pl-3 pr-3.5 text-base font-semibold text-gray-900 hover:bg-gray-50 transition-colors"
                >
                  {item.label}
                  <svg
                    class="size-5 flex-none transition-transform duration-200"
                    :class="expanded ? 'rotate-180' : ''"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" />
                  </svg>
                </button>
                <div x-show="expanded" x-transition class="mt-2 space-y-1">
                  {item.children.map(child => (
                    <a
                      href={child.href}
                      @click="mobileOpen = false"
                      class="block rounded-lg py-2 pl-6 pr-3 text-sm font-semibold text-gray-900 hover:bg-gray-50 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              /* Плоская ссылка */
              <a
                href={item.href}
                @click="mobileOpen = false"
                class="-mx-3 flex items-center gap-1.5 rounded-lg px-3 py-2 text-base font-semibold text-gray-900 hover:bg-gray-50 transition-colors"
              >
                {item.label}
                {item.badge === 'dot' && (
                  <span class="w-1.5 h-1.5 bg-red-500 rounded-full flex-shrink-0" />
                )}
              </a>
            )
          ))}
        </div>

        <div class="py-6">
          {blogPosts.length > 0 && (
            <div class="mb-6">
              <p class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wide">Из блога</p>
              <div class="space-y-3">
                {blogPosts.map(post => (
                  <BlogCard
                    title={post.title}
                    slug={post.slug}
                    cover={post.cover}
                    category={post.category}
                  />
                ))}
              </div>
            </div>
          )}

          {(secondaryLink || cta) && (
            <div class="space-y-2">
              {secondaryLink && (
                <a
                  href={secondaryLink.href}
                  @click="mobileOpen = false"
                  class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold text-gray-500 hover:bg-gray-50 transition-colors"
                >
                  {secondaryLink.label}
                </a>
              )}
              {cta && (
                <button
                  class="w-full text-sm font-medium bg-black text-white px-4 py-3 rounded-lg hover:opacity-90 active:scale-[0.98] transition-all duration-200"
                  @click={`mobileOpen = false; $dispatch('open-drawer', { preset: '${cta.preset ?? 'demo'}' })`}
                >
                  {cta.label}
                </button>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-blur-fade {
    position: absolute;
    inset: 0;
    bottom: -20px;
    z-index: -1;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
  }

  .nav-blur-strong {
    bottom: 50%;
    -webkit-backdrop-filter: blur(32px);
    backdrop-filter: blur(32px);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-blur-fade {
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, transparent 100%);
    }
    .nav-blur-strong {
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }
  }
</style>
