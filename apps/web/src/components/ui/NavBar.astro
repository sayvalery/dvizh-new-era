---
/**
 * NavBar — навигационная шапка-островок
 *
 * Используется в:
 *   Header.astro    → основной сайт (мега-меню, CTA, блог-карточки)
 *   BlogLayout.astro → ДВИЖ Инсайты (только лого + плоские ссылки + secondaryLink)
 *
 * Дизайн: плавающий «островок» со скруглёнными краями, margin-top, внутренним padding.
 * На белых страницах — белый на белом (невидим). На градиенте — полупрозрачный с blur.
 *
 * Прозрачный режим (transparent=true):
 *   clear = transparent && !megaOpen && !mobileOpen
 *   clear: островок полупрозрачный, белый текст/лого
 *   !clear: белый фон до верха страницы, стандартные цвета
 *
 * Мега-меню остаётся открытым пока курсор внутри всего хедера (nav + dropdown).
 */

import BlogCard from './BlogCard.astro'

export interface NavChild {
  label: string
  href: string
  description?: string
}

export interface NavSection {
  title: string
  items: NavChild[]
}

export interface NavItem {
  label: string
  href?: string
  children?: NavChild[]
  sections?: NavSection[]
  badge?: 'dot'
}

interface BlogPost {
  title: string
  slug: string
  cover?: { url?: string; alt?: string }
  category?: string
}

interface Props {
  logo: { label: string; href: string; image?: string; imageLight?: string }
  items?: NavItem[]
  blogPosts?: BlogPost[]
  secondaryLink?: { label: string; href: string }
  cta?: { label: string; preset?: string }
  transparent?: boolean
}

const { logo, items = [], blogPosts = [], secondaryLink, cta, transparent = false } = Astro.props

// Separate mega-menu items from flat items for rendering dropdown outside nav
const megaItem = items.find(i => i.sections?.length)
const megaSections = megaItem?.sections ?? []
---

<header
  x-data={`{ mobileOpen: false, megaOpen: false, hoverTimeout: null, get clear() { return ${transparent} && !this.megaOpen && !this.mobileOpen } }`}
  class:list={[transparent ? 'absolute top-0 left-0 right-0 z-40' : '']}
>
  <!-- Hover zone: keeps mega menu open while cursor is inside header area -->
  <div
    @mouseenter="if (megaOpen) clearTimeout(hoverTimeout)"
    @mouseleave="hoverTimeout = setTimeout(() => megaOpen = false, 200)"
    :class="{ 'bg-white': !clear, 'bg-transparent': clear }"
    class="transition-colors duration-200"
  >
    <!-- Island wrapper: content aligns at 1440px, rounded corners extend beyond -->
    <div class="max-w-[1440px] mx-auto px-4 pt-3 pb-2">
      <nav
        class="flex items-center justify-between -mx-2 px-6 h-14 rounded-2xl transition-all duration-200"
        :class="clear ? '' : 'bg-white'"
      >
        <!-- Left: logo + desktop nav -->
        <div class="flex items-center gap-6">
          <a href={logo.href} class="flex-shrink-0">
            {logo.image && logo.imageLight && transparent ? (
              <>
                <img src={logo.image} alt={logo.label} class="h-7 w-auto" x-show="!clear" x-cloak />
                <img src={logo.imageLight} alt={logo.label} class="h-7 w-auto" x-show="clear" />
              </>
            ) : logo.image ? (
              <img src={logo.image} alt={logo.label} class="h-7 w-auto" />
            ) : (
              <span class="font-bold text-xl">{logo.label}</span>
            )}
          </a>
          <div class="hidden md:flex md:gap-x-1">
            {items.map(item => (
              item.sections?.length ? (
                /* === MEGA MENU TRIGGER === */
                <button
                  class="flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors"
                  :class="clear ? 'text-white hover:bg-white/10' : 'text-gray-700 hover:bg-gray-100'"
                  @mouseenter="clearTimeout(hoverTimeout); megaOpen = true"
                >
                  {item.label}
                  <svg class="w-3.5 h-3.5 transition-transform" :class="megaOpen && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              ) : item.children?.length ? (
                /* === SIMPLE DROPDOWN === */
                <div class="relative group">
                  <button
                    class="flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors"
                    :class="clear ? 'text-white hover:bg-white/10' : 'text-gray-700 hover:bg-gray-100'"
                  >
                    {item.label}
                    <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="absolute top-full left-0 pt-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
                    <div class="bg-white border border-gray-200 rounded-xl shadow-lg py-2 min-w-52">
                      {item.children.map(child => (
                        <a href={child.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900">
                          {child.label}
                          {child.description && (
                            <span class="block text-xs text-gray-400 mt-0.5">{child.description}</span>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                /* === FLAT LINK === */
                <a
                  href={item.href}
                  class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors"
                  :class="clear ? 'text-white hover:bg-white/10' : 'text-gray-700 hover:bg-gray-100'"
                >
                  {item.label}
                  {item.badge === 'dot' && (
                    <span
                      class="w-1.5 h-1.5 rounded-full flex-shrink-0 transition-colors"
                      :class="clear ? 'bg-white' : 'bg-red-500'"
                    />
                  )}
                </a>
              )
            ))}
          </div>
        </div>

        <!-- Right: secondary link + CTA + mobile hamburger -->
        <div class="flex items-center gap-4">
          {secondaryLink && (
            <a
              href={secondaryLink.href}
              class="hidden md:block text-sm font-medium transition-colors"
              :class="clear ? 'text-white/80 hover:text-white' : 'text-gray-500 hover:text-gray-900'"
            >
              {secondaryLink.label}
            </a>
          )}
          {cta && (
            <button
              class="hidden md:block text-sm font-medium px-4 py-2 rounded-lg transition-colors"
              :class="clear ? 'bg-white text-gray-900 hover:bg-white/90' : 'bg-black text-white hover:bg-gray-800'"
              @click={`$dispatch('open-drawer', { preset: '${cta.preset ?? 'demo'}' })`}
            >
              {cta.label}
            </button>
          )}
          <button
            type="button"
            @click="mobileOpen = true"
            class="md:hidden -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 transition-colors"
            :class="clear ? 'text-white' : 'text-gray-700'"
            aria-label="Открыть меню"
          >
            <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </nav>
    </div>

    <!-- Mega menu dropdown (inside hover zone, below island) -->
    {megaSections.length > 0 && (
      <div
        x-cloak
        x-show="megaOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 -translate-y-1"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 -translate-y-1"
        class="border-t border-gray-100"
      >
        <div class="mx-auto max-w-[1440px] px-4 py-8">
          <div class="grid grid-cols-4 gap-8">
            {megaSections.map(section => (
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">{section.title}</p>
                <ul class="space-y-1">
                  {section.items.map(child => (
                    <li>
                      <a href={child.href} class="block text-sm text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-md px-2 py-1.5 -mx-2">
                        {child.label}
                        {child.description && (
                          <span class="block text-xs text-gray-400 mt-0.5">{child.description}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
            {blogPosts.length > 0 && (
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Блог</p>
                <div class="space-y-4">
                  {blogPosts.map(post => (
                    <BlogCard
                      title={post.title}
                      slug={post.slug}
                      cover={post.cover}
                      category={post.category}
                      class="border-0 shadow-none hover:shadow-none"
                    />
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    )}
  </div>

  <!-- Mobile menu overlay -->
  <div
    x-cloak
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-50 md:hidden"
  >
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/10" @click="mobileOpen = false"></div>

    <!-- Panel -->
    <div
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full"
      class="fixed inset-y-0 left-0 w-full overflow-y-auto bg-white px-6 py-6"
    >
      <div class="flex items-center justify-between mb-6">
        <button
          type="button"
          @click="mobileOpen = false"
          class="-m-2.5 rounded-md p-2.5 text-gray-700"
          aria-label="Закрыть меню"
        >
          <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
        <a href={logo.href} class="flex-shrink-0" @click="mobileOpen = false">
          {logo.image ? (
            <img src={logo.image} alt={logo.label} class="h-7 w-auto" />
          ) : (
            <span class="font-bold text-xl">{logo.label}</span>
          )}
        </a>
        <div class="w-10"></div>
      </div>

      <!-- Nav items -->
      <div class="space-y-1">
        {items.map(item => (
          item.sections?.length ? (
            item.sections.map(section => (
              <div>
                <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">
                  {section.title}
                </p>
                {section.items.map(child => (
                  <a
                    href={child.href}
                    @click="mobileOpen = false"
                    class="-mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            ))
          ) : item.children?.length ? (
            <div>
              <p class="px-3 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">
                {item.label}
              </p>
              {item.children.map(child => (
                <a
                  href={child.href}
                  @click="mobileOpen = false"
                  class="-mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50"
                >
                  {child.label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={item.href}
              @click="mobileOpen = false"
              class="-mx-3 flex items-center gap-1.5 rounded-lg px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-50"
            >
              {item.label}
              {item.badge === 'dot' && (
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full flex-shrink-0" />
              )}
            </a>
          )
        ))}
      </div>

      {blogPosts.length > 0 && (
        <div class="mt-6 pt-6 border-t border-gray-100">
          <p class="px-3 pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wide">Из блога</p>
          <div class="space-y-3">
            {blogPosts.map(post => (
              <BlogCard
                title={post.title}
                slug={post.slug}
                cover={post.cover}
                category={post.category}
              />
            ))}
          </div>
        </div>
      )}

      {(secondaryLink || cta) && (
        <div class="mt-6 pt-6 border-t border-gray-100 space-y-2">
          {secondaryLink && (
            <a
              href={secondaryLink.href}
              @click="mobileOpen = false"
              class="-mx-3 block rounded-lg px-3 py-2 text-base font-medium text-gray-500 hover:bg-gray-50"
            >
              {secondaryLink.label}
            </a>
          )}
          {cta && (
            <button
              class="w-full text-sm font-medium bg-black text-white px-4 py-3 rounded-lg hover:bg-gray-800 transition-colors"
              @click={`mobileOpen = false; $dispatch('open-drawer', { preset: '${cta.preset ?? 'demo'}' })`}
            >
              {cta.label}
            </button>
          )}
        </div>
      )}
    </div>
  </div>
</header>
