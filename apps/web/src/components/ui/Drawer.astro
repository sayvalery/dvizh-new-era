---
/**
 * Drawer — глобальный правый дровер с формой
 *
 * Подключён один раз в SiteLayout. Управляется через Alpine custom event.
 *
 * Открыть с любой кнопки на странице:
 *   <button x-data @click="$dispatch('open-drawer', { preset: 'demo' })">...</button>
 *
 * Пресеты и их заголовки:
 *   demo      → "Запросить демо"
 *   lead      → "Связаться с нами"
 *   research  → "Получить исследование"
 *   subscribe → "Подписаться на обновления"
 *
 * Примечание: кнопка должна находиться внутри x-data scope (хотя бы x-data без значения),
 * либо использовать нативный JS: document.dispatchEvent(new CustomEvent('open-drawer', ...))
 */
import Form from './Form.astro'

const presets = ['demo', 'lead', 'research', 'subscribe'] as const

const titles: Record<string, string> = {
  demo:      'Получить демо',
  lead:      'Связаться с нами',
  research:  'Получить исследование',
  subscribe: 'Подписаться на обновления',
}
---

<div
  x-data="{ open: false, preset: 'demo' }"
  @open-drawer.window="preset = $event.detail.preset ?? 'demo'; open = true"
  x-init="$watch('open', v => document.body.classList.toggle('overflow-hidden', v))"
>
  <!-- Backdrop -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="open = false"
    class="fixed inset-0 bg-black/30 z-40"
    style="display:none"
  ></div>

  <!-- Panel -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed inset-y-0 right-0 z-50 w-full max-w-md bg-white shadow-xl flex flex-col"
    style="display:none"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 shrink-0">
      <div>
        {presets.map(p => (
          <h2
            x-show={`preset === '${p}'`}
            class="font-semibold text-gray-900"
            style="display:none"
          >
            {titles[p]}
          </h2>
        ))}
      </div>
      <button
        @click="open = false"
        class="-mr-2 p-2 rounded-md text-gray-400 hover:text-gray-600 transition-colors"
        aria-label="Закрыть"
      >
        <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Forms (все пресеты pre-rendered, Alpine показывает нужный) -->
    <div class="flex-1 overflow-y-auto px-6 py-6">
      {presets.map(p => (
        <div x-show={`preset === '${p}'`} style="display:none">
          <Form preset={p} layout="labels-left" />
        </div>
      ))}
    </div>
  </div>
</div>
