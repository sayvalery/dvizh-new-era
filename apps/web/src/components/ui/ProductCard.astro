---
/**
 * ProductCard — большая карточка продукта с анимированным фоном
 *
 * Hero-секция продукта с заголовком, описанием (до 5 строк) и кнопками.
 * Фон: FlutedGlassBg с тёплой персиково-оранжевой палитрой.
 *
 * @example
 * ```astro
 * <ProductCard
 *   title="Разворачивайте ипотечное дело с уверенностью"
 *   descriptions={[
 *     "Единая платформа для автоматизации",
 *     "всего процесса ипотечного кредитования",
 *     "от заявки до регистрации сделки"
 *   ]}
 *   primaryButton={{ label: "Начать", href: "#" }}
 * />
 * ```
 */

import FlutedGlassBg from './FlutedGlassBg.astro'

interface Button {
  label: string
  href: string
}

interface Props {
  /** Заголовок */
  title: string
  /** Описания (от 1 до 5 строк) */
  descriptions?: string[]
  /** Основная кнопка (CTA) */
  primaryButton?: Button
  /** Вторичная кнопка (текстовая со стрелкой) */
  secondaryButton?: Button
  /** Дополнительные CSS классы */
  class?: string
}

const {
  title,
  descriptions = [],
  primaryButton,
  secondaryButton,
  class: className = ''
} = Astro.props
---

<div class:list={['relative isolate overflow-hidden rounded-[40px]', className]}>
  <!-- Анимированный фон -->
  <FlutedGlassBg
    colors={['#fde8db', '#fcd5c0', '#fae0d0', '#fef3ed', '#f7f0ec']}
    speed={0.7}
    grain={0.15}
    shadows={0.03}
  />

  <div class="relative z-10 p-10 w-fit">
    <div>
      <!-- Заголовок -->
      <h1 class="text-pretty text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-gray-900">
        {title}
      </h1>

      <!-- Описания -->
      {descriptions.length > 0 && (
        <div class="mt-8 space-y-1">
          {descriptions.map((desc) => (
            <p class="text-pretty text-lg font-medium text-gray-500 sm:text-xl/8">
              {desc}
            </p>
          ))}
        </div>
      )}

      <!-- Кнопки -->
      {(primaryButton || secondaryButton) && (
        <div class="mt-10 flex items-center gap-x-6">
          {primaryButton && (
            <a
              href={primaryButton.href}
              class="rounded-md bg-brand px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
            >
              {primaryButton.label}
            </a>
          )}
          {secondaryButton && (
            <a
              href={secondaryButton.href}
              class="text-sm/6 font-semibold text-gray-900"
            >
              {secondaryButton.label} <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</div>
