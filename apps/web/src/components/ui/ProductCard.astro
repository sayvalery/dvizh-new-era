---
/**
 * ProductCard — большая карточка продукта с фоновым паттерном
 *
 * Hero-секция продукта с заголовком, описанием (до 5 строк) и кнопками.
 * Фоновый паттерн SVG + градиентный блюр.
 *
 * @example
 * ```astro
 * <ProductCard
 *   title="Разворачивайте ипотечное дело с уверенностью"
 *   descriptions={[
 *     "Единая платформа для автоматизации",
 *     "всего процесса ипотечного кредитования",
 *     "от заявки до регистрации сделки"
 *   ]}
 *   primaryButton={{ label: "Начать", href: "#" }}
 * />
 * ```
 */

interface Button {
  label: string
  href: string
}

interface Props {
  /** Заголовок */
  title: string
  /** Описания (от 1 до 5 строк) */
  descriptions?: string[]
  /** Основная кнопка (CTA) */
  primaryButton?: Button
  /** Вторичная кнопка (текстовая со стрелкой) */
  secondaryButton?: Button
  /** Дополнительные CSS классы */
  class?: string
}

const {
  title,
  descriptions = [],
  primaryButton,
  secondaryButton,
  class: className = ''
} = Astro.props

// Генерируем уникальный ID для pattern
const patternId = `pattern-${Math.random().toString(36).substr(2, 9)}`
---

<div class:list={['relative isolate overflow-hidden rounded-[40px] bg-[#F8F8F8]', className]}>
  <!-- Фоновый паттерн -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        id={patternId}
        width="200"
        height="200"
        x="50%"
        y="-1"
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none" />
      </pattern>
    </defs>
    <svg x="50%" y="-1" class="overflow-visible fill-gray-50">
      <path
        d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z"
        stroke-width="0"
      />
    </svg>
    <rect width="100%" height="100%" fill={`url(#${patternId})`} stroke-width="0" />
  </svg>

  <!-- Градиентный блюр -->
  <div
    aria-hidden="true"
    class="absolute left-[calc(50%-4rem)] top-10 -z-10 transform-gpu blur-3xl sm:left-[calc(50%-18rem)] lg:left-48 lg:top-[calc(50%-30rem)] xl:left-[calc(50%-24rem)]"
  >
    <div
      style="clip-path: polygon(73.6% 51.7%, 91.7% 11.8%, 100% 46.4%, 97.4% 82.2%, 92.5% 84.9%, 75.7% 64%, 55.3% 47.5%, 46.5% 49.4%, 45% 62.9%, 50.3% 87.2%, 21.3% 64.1%, 0.1% 100%, 5.4% 51.1%, 21.4% 63.9%, 58.9% 0.2%, 73.6% 51.7%)"
      class="aspect-[1108/632] w-[69.25rem] bg-gradient-to-r from-[#ffbc99] to-[#ff4d00] opacity-20"
    ></div>
  </div>

  <div class="p-10 w-fit">
    <div>
      <!-- Заголовок -->
      <h1 class="text-pretty text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-gray-900">
        {title}
      </h1>

      <!-- Описания -->
      {descriptions.length > 0 && (
        <div class="mt-8 space-y-1">
          {descriptions.map((desc) => (
            <p class="text-pretty text-lg font-medium text-gray-500 sm:text-xl/8">
              {desc}
            </p>
          ))}
        </div>
      )}

      <!-- Кнопки -->
      {(primaryButton || secondaryButton) && (
        <div class="mt-10 flex items-center gap-x-6">
          {primaryButton && (
            <a
              href={primaryButton.href}
              class="rounded-md bg-brand px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
            >
              {primaryButton.label}
            </a>
          )}
          {secondaryButton && (
            <a
              href={secondaryButton.href}
              class="text-sm/6 font-semibold text-gray-900"
            >
              {secondaryButton.label} <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</div>
