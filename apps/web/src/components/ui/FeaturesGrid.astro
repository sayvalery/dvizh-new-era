---
/**
 * FeaturesGrid — секция с заголовком, описанием, списком фич с иконками и изображением
 *
 * @example
 * ```astro
 * // Светлая тема (по умолчанию)
 * <FeaturesGrid
 *   badge="Deploy faster"
 *   title="A better workflow"
 *   description="Lorem ipsum dolor sit amet..."
 *   features={[
 *     { icon: "upload", title: "Push to deploy", description: "..." },
 *   ]}
 *   image="/screenshot.png"
 * />
 *
 * // Тёмная тема
 * <FeaturesGrid
 *   variant="dark"
 *   title="Dark mode example"
 *   features={[...]}
 * />
 * ```
 */

interface Feature {
  /** SVG icon path */
  icon: string
  /** Feature title */
  title: string
  /** Feature description */
  description: string
}

interface Props {
  /** Маленькая метка над заголовком (индigo цвет) */
  badge?: string
  /** Основной заголовок */
  title: string
  /** Описание под заголовком */
  description?: string
  /** Список фичей с иконками */
  features: Feature[]
  /** Тема: light (белый фон) или dark (тёмный фон) */
  variant?: 'light' | 'dark'
  /** Изображение справа (темная тема) */
  imageDark?: string
  /** Изображение справа (светлая тема) */
  imageLight?: string
  /** URL изображения */
  image?: string
  /** Дополнительные CSS классы */
  class?: string
}

const {
  badge,
  title,
  description,
  features,
  variant = 'light',
  image,
  imageDark,
  imageLight,
  class: className = ''
} = Astro.props

// Классы для фона и текстов в зависимости от темы
const isDark = variant === 'dark'
const bgClass = isDark ? 'bg-gray-900' : 'bg-white'
const badgeClass = isDark ? 'text-brand-400' : 'text-brand'
const titleClass = isDark ? 'text-white' : 'text-gray-900'
const descClass = isDark ? 'text-gray-300' : 'text-gray-700'
const listClass = isDark ? 'text-gray-400' : 'text-gray-600'
const iconClass = isDark ? 'text-brand-400' : 'text-brand'

// Иконки SVG как inline path
const icons = {
  upload: 'M5.5 17a4.5 4.5 0 0 1-1.44-8.765 4.5 4.5 0 0 1 8.302-3.046 3.5 3.5 0 0 1 4.504 4.272A4 4 0 0 1 15 17H5.5Zm3.75-2.75a.75.75 0 0 0 1.5 0V9.66l1.95 2.1a.75.75 0 1 0 1.1-1.02l-3.25-3.5a.75.75 0 0 0-1.1 0l-3.25 3.5a.75.75 0 1 0 1.1 1.02l1.95-2.1v4.59Z',
  lock: 'M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z',
  database: 'M4.632 3.533A2 2 0 0 1 6.577 2h6.846a2 2 0 0 1 1.945 1.533l1.976 8.234A3.489 3.489 0 0 0 16 11.5H4c-.476 0-.93.095-1.344.267l1.976-8.234Z M4 13a2 2 0 1 0 0 4h12a2 2 0 1 0 0-4H4Zm11.24 2a.75.75 0 0 1 .75-.75H16a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75h-.01a.75.75 0 0 1-.75-.75V15Zm-2.25-.75a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75H13a.75.75 0 0 0 .75-.75V15a.75.75 0 0 0-.75-.75h-.01Z',
  check: 'M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z',
  'building-bank': 'M4 2a2 2 0 0 0-2 2v11a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V4a2 2 0 0 0-2-2H4Zm1 14a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm5-1.757-3.48-2.74a1 1 0 0 0-1.237 1.567l1.983 2.562a1 1 0 0 0 1.586-.19l3.736-6.555a1 1 0 1 0-1.742-.97l-2.97 5.228-1.39-1.796Z',
  document: 'M4 2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H4Zm0 2h12v1.5H4V4Zm12 4H4v1h12V8Zm-7 4H4v1h5v-1Zm7 0h-5v1h5v-1Z',
  globe: 'M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm0-1.5a6.47 6.47 0 0 1-3.022-.746C7.666 14.787 8.696 13 10 13c1.304 0 2.334 1.787 3.022 2.754A6.47 6.47 0 0 1 10 16.5ZM4.777 9.5C5.25 6.923 6.868 5 10 5c3.132 0 4.75 1.923 5.223 4.5H4.777ZM14.223 11c-.473 2.577-2.09 4.5-5.223 4.5-3.132 0-4.75-1.923-5.223-4.5h9.446Z',
  'arrow-path': 'M12.5 2.25a.75.75 0 0 1-1.5 0V15m0 0a.75.75 0 0 1-1.5 0m1.5 0a.75.75 0 0 0 1.5 0M2.25 12h15.75m-3.5-6.75L18.5 12l-3.75 6.75'
}

const hasImage = !!(image || imageDark || imageLight)
---

<section class:list={['overflow-hidden py-24 sm:py-32', bgClass, className]}>
  <div class="mx-auto max-w-[1440px] px-4">
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2">
      <div class="lg:pr-8 lg:pt-4">
        <div class="lg:max-w-lg">
          {badge && (
            <p class:list={['text-base/7 font-semibold', badgeClass]}>
              {badge}
            </p>
          )}
          <h2 class:list={['mt-2 text-pretty text-4xl font-semibold tracking-tight sm:text-5xl', titleClass]}>
            {title}
          </h2>
          {description && (
            <p class:list={['mt-6 text-lg/8', descClass]}>
              {description}
            </p>
          )}
          <dl class:list={['mt-10 max-w-xl space-y-8 text-base/7 lg:max-w-none', listClass]}>
            {features.map((feature) => (
              <div class="relative pl-9">
                <dt class:list={['inline font-semibold', titleClass]}>
                  <svg
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    class:list={['absolute left-1 top-1 size-5', iconClass]}
                  >
                    <path d={icons[feature.icon] || feature.icon} fill-rule="evenodd" clip-rule="evenodd" />
                  </svg>
                  {feature.title}
                </dt>
                <dd class="inline">{feature.description}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
      {hasImage ? (
        <div>
          {image && (
            <img
              width="2432"
              height="1442"
              src={image}
              alt="Product screenshot"
              class="w-[48rem] max-w-none rounded-xl shadow-xl ring-1 ring-gray-400/10 sm:w-[57rem] md:-ml-4 lg:-ml-0"
              loading="lazy"
            />
          )}
        </div>
      ) : (
        <div class="w-[48rem] max-w-none h-[400px] rounded-xl bg-gray-100 sm:w-[57rem] md:-ml-4 lg:-ml-0" />
      )}
    </div>
  </div>
</section>
