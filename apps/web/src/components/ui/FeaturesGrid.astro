---
/**
 * FeaturesGrid — секция с заголовком, описанием, списком фич с иконками и изображением
 *
 * @example
 * ```astro
 * <FeaturesGrid
 *   badge="Deploy faster"
 *   title="A better workflow"
 *   description="Lorem ipsum dolor sit amet..."
 *   image="/screenshot.png"
 *   features={[
 *     { icon: "upload", title: "Push to deploy", description: "..." },
 *     { icon: "lock", title: "SSL certificates", description: "..." },
 *   ]}
 * />
 * ```
 */

interface Feature {
  /** SVG icon path */
  icon: string
  /** Feature title */
  title: string
  /** Feature description */
  description: string
}

interface Props {
  /** Маленькая метка над заголовком (индigo цвет) */
  badge?: string
  /** Основной заголовок */
  title: string
  /** Описание под заголовком */
  description?: string
  /** Список фичей с иконками */
  features: Feature[]
  /** Изображение справа (темная тема) */
  imageDark?: string
  /** Изображение справа (светлая тема) */
  imageLight?: string
  /** URL изображения */
  image?: string
  /** Дополнительные CSS классы */
  class?: string
}

const {
  badge,
  title,
  description,
  features,
  image,
  imageDark,
  imageLight,
  class: className = ''
} = Astro.props

// Иконки SVG как inline path
const icons = {
  upload: 'M5.5 17a4.5 4.5 0 0 1-1.44-8.765 4.5 4.5 0 0 1 8.302-3.046 3.5 3.5 0 0 1 4.504 4.272A4 4 0 0 1 15 17H5.5Zm3.75-2.75a.75.75 0 0 0 1.5 0V9.66l1.95 2.1a.75.75 0 1 0 1.1-1.02l-3.25-3.5a.75.75 0 0 0-1.1 0l-3.25 3.5a.75.75 0 1 0 1.1 1.02l1.95-2.1v4.59Z',
  lock: 'M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z',
  database: 'M4.632 3.533A2 2 0 0 1 6.577 2h6.846a2 2 0 0 1 1.945 1.533l1.976 8.234A3.489 3.489 0 0 0 16 11.5H4c-.476 0-.93.095-1.344.267l1.976-8.234Z M4 13a2 2 0 1 0 0 4h12a2 2 0 1 0 0-4H4Zm11.24 2a.75.75 0 0 1 .75-.75H16a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75h-.01a.75.75 0 0 1-.75-.75V15Zm-2.25-.75a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75H13a.75.75 0 0 0 .75-.75V15a.75.75 0 0 0-.75-.75h-.01Z'
}

const getImage = () => {
  if (imageDark && imageLight) {
    return `
      <img
        width="2432"
        height="1442"
        src={imageDark}
        alt="Product screenshot"
        class="hidden w-[48rem] max-w-none rounded-xl shadow-xl ring-1 ring-gray-400/10 sm:w-[57rem] md:-ml-4 lg:-ml-0 dark:block dark:ring-white/10"
      />
      <img
        width="2432"
        height="1442"
        src={imageLight}
        alt="Product screenshot"
        class="w-[48rem] max-w-none rounded-xl shadow-xl ring-1 ring-gray-400/10 sm:w-[57rem] md:-ml-4 lg:-ml-0 dark:hidden dark:ring-white/10"
      />
    `
  }
  if (image) {
    return `
      <img
        width="2432"
        height="1442"
        src={image}
        alt="Product screenshot"
        class="w-[48rem] max-w-none rounded-xl shadow-xl ring-1 ring-gray-400/10 sm:w-[57rem] md:-ml-4 lg:-ml-0 dark:ring-white/10"
      />
    `
  }
  return ''
}
---

<section class:list={['overflow-hidden bg-white py-24 sm:py-32 dark:bg-gray-900', className]}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2">
      <div class="lg:pr-8 lg:pt-4">
        <div class="lg:max-w-lg">
          {badge && (
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">
              {badge}
            </h2>
          )}
          <p class="mt-2 text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl dark:text-white">
            {title}
          </p>
          {description && (
            <p class="mt-6 text-lg/8 text-gray-700 dark:text-gray-300">
              {description}
            </p>
          )}
          <dl class="mt-10 max-w-xl space-y-8 text-base/7 text-gray-600 lg:max-w-none dark:text-gray-400">
            {features.map((feature) => (
              <div class="relative pl-9">
                <dt class="inline font-semibold text-gray-900 dark:text-white">
                  <svg
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                    class="absolute left-1 top-1 size-5 text-indigo-600 dark:text-indigo-400"
                  >
                    <path d={icons[feature.icon] || feature.icon} fill-rule="evenodd" clip-rule="evenodd" />
                  </svg>
                  {feature.title}
                </dt>
                <dd class="inline">{feature.description}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
      <div set:html={getImage()} />
    </div>
  </div>
</section>
