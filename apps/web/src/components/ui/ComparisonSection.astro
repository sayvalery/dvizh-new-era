---
/**
 * ComparisonSection — секция сравнения «до/после» с заголовком слева и двумя карточками справа
 *
 * @example
 * ```astro
 * <ComparisonSection
 *   title="Одно решение для всей сделки вместо кучи заплаток"
 *   leftTitle="Без ДВИЖа"
 *   leftItems={['Данные теряются...', 'Менеджер тратит время...']}
 *   rightTitle="С ДВИЖом"
 *   rightItems={['Вся сделка в одном окне...', 'Менеджер успевает в 2 раза больше...']}
 * />
 * ```
 */

interface Props {
  /** Основной заголовок слева */
  title: string
  /** Заголовок левой (светлой) карточки */
  leftTitle?: string
  /** Пункты левой карточки */
  leftItems: string[]
  /** Заголовок правой (тёмной) карточки */
  rightTitle?: string
  /** Пункты правой карточки */
  rightItems: string[]
  /** Дополнительные CSS классы */
  class?: string
}

const {
  title,
  leftTitle = 'До',
  leftItems = [],
  rightTitle = 'После',
  rightItems = [],
  class: className = '',
} = Astro.props

const checkPath = 'M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z'
---

<section class:list={['bg-white py-24 sm:py-32', className]}>
  <div class="max-w-[1440px] mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">

      <!-- Левая колонка: заголовок -->
      <div class="lg:col-span-1">
        <h2 class="text-4xl font-semibold font-heading text-gray-900 sm:text-[42.5px] tracking-tight leading-tight">
          {title}
        </h2>
      </div>

      <!-- Правая колонка: две карточки -->
      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-6">

        <!-- Левая карточка (светлая) -->
        <div class="rounded-3xl bg-gray-50 p-8 ring-1 ring-gray-900/10">
          <h3 class="text-2xl font-semibold font-heading text-gray-900">{leftTitle}</h3>
          <ul role="list" class="mt-8 space-y-4 text-sm/6 text-gray-600">
            {leftItems.map((item) => (
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-6 w-5 flex-none text-gray-400">
                  <path fill-rule="evenodd" clip-rule="evenodd" d={checkPath} />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Правая карточка (тёмная) -->
        <div class="rounded-3xl bg-gray-900 p-8 shadow-2xl">
          <h3 class="text-2xl font-semibold font-heading text-white">{rightTitle}</h3>
          <ul role="list" class="mt-8 space-y-4 text-sm/6 text-gray-300">
            {rightItems.map((item) => (
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-6 w-5 flex-none text-brand-400">
                  <path fill-rule="evenodd" clip-rule="evenodd" d={checkPath} />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>
