---
/**
 * HeroSection — главная hero-секция страницы с заголовком, описанием и формой
 *
 * @example
 * ```astro
 * <HeroSection
 *   badge="Ипотечная платформа"
 *   title="Закрывайте до 26% больше сделок на том же трафике"
 *   description="Повышаем конверсии на каждом этапе работы с заявками."
 * />
 * ```
 */

import Form from './Form.astro'

interface Props {
  /** Бейдж/надпись над заголовком (оранжевый) */
  badge?: string
  /** Основной заголовок */
  title: string
  /** Описание под заголовком */
  description?: string
  /** Показывать форму */
  withForm?: boolean
  /** Пресет формы: lead, demo, subscribe, research */
  formPreset?: 'lead' | 'demo' | 'subscribe' | 'research'
  /** Изображение справа (URL) */
  image?: string
  /** Alt-текст для изображения */
  imageAlt?: string
  /** Дополнительные CSS классы */
  class?: string
}

const {
  badge,
  title,
  description,
  withForm = true,
  formPreset = 'lead',
  image,
  imageAlt = 'Hero image',
  class: className = ''
} = Astro.props
---

<section class:list={['bg-white', className]}>
  <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
    <div class="grid lg:grid-cols-[726px_1fr] gap-8 items-center lg:min-h-[800px]">
    <div class="grid lg:grid-cols-[726px_1fr] gap-8 items-center lg:min-h-[800px]">
      <!-- Левая колонка: контент -->
      <div class="flex flex-col justify-center gap-[52px] py-16 lg:py-0 order-2 lg:order-1">
        <div class="flex flex-col gap-9">
          <!-- Бейдж -->
          {badge && (
            <p class="text-[18px] text-[#ff4d00] font-normal">
              {badge}
            </p>
          )}

          <!-- Заголовок и описание -->
          <div class="flex flex-col gap-8">
            <h1 class="text-[56px] lg:text-[72px] font-medium leading-none tracking-tight text-[#1b2226]">
              {title}
            </h1>
            {description && (
              <p class="text-[20px] lg:text-[24px] text-[#858585] leading-[1.4] max-w-[602px]">
                {description}
              </p>
            )}
          </div>
        </div>

        <!-- Форма -->
        {withForm && (
          <Form preset={formPreset} layout="inline" />
        )}
      </div>

      <!-- Правая колонка: изображение -->
      {image && (
        <div class="relative h-[400px] lg:h-[800px] w-full bg-[#ededed] rounded-none overflow-hidden order-1 lg:order-2">
          <img
            src={image}
            alt={imageAlt}
            class="w-full h-full object-cover"
            width="595"
            height="800"
          />
        </div>
      )}
    </div>
  </div>
</section>
