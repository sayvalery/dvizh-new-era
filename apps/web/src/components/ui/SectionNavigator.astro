---
/**
 * SectionNavigator — навигация по секциям с нумерованным меню
 *
 * Компонент с левым меню (номера 01, 02, 03...) и контентом справа.
 * На мобильной — горизонтальная прокрутка сверху.
 *
 * @example
 * ```astro
 * <SectionNavigator
 *   sections={[
 *     {
 *       number: '01',
 *       title: 'Процесс',
 *       content: '<p>Описание процесса...</p>',
 *     },
 *     {
 *       number: '02',
 *       title: 'Производительность',
 *       content: '<p>Описание производительности...</p>',
 *     },
 *   ]}
 * />
 * ```
 */

export interface SectionItem {
  /** Номер секции (01, 02, 03...) */
  number: string
  /** Заголовок секции */
  title: string
  /** HTML-контент секции */
  content: string
}

interface Props {
  /** Массив секций */
  sections: SectionItem[]
  /** Бейдж над заголовком */
  badge?: string
  /** Основной заголовок */
  title?: string
  /** Дополнительные CSS классы */
  class?: string
}

const { sections, badge, title, class: className = '' } = Astro.props

// Сериализуем данные для безопасной передачи в Alpine
const sectionsJson = JSON.stringify(sections)
const componentId = `section-navigator-${Math.random().toString(36).substr(2, 9)}`
---

<section class:list={['py-16 lg:py-24', className]}>
  <div class="max-w-[1440px] mx-auto px-4">
    {(badge || title) && (
      <div class="max-w-2xl mb-12">
        {badge && (
          <p class="text-sm font-medium tracking-widest uppercase text-brand mb-4">
            {badge}
          </p>
        )}
        {title && (
          <h2 class="text-3xl lg:text-5xl font-medium leading-tight text-gray-900">
            {title}
          </h2>
        )}
      </div>
    )}

    <div id={componentId}>
      <!-- Скрытый блок с данными -->
      <template x-data="sectionsData" data-sections hidden>
        {sectionsJson}
      </template>

      <!-- Alpine компонент -->
      <div
        x-data="{
          activeSection: 0,
          init() {
            const dataEl = document.querySelector('#{componentId} [data-sections]')
            this.sections = JSON.parse(dataEl.textContent)
          }
        }"
      >
        <div class="flex flex-col lg:flex-row gap-8 lg:gap-16">

          <!-- Мобильная навигация (горизонтальная прокрутка) -->
          <div class="lg:hidden flex gap-3 overflow-x-auto pb-4 -mx-4 px-4 scrollbar-hide">
            <template x-for="(section, index) in sections" :key="index">
              <button
                @click="activeSection = index"
                class="flex-shrink-0 flex items-center gap-3 px-4 py-3 rounded-lg transition-all"
                :class="activeSection === index ? 'bg-brand text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'"
              >
                <span class="text-sm font-medium" x-text="section.number"></span>
                <span class="text-sm font-medium whitespace-nowrap" x-text="section.title"></span>
              </button>
            </template>
          </div>

          <!-- Десктоп навигация (левая колонка) -->
          <nav class="hidden lg:block lg:w-[220px] lg:flex-shrink-0">
            <div class="sticky top-8 space-y-2">
              <template x-for="(section, index) in sections" :key="index">
                <button
                  @click="activeSection = index"
                  class="w-full text-left flex items-center gap-4 px-4 py-3 rounded-lg transition-all group"
                  :class="activeSection === index
                    ? 'bg-brand text-white shadow-md'
                    : 'bg-gray-50 text-gray-600 hover:bg-gray-100'"
                >
                  <span
                    class="text-lg font-medium font-heading"
                    x-text="section.number"
                  ></span>
                  <span class="text-sm font-medium" x-text="section.title"></span>
                </button>
              </template>
            </div>
          </nav>

          <!-- Контент справа -->
          <div class="flex-1 min-w-0">
            <template x-for="(section, index) in sections" :key="index">
              <div
                x-show="activeSection === index"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4"
                x-transition:enter-end="opacity-100 translate-y-0"
                x-cloak
              >
                <div class="prose prose-lg max-w-none" x-html="section.content"></div>
              </div>
            </template>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  [x-cloak] { display: none !important; }

  /* Скрытие скроллбара для мобильной навигации */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
