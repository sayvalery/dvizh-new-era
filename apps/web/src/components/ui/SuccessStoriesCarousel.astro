---
/**
 * SuccessStoriesCarousel — горизонтальная карусель карточек SuccessStory
 *
 * Использует CSS Scroll Snap для нативной прокрутки с эффектом «липания» к слайдам.
 * Работает с тач-свайпом на мобильных и скроллом на десктопе.
 *
 * @example
 * ```astro
 * <!-- Full вариант -->
 * <SuccessStoriesCarousel
 *   title="70+ историй успеха на рынке девелопмента"
 *   variant="default"
 *   :stories={[...]}
 * />
 *
 * <!-- Mini вариант (3 карточки) -->
 * <SuccessStoriesCarousel
 *   title="70+ историй успеха на рынке девелопмента"
 *   variant="mini"
 *   :stories={[...]}
 * />
 * ```
 */

import SuccessStory from './SuccessStory.astro'

interface Person {
  name: string
  slug?: string
  photo?: { url: string; alt?: string }
  jobTitle?: string
  company?: { name: string; slug?: string }
}

interface StoryProps {
  title: string
  quote?: string
  person: Person
  image?: string
  imageAlt?: string
  logo?: string
  logoAlt?: string
}

interface Props {
  /** Заголовок секции */
  title: string
  /** Массив карточек SuccessStory */
  stories: StoryProps[]
  /** Вариант: default (полные карточки) или mini (только заголовок и персона) */
  variant?: 'default' | 'mini'
  /** Дополнительные CSS классы */
  class?: string
}

const { title, stories, variant = 'default', class: className = '' } = Astro.props

const isMini = variant === 'mini'

// Ширина карточки для snap
const itemClass = isMini
  ? 'snap-center shrink-0 w-[42%]'
  : 'snap-center shrink-0 w-full max-w-[80%] xl:max-w-[900px]'
---

<section class:list={[className]} data-stories-carousel>
  <!-- Заголовок -->
  <h2 class="text-[36px] sm:text-[52px] md:text-[80px] font-medium text-[#1b2226] leading-none mb-8 sm:mb-[52px]">
    {title}
  </h2>

  <!-- Карусель с CSS Scroll Snap -->
  <div
    class="flex overflow-x-auto gap-5 pb-4 pr-6 snap-x snap-mandatory scrollbar-hide cursor-grab select-none"
    style="-webkit-overflow-scrolling: touch; -ms-overflow-style: none; scrollbar-width: none; scroll-behavior: smooth;"
  >
    {stories.map((story) => (
      <div class={itemClass}>
        <SuccessStory variant={variant} {...story} />
      </div>
    ))}
  </div>
</section>

<script>
  // Simple drag-to-scroll for mouse users
  document.querySelectorAll('[data-stories-carousel]').forEach(section => {
    const container = section.querySelector('[class*="overflow-x-auto"]') as HTMLElement
    if (!container) return

    let isDown = false
    let startX: number
    let scrollLeft: number

    container.addEventListener('mousedown', (e: MouseEvent) => {
      isDown = true
      container.style.cursor = 'grabbing'
      startX = e.pageX - container.offsetLeft
      scrollLeft = container.scrollLeft
    })

    container.addEventListener('mouseleave', () => {
      isDown = false
      container.style.cursor = ''
    })

    container.addEventListener('mouseup', () => {
      isDown = false
      container.style.cursor = ''
    })

    container.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDown) return
      e.preventDefault()
      const x = e.pageX - container.offsetLeft
      const walk = x - startX
      container.scrollLeft = scrollLeft - walk
    })
  })
</script>

<style>
  /* Скрыть скроллбар */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
