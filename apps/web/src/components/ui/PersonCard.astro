---
/**
 * PersonCard — карточка персоны
 *
 * Варианты:
 *   full   (по умолчанию) — аватар 44px + имя + должность + компания. Для раздела авторов.
 *   inline                — аватар 24px + имя. Для строки метаданных статьи.
 *
 * Примеры:
 *   <PersonCard person={primaryAuthor} variant="inline" />   // в шапке статьи
 *   <PersonCard person={author} variant="full" />            // в блоке авторов внизу
 *
 * person.slug  → кликабельная ссылка на /persons/[slug]
 * person.company.slug → ссылка на /companies/[slug]
 * person.photo.url    → абсолютный URL (Payload serverURL уже включён, не добавлять CMS_URL)
 */
interface Company {
  name: string
  slug?: string
}

interface Person {
  name: string
  slug?: string
  photo?: { url: string; alt?: string }
  jobTitle?: string
  company?: Company
}

interface Props {
  person: Person
  variant?: 'full' | 'inline'
}

const { person, variant = 'full' } = Astro.props
const photoUrl = person.photo?.url ?? null
const personHref = person.slug ? `/person/${person.slug}` : null
const companyHref = person.company?.slug ? `/companies/${person.company.slug}` : null
---

{variant === 'inline' ? (
  personHref ? (
    <a href={personHref} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      {photoUrl ? (
        <img src={photoUrl} alt={person.photo?.alt ?? person.name} class="w-6 h-6 rounded-full object-cover shrink-0" />
      ) : (
        <div class="w-6 h-6 rounded-full bg-gray-200 shrink-0 flex items-center justify-center">
          <span class="text-xs text-gray-500 font-medium">{person.name[0]}</span>
        </div>
      )}
      <span class="text-sm text-gray-700">{person.name}</span>
    </a>
  ) : (
    <div class="flex items-center gap-2">
      {photoUrl ? (
        <img src={photoUrl} alt={person.photo?.alt ?? person.name} class="w-6 h-6 rounded-full object-cover shrink-0" />
      ) : (
        <div class="w-6 h-6 rounded-full bg-gray-200 shrink-0 flex items-center justify-center">
          <span class="text-xs text-gray-500 font-medium">{person.name[0]}</span>
        </div>
      )}
      <span class="text-sm text-gray-700">{person.name}</span>
    </div>
  )
) : (
  <div class="flex items-center gap-3">
    {personHref ? (
      <a href={personHref} class="shrink-0 hover:opacity-80 transition-opacity">
        {photoUrl ? (
          <img src={photoUrl} alt={person.photo?.alt ?? person.name} class="w-11 h-11 rounded-full object-cover" />
        ) : (
          <div class="w-11 h-11 rounded-full bg-gray-200 flex items-center justify-center">
            <span class="text-base text-gray-500 font-medium">{person.name[0]}</span>
          </div>
        )}
      </a>
    ) : (
      <div class="shrink-0">
        {photoUrl ? (
          <img src={photoUrl} alt={person.photo?.alt ?? person.name} class="w-11 h-11 rounded-full object-cover" />
        ) : (
          <div class="w-11 h-11 rounded-full bg-gray-200 flex items-center justify-center">
            <span class="text-base text-gray-500 font-medium">{person.name[0]}</span>
          </div>
        )}
      </div>
    )}
    <div>
      {personHref ? (
        <a href={personHref} class="font-semibold text-sm leading-tight hover:underline">{person.name}</a>
      ) : (
        <p class="font-semibold text-sm leading-tight">{person.name}</p>
      )}
      {person.jobTitle && (
        <p class="text-sm text-gray-500 leading-tight mt-0.5">
          {person.jobTitle}
          {person.company && (
            <>
              {companyHref ? (
                <>, <a href={companyHref} class="hover:underline">{person.company.name}</a></>
              ) : (
                <>, {person.company.name}</>
              )}
            </>
          )}
        </p>
      )}
    </div>
  </div>
)}
