---
import NavBar from '../ui/NavBar.astro'
import type { NavItem } from '../ui/NavBar.astro'
import { getBlogPosts, normalizeMediaUrl } from '../../lib/payload'

interface Props {
  /** Прозрачный режим навигации (для страниц с цветным hero) */
  transparent?: boolean
}

const { transparent = false } = Astro.props

// Иконки (Heroicons outline 24px, только path-данные)
const icons = {
  mortgage: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />',
  docCheck: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.125 2.25h-4.5c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125v-9M10.125 2.25h.375a9 9 0 0 1 9 9v.375M10.125 2.25A3.375 3.375 0 0 1 13.5 5.625v1.5c0 .621.504 1.125 1.125 1.125h1.5a3.375 3.375 0 0 1 3.375 3.375M9 15l2.25 2.25 4.5-4.5" />',
  chartBar: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />',
  calculator: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18Zm2.498-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM8.25 6h7.5v2.25h-7.5V6ZM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.598 4.5 4.698V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 19.5 18V4.698c0-1.1-.807-1.998-1.907-2.126A48.507 48.507 0 0 0 12 2.25Z" />',
  user: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />',
  grid: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />',
  presentation: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />',
}

const navItems: NavItem[] = [
  {
    label: 'Продукты',
    children: [
      { label: 'Ипотека', href: '/ipoteka', description: 'Ипотечный процесс от заявки до выдачи', icon: icons.mortgage },
      { label: 'Электронная регистрация', href: '/elektronnaya-registraciya', description: 'Цифровая регистрация сделок', icon: icons.docCheck },
      { label: 'Скоринг', href: '/scoring', description: 'Оценка кредитоспособности клиентов', icon: icons.chartBar },
      { label: 'Ипотечный калькулятор', href: '/ipotechnyy-kalkulyator', description: 'Интеграция в сайт и CRM', icon: icons.calculator },
      { label: 'Личный кабинет', href: '/lichnyy-kabinet', description: 'Кабинет клиента для ведения сделок', icon: icons.user },
      { label: 'Витрина', href: '/vitrina', description: 'Витрина объектов недвижимости', icon: icons.grid },
      { label: 'Бизнес-ревью', href: '/qbr', description: 'Аналитика и бизнес-отчёты', icon: icons.presentation },
    ],
  },
  {
    label: 'Решения',
    children: [
      { label: 'Для девелоперов', href: '/developers' },
      { label: 'Для банков', href: '/banki' },
      { label: 'Для агентств недвижимости', href: '/agentstva-nedvizhimosti' },
    ],
  },
  {
    label: 'Для кого',
    children: [
      { label: 'Департамент продаж', href: '/lab/sales' },
      { label: 'Отдел ипотеки', href: '/ipoteka' },
      { label: 'Отдел оформления', href: '/elektronnaya-registraciya' },
      { label: 'Команда маркетинга и аналитики', href: '/qbr' },
    ],
  },
  { label: 'Блог', href: '/blog', badge: 'dot' },
  { label: 'О нас', href: '/about' },
]

// Последние 2 поста для мобильного меню
let blogPosts: { title: string; slug: string; cover?: { url?: string; alt?: string }; category?: string }[] = []
try {
  const { docs } = await getBlogPosts({ limit: 2 })
  blogPosts = docs.map((post: any) => ({
    title: post.title,
    slug: post.slug,
    cover: post.cover ? { url: normalizeMediaUrl(post.cover.url) ?? undefined, alt: post.cover.alt } : undefined,
    category: post.category?.title,
  }))
} catch {
  // CMS недоступен при сборке — мобильное меню работает без блог-карточек
}
---

<NavBar
  logo={{ label: 'ДВИЖ', href: '/', image: '/logo-dvizh.svg', imageLight: '/logo-dvizh-white.svg' }}
  items={navItems}
  blogPosts={blogPosts}
  secondaryLink={{ label: '+7 495 032 10 47', href: 'tel:+74950321047' }}
  cta={{ label: 'Получить расчет', preset: 'demo' }}
  transparent={transparent}
/>
