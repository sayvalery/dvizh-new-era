---
import SiteLayout from '../layouts/SiteLayout.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import StatsSection from '../components/ui/StatsSection.astro'
import CTA from '../components/ui/CTA.astro'
import LogoGrid from '../components/ui/LogoGrid.astro'
---

<SiteLayout title="Для девелоперов — ДВИЖ" description="AI-платформа для автоматизации ипотечных продаж, электронной регистрации и аналитики. Используется 75 из ТОП-100 застройщиков.">
  <HeroSection
    badge="Платформа для застройщиков"
    title="Лучшие отделы продаж застройщиков используют ДВИЖ"
    description="AI-платформа для автоматизации продаж и маркетинга. ДВИЖ объединяет застройщиков и банки в единую цифровую экосистему — ипотека, регистрация, аналитика и витрина на одной платформе."
    formPreset="demo"
  />

  <LogoGrid
    title="Заряжаем лучшие отделы продаж"
    logos={[
      { src: '/partners/lsr.svg', alt: 'ЛСР' },
      { src: '/partners/ava.svg', alt: 'AVA' },
      { src: '/partners/ganel.svg', alt: 'Ganel' },
      { src: '/partners/strana.svg', alt: 'Strana' },
      { src: '/partners/glorax.svg', alt: 'Glorax' },
      { src: '/partners/a101.svg', alt: 'A101' },
    ]}
    variant="dark"
  />

  <!-- Повышаем качество лидов -->
  <FeaturesGrid
    title="Повышаем качество лидов"
    features={[
      { icon: 'document', title: 'Форма на сайт для проверки кредитного рейтинга:', description: 'приведем надежных клиентов' },
      { icon: 'check', title: 'Скоринг по банковским стандартам:', description: 'расскажем все о платежеспособности покупателей' },
      { icon: 'arrow-path', title: 'Ипотечный калькулятор для сайта:', description: 'приведем клиентов с нужным уровнем дохода' },
    ]}
    variant="light"
  />

  <!-- Продукт 4: Аналитика -->
  <FeaturesGrid
    title="Помогаем закрывать даже сложных клиентов..."
    features={[
      { icon: 'document', title: 'Финансовый скоринг', description: 'покажет, как улучшить портрет клиента до отправки заявки в банк' },
      { icon: 'check', title: '+40 банков-партнеров', description: 'помогут подобрать ипотечную программу для каждого' },
      { icon: 'arrow-path', title: 'ДВИЖ AI', description: 'рассчитает вероятность одобрения клиента в каждом банке и подберет лучшие варианты' },
    ]}
    variant="light"
  />

  <!-- Продукт 5: Личный кабинет -->
  <FeaturesGrid
    title="... и делать это быстрее конкурентов"
    features={[
      { icon: 'document', title: 'Актуальные статусы по сделке в CRM:', description: 'контроль каждого этапа в карточке клиента' },
      { icon: 'check', title: 'Одна анкета для всех этапов', description: 'от заявки до регистрации' },
      { icon: 'arrow-path', title: 'Регистрация всех видов сделок', description: 'и подписание любых документов в рамках 1 платформы' },
      { icon: 'lock', title: 'Пакетное распознавание документов:', description: 'никакого ручного ввода данных' },
      { icon: 'globe', title: '', description: 'Заполнение анкеты через Госуслуги за 30 секунд' },
    ]}
    variant="light"
  />

  <!-- Продукт 6: Витрина -->
  <FeaturesGrid
    title="Раскрываем финансовый потенциал клиентов"
    features={[
      { icon: 'globe', title: '', description: 'Покажем клиенту ежемесячный платеж и поможем выбрать квартиру под весь бюджет' },
      { icon: 'database', title: '', description: 'Рассчитаем ПДН клиента и поможем увеличить средний чек сделки' },
    ]}
    variant="light"
  />

  <!-- Продукт 7: Управление -->
  <FeaturesGrid
    title="Делаем работу менеджеров управляемой"
    features={[
      { icon: 'document', title: 'Контроль всех этапов через CRM:', description: 'покажем, как быстро менеджер взял сделку в работу' },
      { icon: 'check', title: 'Отображаем статусы сделки в CRM:', description: 'покажем, в каком отделе потерялся клиент' },
      { icon: 'arrow-path', title: 'Соберем актуальную статистику', description: 'по банкам и одобрениям, для контроля и принятия решений' },
    ]}
    variant="light"
  />

  <!-- Кейсы клиентов -->
  <section class="bg-gray-50 py-24">
    <div class="mx-auto max-w-[1440px] px-4">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-base font-semibold text-brand">Кейсы клиентов</h2>
        <p class="mt-2 text-4xl font-semibold text-gray-900 sm:text-5xl">Результаты наших клиентов</p>
        <p class="mt-6 text-lg text-gray-600">75 из 100 крупнейших застройщиков России уже работают с ДВИЖ</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">ГК ЛСР</h3>
          <p class="text-3xl font-bold text-brand mb-2">+281%</p>
          <p class="text-sm text-gray-600">Рост количества заявок после подключения платформы ДВИЖ</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">ГК Точно</h3>
          <p class="text-3xl font-bold text-brand mb-2">1 116 → 3 500</p>
          <p class="text-sm text-gray-600">Рост количества заявок на ипотеку в месяц</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">ГК Самолет</h3>
          <p class="text-3xl font-bold text-brand mb-2">816 млн ₽</p>
          <p class="text-sm text-gray-600">Дополнительный доход — 96 квартир продано через платформу</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Гранель</h3>
          <p class="text-3xl font-bold text-brand mb-2">66.7% → 95%</p>
          <p class="text-sm text-gray-600">Рост процента одобрения ипотечных заявок</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Страна Девелопмент</h3>
          <p class="text-3xl font-bold text-brand mb-2">150 млн ₽/мес</p>
          <p class="text-sm text-gray-600">Ежемесячный объём сделок через платформу</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">GloraX</h3>
          <p class="text-3xl font-bold text-brand mb-2">−30%</p>
          <p class="text-sm text-gray-600">Сокращение затрат на сопровождение сделок</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Поддержка -->
  <section class="bg-gray-50 py-24">
    <div class="mx-auto max-w-[1440px] px-4">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-base font-semibold text-brand">Поддержка</h2>
        <p class="mt-2 text-4xl font-semibold text-gray-900 sm:text-5xl">Команда поддержки на вашей стороне</p>
        <p class="mt-6 text-lg text-gray-600">Каждому клиенту ДВИЖ доступна выделенная команда специалистов</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center"><svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg></div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Менеджер успеха</h3>
          <p class="text-sm text-gray-600">Персональный менеджер для решения стратегических задач и роста показателей</p>
        </div>
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center"><svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg></div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Консультант поддержки</h3>
          <p class="text-sm text-gray-600">Оперативная помощь по любым вопросам работы с платформой</p>
        </div>
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-16 h-16 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center"><svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg></div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Аналитик</h3>
          <p class="text-sm text-gray-600">Подготовка отчетов, анализ данных и рекомендации по оптимизации</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      title="Записаться на демо"
      description="75 из ТОП-100 застройщиков уже с нами. Покажем, как ДВИЖ увеличит ваши продажи"
      buttonText="Записаться на демо"
      buttonHref="#"
    />
  </div>
</SiteLayout>
