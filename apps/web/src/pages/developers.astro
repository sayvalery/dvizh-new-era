---
/**
 * Для девелоперов — ДВИЖ
 */
import SiteLayout from '../layouts/SiteLayout.astro'
import Card from '../components/lab-new/Card.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import LogoMarquee from '../components/lab-new/LogoMarquee.astro'
import FeatureCard from '../components/lab-new/FeatureCard.astro'
import CTA from '../components/ui/CTA.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import ProductSectionNew from '../components/ui/ProductSectionNew.astro'
import StoryCard from '../components/ui/StoryCard.astro'
import ComparisonSection from '../components/ui/ComparisonSection.astro'
---

<SiteLayout title="Для девелоперов">
  <!-- Hero split layout (Linear-style) -->
  <HeroSection
    layout="split"
    badge="Платформа для выполнения планов продаж"
    title="Ускоряем цикл сделки и забираем на себя всю рутину"
    description="Повышаем конверсии на каждом этапе работы с заявками: от консультации до одобрения в банке"
    demoLabel="Посмотреть демо"
    kpLabel="Получить КП"
    stats={[
      { value: '26% больше', label: 'сделок на том же трафике' },
      { value: '1 500 000+', label: 'сделок на рынке недвижимости прошло через ДВИЖ' },
      { value: '79', label: 'застройщиков из ТОП-100 ЕРЗ наши партнеры' },
    ]}
    statsCols={3}
  />

  <!-- Бегущая строка с логотипами -->
  <LogoMarquee
    logos={[
      { name: 'ЛСР', src: '/partners/lsr.svg' },
      { name: 'А101', src: '/partners/a101.svg' },
      { name: 'AVA', src: '/partners/ava.svg' },
      { name: 'Глоракс', src: '/partners/glorax.svg' },
      { name: 'Гранель', src: '/partners/ganel.svg' },
      { name: 'Страна', src: '/partners/strana.svg' },
    ]}
  />

  <!-- Card -->
  <section class="pt-32 pb-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card
          title="Наполнить воронку
качественными лидами"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/1.jpg"
        />
        <Card
          title="Закрыть клиентов
быстрее, чем конкуренты"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/3.jpg"
        />
        <Card
          title="Увеличить средний чек
и допродажи"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/2.jpg"
        />
        <Card
          title="Увидеть результат работы
каждого сотрудника"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/4.jpg"
        />
      </div>
    </div>
  </section>

  <!-- ProductSectionNew -->
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <ProductSectionNew
    sections={[
      { number: "01", title: "Качественные лиды", active: true },
      { number: "02", title: "Работа с клиентами" },
      { number: "03", title: "Быстрые заявки" },
      { number: "04", title: "Апсейл клиентов" },
      { number: "05", title: "Контроль работы" },
    ]}
    title={{
      lg: "Заголовок для больших экранов (lg+)",
      md: "Заголовок для средних экранов (md)",
      sm: "Заголовок для мобильных (sm)"
    }}
    descriptions={[
      "Это демонстрация нового компонента ProductSectionNew",
      "С адаптивными заголовками и изображениями в правом блоке"
    ]}
    primaryButton={{ label: "Читать кейс", href: "#" }}
    secondaryButton={{ label: "Подробнее о модуле", href: "#" }}
    rightContent={[
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-2v2.jpg",
            alt: "Цифровая ипотека",
            width: 600,
            height: 400
          }
        ],
        title: "Повышаем качество лидов",
        description: [
          "Форма на сайт для проверки кредитного рейтинга: приведем надежных клиентов",
          "Скоринг по банковским стандартам: расскажем все о платежеспособности покупателей",
          "Ипотечный калькулятор для сайта: приведем клиентов с нужным уровнем дохода"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/sales-section-1.jpg",
            alt: "Ипотечный калькулятор",
            width: 600,
            height: 400
          }
        ],
        title: "Помогаем закрывать даже сложных клиентов",
        description: [
          "Финансовый скоринг покажет, как улучшить портрет клиента до отправки заявки в банк",
          "40+ банков-партнеров помогут подобрать ипотечную программу для каждого",
          "ДВИЖ AI рассчитает вероятность одобрения клиента в каждом банке и подберет лучшие варианты"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/sales-section-2.jpg",
            alt: "Финансовый скоринг",
            width: 600,
            height: 400
          }
        ],
        title: "... и делать это быстрее конкурентов",
        description: [
          "Актуальные статусы по сделке в CRM: контроль каждого этапа в карточке клиента",
          "Одна анкета для всех этапов: от заявки до регистрации",
          "Регистрация всех видов сделок и подписание любых документов в рамках 1 платформы",
          "Пакетное распознавание документов: никакого ручного ввода данных",
          "Заполнение анкеты через Госуслуги за 30 секунд"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/sales-section-3.jpg",
            alt: "Электронная регистрация",
            width: 600,
            height: 400
          }
        ],
        title: "Раскрываем финансовый потенциал клиентов",
        description: [
          "Покажем клиенту ежемесячный платеж и поможем выбрать квартиру под весь бюджет",
          "Рассчитаем ПДН* клиента и поможем увеличить средний чек сделки"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/sales-section-4.jpg",
            alt: "Движ AI",
            width: 600,
            height: 400
          }
        ],
        title: "Делаем работу менеджеров управляемой",
        description: [
          "Контроль всех этапов через CRM: покажем, как быстро менеджер взял сделку в работу",
          "Отображаем статусы сделки в CRM: покажем, в каком отделе потерялся клиент",
          "Соберем актуальную статистику по банкам и одобрениям, для контроля и принятия решений"
        ]
      }
    ]}
    />
  </div>

  <!-- Advantages -->
  <ComparisonSection
    title="Одно решение для всей сделки вместо кучи заплаток"
    leftTitle="Без ДВИЖа"
    leftItems={[
      'Данные клиента теряются, сделка застревает между отделами',
      'Менеджер тратит время на нецелевых клиентов и не выполняет KPI',
      'Нет потенциала для апсейла клиентов',
      'Менеджер узнаёт о финансовых проблемах клиента после отказа в банке',
      'Море цифр и ни одного ответа на вопрос: почему сделка так и не закрылась за полгода',
    ]}
    rightTitle="С ДВИЖом"
    rightItems={[
      'Вся сделка в одном окне: без ошибок и потерянных часов',
      'Менеджер успевает в 2 раза больше, выполняет KPI и не забывает про кофе-брейки',
      'Средний чек и допродажи постоянно растут',
      'Менеджер знает о платёжеспособности клиентов больше, чем они сами',
      'Вклад каждого сотрудника виден как под микроскопом',
    ]}
  />

  <!-- Feature Cards -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          Делаем все для ваших крутых результатов
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <FeatureCard
          title="Контроль всех этапов через CRM"
          subtitle="покажем, как быстро менеджер взял сделку в работу"
          color="#202b32"
          image="https://admin.dvizh.cc/api/media/file/5-new.jpg"
          imagePosition="right bottom"
        />
        <FeatureCard
          title="Отображаем статусы сделки в CRM"
          subtitle="покажем, в каком отделе потерялся клиент"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/6-new.jpg"
        />
        <FeatureCard
          title="Соберем актуальную статистику"
          subtitle="по банкам и одобрениям, для контроля и принятия решений"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/7-new.jpg"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-[1440px] mx-auto px-4">
      <CTA
        title="Бонус от ДВИЖа"
        description="Скачайте пример идеального отчета ипотечного отдела"
        buttonText="Посмотреть демо"
        buttonHref="#"
        image="https://admin.dvizh.cc/api/media/file/orthographic-front-view-3d-ui-icon-of-a-present--a%20(1).png"
        imageAlt="Подарок"
      />
    </div>
  </section>

  <!-- StoryCard -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          Не верите нам, спросите наших клиентов
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-1 lg:grid-cols-3 gap-6">
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/samolet-bg.jpg"
          title="Помогли начать обрабатывать на 281% больше заявок"
          person={{
            name: "Светлана Корнелюк",
            jobTitle: "Директор отдела продаж",
            photo: { url: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/a101.svg" alt="A101" class="h-6 object-contain" slot="logo" />
        </StoryCard>
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/lsr-bg.jpg"
          title="Дополнительно продали 96 квартир"
          person={{
            name: "Иван Петров",
            jobTitle: "Руководитель отдела ипотеки",
            photo: { url: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/lsr.svg" alt="LSR" class="h-6 object-contain" slot="logo" />
        </StoryCard>
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/glorax-bg.jpg"
          title="Увеличили объем закрытых сделок с 1116 до 3500 за год"
          person={{
            name: "Мария Сидорова",
            jobTitle: "Ипотечный брокер",
            photo: { url: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/glorax.svg" alt="Глоракс" class="h-6 object-contain" slot="logo" />
        </StoryCard>
      </div>
    </div>
  </section>

  <!-- Form Closing -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <FormClosing
        title="Не оставим вас одних"
        description="За каждым клиентом закреплён менеджер, который обучит вашу команду, подключит все виджеты и ответит на ваши вопросы в течение 57 секунд"
        preset="lead"
        submitLabel="Отправить заявку"
        bgColor="bg-gray-100"
        bgImage="https://admin.dvizh.cc/api/media/file/form-image.jpg"
        showGradient={false}
        privacyText="Нажимая кнопку «Отправить заявку», вы даёте согласие на обработку ваших персональных данных"
      />
    </div>
  </section>
</SiteLayout>
