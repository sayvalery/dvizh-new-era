---
import SiteLayout from '../layouts/SiteLayout.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import BentoGrid from '../components/ui/BentoGrid.astro'
import SuccessStoriesCarousel from '../components/ui/SuccessStoriesCarousel.astro'
---

<SiteLayout
  title="ДВИЖ — цифровые продукты для рынка недвижимости"
  description="Ипотека, регистрация, скоринг и другие решения для банков, девелоперов и агентств"
>
  <!-- Hero Section -->
  <HeroSection
    title="Лучшие отделы продаж
застройщиков используют ДВИЖ"
    description="Единая платформа для увеличения продаж. Закрываем весь цикл сделки: от подбора квартиры до одобрения ипотеки и регистрации в Росреестре"
    formPreset="lead"
  />

  <!-- Девелоперы с ДВИЖ -->
  <section class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
      <h2 class="text-5xl font-medium tracking-tight text-gray-900" style="letter-spacing: -0.06em">
        Девелоперы с ДВИЖ
      </h2>
    </div>
    <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8 mt-16">
      <BentoGrid
        items={[
          { title: "<span class='text-[#FF4D00]'>Закрывают до 26% больше сделок</span> на том же трафике" },
          { title: "<span class='text-[#FF4D00]'>Получают больше выручки</span> на одного менеджера" },
          { title: "<span class='text-[#FF4D00]'>Снизили количество отказов</span> по ипотеке" },
          { title: "<span class='text-[#FF4D00]'>Сократили расходы</span> на электронную регистрацию" },
        ]}
      />
    </div>
  </section>

  <!-- Истории успеха -->
  <section class="bg-white py-[52px]">
    <div class="mx-auto px-6 lg:max-w-7xl lg:px-8">
      <SuccessStoriesCarousel
        variant="mini"
        title="70+ историй успеха
на рынке девелопмента"
        stories={[
          {
            title: "Процент одобрения заявок <span class='text-[#FF4D00]'>вырос с 80% до 89%</span>",
            person: { name: "Иван Иванов", jobTitle: "Директор по продажам" }
          },
          {
            title: "Сроки рассмотрения заявок на кредит <span class='text-[#FF4D00]'>сократились в 7-10 раз</span>",
            person: { name: "Мария Петрова", jobTitle: "Финансовый директор" }
          },
          {
            title: "Сократили расходы на регистрацию <span class='text-[#FF4D00]'>на 30%</span>",
            person: { name: "Алексей Сидоров", jobTitle: "Коммерческий директор" }
          }
        ]}
      />
    </div>
  </section>

  <!-- Решения -->
  <section class="max-w-7xl mx-auto px-4 py-16 border-t border-gray-100">
    <h2 class="text-2xl font-bold mb-8">Решения</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        { title: 'Для банков', href: '/banki', description: 'Комплексные решения для ипотечных и розничных банков' },
        { title: 'Для девелоперов', href: '/developers', description: 'Автоматизация продаж и оформления сделок' },
        { title: 'Для агентств недвижимости', href: '/agentstva-nedvizhimosti', description: 'Платформа для риелторов и агентств' },
      ].map(s => (
        <a href={s.href} class="p-6 border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors">
          <h3 class="font-semibold mb-1">{s.title}</h3>
          <p class="text-sm text-gray-600">{s.description}</p>
        </a>
      ))}
    </div>
  </section>
</SiteLayout>
