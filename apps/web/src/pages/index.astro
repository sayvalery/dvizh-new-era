---
import SiteLayout from '../layouts/SiteLayout.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import LogoStream from '../components/ui/LogoStream.astro'
import BentoGrid from '../components/ui/BentoGrid.astro'
import SuccessStoriesCarousel from '../components/ui/SuccessStoriesCarousel.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import SectionBlock from '../components/ui/SectionBlock.astro'
import GradientCTA from '../components/ui/GradientCTA.astro'
import BlogCards from '../components/ui/BlogCards.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import CTA from '../components/ui/CTA.astro'

const partnerLogos = [
  '/partners/a101.svg',
  '/partners/ava.svg',
  '/partners/ganel.svg',
  '/partners/glorax.svg',
  '/partners/lsr.svg',
  '/partners/strana.svg',
  '/logo-dvizh-white.svg',
]
---

<SiteLayout
  title="ДВИЖ — цифровые продукты для рынка недвижимости"
  description="Единая платформа для увеличения продаж. Закрываем весь цикл сделки: от подбора квартиры до одобрения ипотеки и регистрации в Росреестре"
  transparentHeader
>
  <!-- Hero -->
  <HeroSection
    title={"Лучшие отделы\u00A0продаж застройщиков используют ДВИЖ"}
    description="Единая платформа для увеличения продаж. Закрываем весь цикл сделки: от подбора квартиры до одобрения ипотеки и регистрации в Росреестре"
    formPreset="lead"
    formSubmitLabel="Получить демо"
    withGradient
    gradientColors={['#ff4d00', '#ff6b2c', '#ffb347', '#ffd866']}
  >
    <div slot="right" class="w-full h-[700px]">
      <LogoStream logos={partnerLogos} duration={24} logoWidth={140} logoHeight={48} />
    </div>
  </HeroSection>

  <!-- Девелоперы с ДВИЖ -->
  <section class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-[1440px] px-4">
      <h2 class="text-5xl font-medium text-gray-900">
        Девелоперы с ДВИЖ
      </h2>
    </div>
    <div class="mx-auto max-w-[1440px] px-4 mt-16">
      <BentoGrid
        items={[
          { title: "<span class='text-[#FF4D00]'>Закрывают до 26% больше сделок</span> на том же трафике" },
          { title: "<span class='text-[#FF4D00]'>Получают больше выручки</span> на одного менеджера" },
          { title: "<span class='text-[#FF4D00]'>Снизили количество отказов</span> по ипотеке" },
          { title: "<span class='text-[#FF4D00]'>Сократили расходы</span> на электронную регистрацию" },
        ]}
      />
    </div>
  </section>

  <!-- Истории успеха -->
  <section class="bg-white py-[52px]">
    <div class="mx-[100.5px] px-4">
      <SuccessStoriesCarousel
        variant="mini"
        title="70+ историй успеха
на рынке девелопмента"
        stories={[
          {
            title: "Помогли начать обрабатывать <span class='text-[#FF4D00]'>на 281% заявок больше</span>, чем в среднем на рынке",
            person: { name: "Иван Иванов", jobTitle: "Директор по продажам" }
          },
          {
            title: "Увеличили объем закрытых сделок <span class='text-[#FF4D00]'>с 1116 до 3500 за год</span>",
            person: { name: "Мария Петрова", jobTitle: "Финансовый директор" }
          },
          {
            title: "Дополнительно продали <span class='text-[#FF4D00]'>96 квартир</span>",
            person: { name: "Алексей Сидоров", jobTitle: "Коммерческий директор" }
          }
        ]}
      />
    </div>
  </section>

  <!-- Цифровая ипотека -->
  <FeaturesGrid
    badge="Цифровая ипотека"
    title="Поможем перевыполнить план продаж на том же трафике"
    features={[
      { icon: 'check', title: 'До 96% одобрения', description: '' },
      { icon: 'check', title: 'Единая анкета в 40+ банков', description: '' },
      { icon: 'check', title: 'Моментальное заполнение анкеты через Госуслуги', description: '' },
      { icon: 'check', title: 'Готовые интеграции с CRM', description: '' },
      { icon: 'check', title: 'Анализ работы менеджеров', description: '' },
    ]}
    variant="light"
  />

  <!-- Ипотечный калькулятор -->
  <FeaturesGrid
    badge="Ипотечный калькулятор"
    title="Приведем больше лидов с сайта"
    features={[
      { icon: 'check', title: 'Расчет рассрочки и досрочного погашения', description: '' },
      { icon: 'check', title: 'Автоматическое обновление ставок и программ', description: '' },
      { icon: 'check', title: 'API для интеграции с вашим сайтом и личным кабинетом', description: '' },
      { icon: 'check', title: 'Брендирование калькулятора под ваши цвета', description: '' },
    ]}
    variant="light"
  />

  <!-- Финансовый скоринг -->
  <FeaturesGrid
    badge="Финансовый скоринг"
    title="Сократим процент отказов по проблемным заемщикам"
    features={[
      { icon: 'check', title: 'Проверка заемщика по 15 источникам', description: '' },
      { icon: 'check', title: 'Ежемесячный скоринг по ДДУ c рассрочкой', description: '' },
      { icon: 'check', title: 'Рекомендации по улучшению кредитной истории', description: '' },
    ]}
    variant="light"
  />

  <!-- Электронная регистрация сделок -->
  <FeaturesGrid
    badge="Электронная регистрация сделок"
    title="Сократим стоимость регистрации в Росреестре"
    features={[
      { icon: 'check', title: 'Сквозное оформление сделки от ипотеки до регистрации', description: '' },
      { icon: 'check', title: 'До 30% дешевле цены конкурентов', description: '' },
      { icon: 'check', title: 'Все виды сделок', description: '' },
    ]}
    variant="light"
  />

  <!-- ДВИЖ AI -->
  <FeaturesGrid
    badge="ДВИЖ AI"
    title="Нейросети на службе вашего бизнеса"
    features={[
      { icon: 'check', title: 'Расчет вероятности и скорости одобрения по банкам', description: '' },
      { icon: 'check', title: 'Автоматический подбор ипотечной программы', description: '' },
      { icon: 'check', title: 'Меньше отказов, больше сделок', description: '' },
    ]}
    variant="light"
  />

  <!-- Не оставим вас одних -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <FormClosing
      preset="lead"
      title="Не оставим вас одних"
      description="За каждым клиентом закреплен менеджер, который обучит вашу команду, подключит все виджеты и ответит на ваши вопросы в течение 57 секунд"
      submitLabel="Оставить заявку"
    />
  </div>

  <!-- CTA: Как оценить отдел ипотеки -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      title="Как оценить отдел ипотеки"
      description="Скачайте пример отчета и узнайте, какие метрики нужно контролировать"
      buttonText="Получить отчет"
      drawerPreset="research"
    />
  </div>
</SiteLayout>
