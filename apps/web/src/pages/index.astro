---
/**
 * Главная страница ДВИЖ
 */
import SiteLayout from '../layouts/SiteLayout.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import LogoDrum from '../components/ui/LogoDrum.astro'
import BentoGrid from '../components/ui/BentoGrid.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import SectionBlock from '../components/ui/SectionBlock.astro'
import GradientCTA from '../components/ui/GradientCTA.astro'
import BlogCards from '../components/ui/BlogCards.astro'
import ProductSection from '../components/ui/ProductSection.astro'
import ProductSectionNew from '../components/ui/ProductSectionNew.astro'
import BentoThreeNew from '../components/ui/BentoThreeNew.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import Card from '../components/lab-new/Card.astro'
import CTA from '../components/ui/CTA.astro'
import StoryCard from '../components/ui/StoryCard.astro'

const partnerLogos = [
  '/partners/a101.svg',
  '/partners/ava.svg',
  '/partners/ganel.svg',
  '/partners/glorax.svg',
  '/partners/lsr.svg',
  '/partners/strana.svg',
  '/logo-dvizh-white.svg',
]

const blogArticles = [
  {
    image: "https://admin.dvizh.cc/api/media/file/1.jpg",
    imageAlt: "Статья 1",
    date: "15 января 2025",
    category: "Продажи",
    title: "Как увеличить конверсию заявок в ипотеке",
    description: "Практические советы по работе с заявками",
    href: "#",
    author: { name: "Иван Иванов", role: "Эксперт" }
  },
  {
    image: "https://admin.dvizh.cc/api/media/file/2.jpg",
    imageAlt: "Статья 2",
    date: "10 января 2025",
    category: "Маркетинг",
    title: "Эффективные стратегии для девелоперов",
    description: "Как привлечь больше клиентов",
    href: "#",
    author: { name: "Мария Петрова", role: "Маркетолог" }
  },
  {
    image: "https://admin.dvizh.cc/api/media/file/3.jpg",
    imageAlt: "Статья 3",
    date: "5 января 2025",
    category: "Автоматизация",
    title: "Внедрение CRM для отдела продаж",
    description: "Пошаговое руководство",
    href: "#",
    author: { name: "Алексей Сидоров", role: "Технолог" }
  }
]
---

<SiteLayout
  title="ДВИЖ — цифровые продукты для рынка недвижимости"
  description="AI-платформа для автоматизации продаж и маркетинга застройщиков"
  transparentHeader
>
  <!-- Hero -->
  <HeroSection
    title={"Лучшие отделы\u00A0продаж застройщиков используют ДВИЖ"}
    description="Единая платформа для увеличения продаж. Закрываем весь цикл сделки: от подбора квартиры до одобрения ипотеки и регистрации в Росреестре"
    formPreset="lead"
    formSubmitLabel="Получить демо"
    withGradient
    gradientColors={['#ff4d00', '#ff6b2c', '#ffb347', '#ffd866']}
  >
    <div slot="right" class="w-full h-[700px]">
      <LogoDrum logos={partnerLogos} duration={55} />
    </div>
  </HeroSection>

  <!-- Card -->
  <section class="pt-32 pb-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card
          title="Закрывают до 26% больше сделок на том же трафике"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/1.jpg"
        />
        <Card
          title="Снизили количество отказов по ипотеке"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/3.jpg"
        />
        <Card
          title="Получают больше выручки на одного менеджера"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/2.jpg"
        />
        <Card
          title="Сократили расходы на электронную регистрацию"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/4.jpg"
        />
      </div>
    </div>
  </section>

  <!-- ProductSectionNew Demo -->
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <ProductSectionNew
    sections={[
      { number: "01", title: "Цифровая ипотека", active: true },
      { number: "02", title: "Ипотечный калькулятор" },
      { number: "03", title: "Финансовый скоринг" },
      { number: "04", title: "Электронная регистрация" },
      { number: "05", title: "Движ AI" },
    ]}
    title={{
      lg: "Заголовок для больших экранов (lg+)",
      md: "Заголовок для средних экранов (md)",
      sm: "Заголовок для мобильных (sm)"
    }}
    descriptions={[
      "Это демонстрация нового компонента ProductSectionNew",
      "С адаптивными заголовками и изображениями в правом блоке"
    ]}
    primaryButton={{ label: "Запросить демо", href: "#" }}
    rightContent={[
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-1.jpg",
            alt: "Цифровая ипотека",
            width: 600,
            height: 400
          }
        ],
        title: "Поможем перевыполнить план продаж на том же трафике",
        description: [
          "До 96% одобрения",
          "Единая анкета в 40+ банков",
          "Моментальное заполнение анкеты через Госуслуги",
          "Готовые интеграции с CRM",
          "Анализ работы менеджеров"
        ],
        secondaryButton: { label: "Подробнее об ипотеке", href: "/ipoteka" }
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-2v2.jpg",
            alt: "Ипотечный калькулятор",
            width: 600,
            height: 400
          }
        ],
        title: "Приведем больше лидов с сайта",
        description: [
          "Расчет рассрочки и досрочного погашения",
          "Автоматическое обновление ставок и программ",
          "API для интеграции с вашим сайтом и личным кабинетом",
          "Брендирование калькулятора под ваши цвета"
        ],
        secondaryButton: { label: "Подробнее о калькуляторе", href: "/ipotechnyy-kalkulyator" }
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-3.jpg",
            alt: "Финансовый скоринг",
            width: 600,
            height: 400
          }
        ],
        title: "Сократим процент отказов по проблемным заемщикам",
        description: [
          "Проверка заемщика по 15 источникам",
          "Ежемесячный скоринг по ДДУ c рассрочкой",
          "Рекомендации по улучшению кредитной истории"
        ],
        secondaryButton: { label: "Подробнее о скоринге", href: "/scoring" }
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-4.jpg",
            alt: "Электронная регистрация",
            width: 600,
            height: 400
          }
        ],
        title: "Сократим стоимость регистрации в Росреестре",
        description: [
          "Сквозное оформление сделки от ипотеки до регистрации",
          "До 30% дешевле цены конкурентов",
          "Все виды сделок"
        ],
        secondaryButton: { label: "Подробнее о регистрации", href: "/elektronnaya-registraciya" }
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-5.jpg",
            alt: "Движ AI",
            width: 600,
            height: 400
          }
        ],
        title: "Нейросети на службе вашего бизнеса",
        description: [
          "Расчет вероятности и скорости одобрения по банкам",
          "Автоматический подбор ипотечной программы",
          "Меньше отказов, больше сделок"
        ]
      }
    ]}
    />
  </div>

  <!-- BentoThreeNew Demo (hidden) -->
  <!--
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <BentoThreeNew
      title={{
        lg: "Закрывайте до 26% больше сделок на таком же трафике",
        md: "Закрывайте до 26% больше сделок на таком же трафике",
        sm: "Закрывайте до 26% больше сделок на таком же трафике"
      }}
      bigCard={{
        title: "Получайте больше выручку",
        description: "на одного менеджера"
      }}
      smallCards={[
        {
          title: "Снижайте количество отказов",
          description: "по ипотеке"
        },
        {
          title: "Сокращайте количество расходов",
          description: "на электронную регистрацию"
        }
      ]}
  />
  </div>
  -->

  <!-- StoryCard Demo -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          70+ историй успеха<br>на рынке девелопмента
        </h2>
      </div>
    <div class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-1 lg:grid-cols-3 gap-6">
      <StoryCard
        backgroundImage="https://admin.dvizh.cc/api/media/file/samolet-bg.jpg"
        title="Помогли начать обрабатывать на 281% больше заявок"
        person={{
          name: "Светлана Корнелюк",
          jobTitle: "Директор отдела продаж",
          photo: { url: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=100&auto=format&fit=crop" }
        }}
      >
        <img src="/partners/a101.svg" alt="A101" class="h-6 object-contain" slot="logo" />
      </StoryCard>
      <StoryCard
        backgroundImage="https://admin.dvizh.cc/api/media/file/lsr-bg.jpg"
        title="Дополнительно продали 96 квартир"
        person={{
          name: "Иван Петров",
          jobTitle: "Руководитель отдела ипотеки",
          photo: { url: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=100&auto=format&fit=crop" }
        }}
      >
        <img src="/partners/lsr.svg" alt="LSR" class="h-6 object-contain" slot="logo" />
      </StoryCard>
      <StoryCard
        backgroundImage="https://admin.dvizh.cc/api/media/file/glorax-bg.jpg"
        title="Увеличили объем закрытых сделок с 1116 до 3500 за год"
        person={{
          name: "Мария Сидорова",
          jobTitle: "Ипотечный брокер",
          photo: { url: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&auto=format&fit=crop" }
        }}
      >
        <img src="/partners/glorax.svg" alt="Глоракс" class="h-6 object-contain" slot="logo" />
      </StoryCard>
    </div>
  </div>

  <!-- Form Closing -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <FormClosing
        title="Не оставим вас одних"
        description="За каждым клиентом закреплён менеджер, который обучит вашу команду, подключит все виджеты и ответит на ваши вопросы в течение 57 секунд"
        preset="lead"
        submitLabel="Отправить заявку"
        bgColor="bg-gray-100"
        bgImage="https://admin.dvizh.cc/api/media/file/form-image.jpg"
        showGradient={false}
        privacyText="Нажимая кнопку «Отправить заявку», вы даёте согласие на обработку ваших персональных данных"
      />
    </div>
  </section>

  <!-- CTA (hidden) -->
  <!--
  <section class="py-20">
    <div class="max-w-[1440px] mx-auto px-4">
      <CTA
        title="Бонус от ДВИЖа"
        description="Скачайте пример идеального отчета ипотечного отдела"
        buttonText="Посмотреть демо"
        buttonHref="#"
      />
    </div>
  </section>
  -->

</SiteLayout>
