---
import BaseLayout from '../../layouts/BaseLayout.astro'

const roles = [
  { slug: 'otdel-prodazh', title: 'Департамент продаж', description: 'Инструменты для отдела продаж' },
  { slug: 'otdel-ipoteki', title: 'Отдел ипотеки', description: 'Автоматизация ипотечного процесса' },
  { slug: 'otdel-oformleniya', title: 'Отдел оформления', description: 'Электронное оформление сделок' },
  { slug: 'marketing-i-analitika', title: 'Маркетинг и аналитика', description: 'Аналитика и маркетинговые инструменты' },
]
---

<BaseLayout title="Для кого">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-12">Для кого</h1>
    <div class="grid md:grid-cols-2 gap-6">
      {roles.map(r => (
        <a href={`/for-whom/${r.slug}`} class="p-6 border rounded-xl hover:bg-gray-50">
          <h2 class="text-xl font-semibold mb-2">{r.title}</h2>
          <p class="text-gray-600 text-sm">{r.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
