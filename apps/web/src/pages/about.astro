---
import SiteLayout from '../layouts/SiteLayout.astro'
import StatsSection from '../components/ui/StatsSection.astro'
import Timeline from '../components/ui/Timeline.astro'
---

<SiteLayout title="О компании — ДВИЖ" description="ДВИЖ — AI-решения для автоматизации продаж и маркетинга застройщиков">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-4">О компании</h1>
    <p class="text-xl text-gray-600 mb-12 max-w-3xl">
      ДВИЖ — AI-платформа для автоматизации продаж и маркетинга застройщиков.
      75 из 100 крупнейших застройщиков России используют ДВИЖ. Более 1,5 млн заявок обработано на платформе.
    </p>
  </div>

  <StatsSection
    cols={4}
    items={[
      { value: '75', label: 'Из ТОП-100 крупнейших застройщиков — клиентов' },
      { value: '1,5 млн+', label: 'Заявок обработано на платформе' },
      { value: 'x2', label: 'Рост конверсии с продуктами ДВИЖ' },
      { value: '2018', label: 'Год основания' },
    ]}
  />

  <Timeline
    badge="История"
    title="История развития"
    items={[
      { year: '2018', title: 'Цифровая ипотека', description: 'Появилась цифровая ипотека' },
      { year: '2019', title: 'Электронная анкета', description: 'Разработали электронную анкету' },
      { year: '2020', title: 'Платформа ДВИЖ', description: 'Переименовали в платформу ДВИЖ' },
      { year: '2021', title: 'Электронная регистрация', description: 'Добавили модуль электронной регистрации' },
      { year: '2022', title: 'Бронирование и ЛК', description: 'Разработали модуль бронирования и личный кабинет' },
      { year: '2023', title: 'Страхование и AI', description: 'Создали модуль страхования и ДВИЖ AI' },
      { year: '2024', title: 'Полностью онлайн', description: 'Первая в России ипотечная сделка полностью онлайн' },
    ]}
  />

  <div class="max-w-5xl mx-auto px-4 py-16">
    <!-- Основатели -->
    <h2 class="text-2xl font-bold mb-8">Основатели</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <div class="p-6 border rounded-xl">
        <div class="w-16 h-16 rounded-full bg-brand-50 mb-4 flex items-center justify-center text-brand font-heading text-xl font-bold">РГ</div>
        <h3 class="font-semibold text-lg">Роман Гуров</h3>
        <p class="text-gray-500 text-sm">Сооснователь, CEO</p>
      </div>
      <div class="p-6 border rounded-xl">
        <div class="w-16 h-16 rounded-full bg-brand-50 mb-4 flex items-center justify-center text-brand font-heading text-xl font-bold">МЕ</div>
        <h3 class="font-semibold text-lg">Максим Ершов</h3>
        <p class="text-gray-500 text-sm">Сооснователь, руководитель проекта ДВИЖ.брокер</p>
      </div>
    </div>

    <!-- Ключевые клиенты -->
    <h2 class="text-2xl font-bold mb-4">Ключевые клиенты</h2>
    <p class="text-gray-600 mb-6">75 из 100 крупнейших застройщиков России используют ДВИЖ, в том числе:</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
      {[
        'ГК ЛСР', 'ГК Самолет', 'ГК Точно', 'Гранель', 'Страна Девелопмент', 'GloraX'
      ].map(name => (
        <div class="p-4 bg-gray-50 rounded-xl text-center">
          <p class="font-semibold text-sm">{name}</p>
        </div>
      ))}
    </div>

    <!-- География -->
    <h2 class="text-2xl font-bold mb-8">География присутствия</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { city: 'Москва', area: '16 млн м²' },
        { city: 'Санкт-Петербург', area: '6 млн м²' },
        { city: 'Краснодар', area: '5 млн м²' },
        { city: 'Тюмень', area: '1,6 млн м²' },
        { city: 'Татарстан', area: '530 тыс м²' },
        { city: 'Ростов', area: '463 тыс м²' },
        { city: 'Свердловская обл.', area: '260 тыс м²' },
      ].map(g => (
        <div class="p-4 bg-gray-50 rounded-xl">
          <p class="font-semibold text-sm">{g.city}</p>
          <p class="text-gray-500 text-xs mt-1">{g.area}</p>
        </div>
      ))}
    </div>
  </div>
</SiteLayout>
