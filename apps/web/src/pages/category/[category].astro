---
import BlogLayout from '../../layouts/BlogLayout.astro'
import { getCategories, getBlogPosts, normalizeMediaUrl } from '../../lib/payload'

export async function getStaticPaths() {
  const { docs: categories } = await getCategories()
  return categories.map((cat: any) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }))
}

const { category } = Astro.props
const { docs: posts } = await getBlogPosts({
  where: {
    _status: { equals: 'published' },
    'category.slug': { equals: category.slug },
  },
  limit: 200,
})
---

<BlogLayout title={`${category.title} — Блог`}>
  <div class="max-w-7xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/blog" class="hover:underline">Блог</a>
      <span class="mx-2">›</span>
      <span>{category.title}</span>
    </nav>
    <h1 class="text-4xl font-bold mb-2">{category.title}</h1>
    <p class="text-gray-400 text-sm mb-10">{posts.length} статей</p>

    {posts.length === 0 ? (
      <p class="text-gray-500">В этой категории пока нет статей.</p>
    ) : (
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post: any) => {
          const coverUrl = normalizeMediaUrl(post.cover?.url)
          return (
            <a href={`/blog/${post.slug}`} class="group border rounded-xl overflow-hidden hover:shadow-md transition-shadow">
              {coverUrl ? (
                <img src={coverUrl} alt={post.title} class="w-full aspect-video object-cover" loading="lazy" decoding="async" width="400" height="225" />
              ) : (
                <div class="w-full aspect-video bg-gray-100" />
              )}
              <div class="p-5">
                <h2 class="font-semibold group-hover:underline">{post.title}</h2>
                {post.excerpt && <p class="text-sm text-gray-600 mt-2 line-clamp-2">{post.excerpt}</p>}
              </div>
            </a>
          )
        })}
      </div>
    )}
  </div>
</BlogLayout>
