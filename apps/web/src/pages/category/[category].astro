---
import BlogLayout from '../../layouts/BlogLayout.astro'
import BlogCard from '../../components/ui/BlogCard.astro'
import { getCategories, getBlogPosts } from '../../lib/payload'

export async function getStaticPaths() {
  const { docs: categories } = await getCategories()
  return categories.map((cat: any) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }))
}

const { category } = Astro.props

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Блог', item: `${Astro.site}blog` },
    { '@type': 'ListItem', position: 2, name: category.title },
  ],
}

const { docs: posts } = await getBlogPosts({
  where: {
    _status: { equals: 'published' },
    'category.slug': { equals: category.slug },
  },
  limit: 200,
})
---

<BlogLayout title={`${category.title} — Блог`} jsonLd={breadcrumbLd}>
  <div class="max-w-[1440px] mx-auto px-4 py-16">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/blog" class="hover:underline">Блог</a>
      <span class="mx-2">›</span>
      <span>{category.title}</span>
    </nav>
    <h1 class="text-4xl font-bold mb-2">{category.title}</h1>
    <p class="text-gray-400 text-sm mb-10">{posts.length} статей</p>

    {posts.length === 0 ? (
      <p class="text-gray-500">В этой категории пока нет статей.</p>
    ) : (
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {posts.map((post: any) => (
          <BlogCard
            title={post.title}
            slug={post.slug}
            cover={post.cover}
            category={post.category?.title}
            excerpt={post.excerpt}
          />
        ))}
      </div>
    )}
  </div>
</BlogLayout>
