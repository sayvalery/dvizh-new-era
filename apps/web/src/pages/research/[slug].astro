---
import SiteLayout from '../../layouts/SiteLayout.astro'
import BlockRenderer from '../../components/blocks/BlockRenderer.astro'
import { getResearch, getResearchItem } from '../../lib/payload'

export async function getStaticPaths() {
  const { docs } = await getResearch({ limit: 100 })
  return docs.map((item: any) => ({ params: { slug: item.slug } }))
}

const { slug } = Astro.params
const item = await getResearchItem(slug!)
if (!item) return Astro.redirect('/404')

const fileUrl = item.file?.url ?? null
---

<SiteLayout title={item.meta?.title ?? item.title} description={item.meta?.description ?? item.description}>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/research" class="hover:underline">Исследования</a>
    </nav>
    <h1 class="text-4xl font-bold mb-4">{item.title}</h1>
    {item.description && <p class="text-xl text-gray-600 mb-8">{item.description}</p>}

    {fileUrl && (
      <a
        href={fileUrl}
        download
        class="inline-block mb-10 bg-black text-white px-5 py-2 rounded font-medium text-sm hover:bg-gray-800"
      >
        Скачать PDF
      </a>
    )}

    <BlockRenderer blocks={item.content ?? []} />
  </div>
</SiteLayout>
