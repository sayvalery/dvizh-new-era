                <PersonCard person={{ name: 'Иван Азизов', jobTitle: 'CEO, ДВИЖ' }} />
                <PersonCard person={{ name: 'Анна Смирнова', jobTitle: 'Head of Product' }} />
                <PersonCard person={{ name: 'Без должности' }} />
