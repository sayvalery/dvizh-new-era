---
import BaseLayout from '../../layouts/BaseLayout.astro'
import NavBar from '../../components/ui/NavBar.astro'
import PersonCard from '../../components/ui/PersonCard.astro'
import Form from '../../components/ui/Form.astro'
import Drawer from '../../components/ui/Drawer.astro'
import CTABlock from '../../components/blocks/CTABlock.astro'
import ImageBlock from '../../components/blocks/ImageBlock.astro'
import VideoBlock from '../../components/blocks/VideoBlock.astro'
import QuoteBlock from '../../components/blocks/QuoteBlock.astro'
import FormBlock from '../../components/blocks/FormBlock.astro'
import RichTextBlock from '../../components/blocks/RichTextBlock.astro'
import FeaturesGrid from '../../components/ui/FeaturesGrid.astro'
import BentoGrid from '../../components/ui/BentoGrid.astro'
import SuccessStory from '../../components/ui/SuccessStory.astro'
import HeroSection from '../../components/ui/HeroSection.astro'
import StatsSection from '../../components/ui/StatsSection.astro'

// В продакшн-билде страница не генерируется
export function getStaticPaths() {
  if (import.meta.env.PROD) return []
  return [
    { params: { slug: undefined }, props: { section: 'overview' } },
    { params: { slug: 'navigation' }, props: { section: 'navigation' } },
    { params: { slug: 'persons' }, props: { section: 'persons' } },
    { params: { slug: 'typography' }, props: { section: 'typography' } },
    { params: { slug: 'colors' }, props: { section: 'colors' } },
    { params: { slug: 'buttons' }, props: { section: 'buttons' } },
    { params: { slug: 'forms' }, props: { section: 'forms' } },
    { params: { slug: 'cards' }, props: { section: 'cards' } },
    { params: { slug: 'drawer' }, props: { section: 'drawer' } },
    { params: { slug: 'blocks' }, props: { section: 'blocks' } },
    { params: { slug: 'features' }, props: { section: 'features' } },
    { params: { slug: 'stories' }, props: { section: 'stories' } },
  { params: { slug: 'bento' }, props: { section: 'bento' } },
    { params: { slug: 'hero' }, props: { section: 'hero' } },
    { params: { slug: 'stats' }, props: { section: 'stats' } },
  ]
}

const { section } = Astro.props

const sections = [
  { slug: '', label: 'Обзор' },
  { slug: 'navigation', label: 'Навигация' },
  { slug: 'persons', label: 'Персоны' },
  { slug: 'typography', label: 'Типографика' },
  { slug: 'colors', label: 'Цвета' },
  { slug: 'buttons', label: 'Кнопки' },
  { slug: 'forms', label: 'Формы' },
  { slug: 'cards', label: 'Карточки' },
  { slug: 'drawer', label: 'Дровер' },
  { slug: 'blocks', label: 'Блоки статей' },
  { slug: 'features', label: 'Features Grid' },
  { slug: 'stories', label: 'Success Story' },
  { slug: 'bento', label: 'Bento Grid' },
  { slug: 'hero', label: 'Hero Section' },
  { slug: 'stats', label: 'Stats Section' },
]
---

<BaseLayout title={`UI Kit — ${section}`}>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-56 border-r border-gray-200 px-4 py-8 shrink-0 flex flex-col">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">UI Kit</p>
      <nav class="space-y-1 flex-1">
        {sections.map(s => (
          <a
            href={s.slug ? `/ui-kit/${s.slug}` : '/ui-kit'}
            class={`block px-3 py-1.5 rounded text-sm ${section === (s.slug || 'overview') ? 'bg-gray-100 font-medium' : 'text-gray-600 hover:text-gray-900'}`}
          >
            {s.label}
          </a>
        ))}
      </nav>
      <a href="/" class="block px-3 py-1.5 text-sm text-gray-400 hover:text-gray-900 mt-4">← На сайт</a>
    </aside>

    <!-- Content -->
    <main class="flex-1 px-10 py-8">
      {section === 'overview' && (
        <div>
          <h1 class="text-3xl font-bold mb-2">UI Kit</h1>
          <p class="text-gray-600 mb-8">Компоненты и токены дизайн-системы ДВИЖ. Доступно только в dev-режиме.</p>
          <div class="grid grid-cols-2 gap-4 max-w-lg">
            {sections.slice(1).map(s => (
              <a href={`/ui-kit/${s.slug}`} class="p-4 border rounded-xl hover:bg-gray-50 text-sm font-medium">
                {s.label} →
              </a>
            ))}
          </div>
        </div>
      )}

      {section === 'navigation' && (
        <div>
          <h1 class="text-3xl font-bold mb-6">Навигация</h1>

          <div class="space-y-10">
            <div>
              <p class="text-sm font-medium text-gray-400 mb-3">Основной сайт — с дропдаунами</p>
              <div class="-mx-10 border-y border-gray-200">
                <NavBar
                  logo={{ label: 'ДВИЖ', href: '#' }}
                  items={[
                    { label: 'Продукты', children: [
                      { label: 'Электронная регистрация', href: '#', description: 'Цифровая регистрация сделок' },
                      { label: 'Ипотека', href: '#', description: 'Ипотечный процесс' },
                      { label: 'QBR', href: '#', description: 'Аналитика и отчёты' },
                    ]},
                    { label: 'Решения', children: [
                      { label: 'Для банков', href: '#' },
                      { label: 'Для девелоперов', href: '#' },
                    ]},
                    { label: 'Блог', href: '#' },
                    { label: 'О нас', href: '#' },
                  ]}
                  cta={{ label: 'Запросить демо', preset: 'demo' }}
                />
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-400 mb-3">Блог / ДВИЖ Инсайты — с вторичной ссылкой</p>
              <div class="-mx-10 border-y border-gray-200">
                <NavBar
                  logo={{ label: 'ДВИЖ Инсайты', href: '#' }}
                  items={[
                    { label: 'Кейсы', href: '#' },
                    { label: 'Аналитика', href: '#' },
                    { label: 'Маркетинг', href: '#' },
                    { label: 'Правила девелопера', href: '#' },
                  ]}
                  secondaryLink={{ label: '← dvizh.io', href: '#' }}
                />
              </div>
            </div>
          </div>
        </div>
      )}

      {section === 'persons' && (
        <div>
          <h1 class="text-3xl font-bold mb-6">Персоны</h1>
          <div class="space-y-10">

            <div>
              <p class="text-sm font-medium text-gray-400 mb-4">Full — аватар + имя + должность</p>
              <div class="flex flex-wrap gap-6">
                <PersonCard person={{ name: 'Иван Азизов', jobTitle: 'CEO, ДВИЖ' }} />
                <PersonCard person={{ name: 'Анна Смирнова', jobTitle: 'Head of Product' }} />
                <PersonCard person={{ name: 'Без должности' }} />
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-400 mb-4">Inline — аватар + имя (без подзаголовка)</p>
              <div class="flex flex-wrap gap-4">
                <PersonCard person={{ name: 'Иван Азизов', jobTitle: 'CEO' }} variant="inline" />
                <PersonCard person={{ name: 'Анна Смирнова' }} variant="inline" />
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-400 mb-4">В контексте статьи — inline в шапке, full внизу</p>
              <div class="border rounded-xl p-6 max-w-lg space-y-4">
                <div class="flex items-center gap-4">
                  <PersonCard person={{ name: 'Иван Азизов' }} variant="inline" />
                  <span class="text-sm text-gray-400">12 января 2025</span>
                </div>
                <p class="text-sm text-gray-600">Текст статьи…</p>
                <div class="border-t pt-4">
                  <p class="text-xs uppercase tracking-wide text-gray-400 mb-3">Автор</p>
                  <PersonCard person={{ name: 'Иван Азизов', jobTitle: 'CEO, ДВИЖ' }} variant="full" />
                </div>
              </div>
            </div>

          </div>
        </div>
      )}

      {section === 'typography' && (
        <div class="space-y-8">
          <h1 class="text-3xl font-bold mb-6">Типографика</h1>
          <div class="space-y-4">
            <div><span class="text-xs text-gray-400 block mb-1">text-5xl font-bold</span><p class="text-5xl font-bold">Заголовок H1</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-4xl font-bold</span><p class="text-4xl font-bold">Заголовок H2</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-3xl font-semibold</span><p class="text-3xl font-semibold">Заголовок H3</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-xl</span><p class="text-xl">Подзаголовок / лид-текст</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-base</span><p class="text-base">Основной текст. Движ помогает банкам и девелоперам автоматизировать ипотечный процесс.</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-sm text-gray-600</span><p class="text-sm text-gray-600">Вспомогательный текст, подписи, метаданные</p></div>
            <div><span class="text-xs text-gray-400 block mb-1">text-xs uppercase tracking-wide</span><p class="text-xs uppercase tracking-wide text-gray-400">Метка / Теги</p></div>
          </div>
        </div>
      )}

      {section === 'colors' && (
        <div>
          <h1 class="text-3xl font-bold mb-6">Цвета</h1>
          <div class="space-y-6">
            <div>
              <p class="text-sm font-medium mb-3">Основные</p>
              <div class="flex gap-3">
                <div class="w-16 h-16 bg-black rounded-lg"></div>
                <div class="w-16 h-16 bg-white border rounded-lg"></div>
                <div class="w-16 h-16 bg-gray-100 rounded-lg"></div>
                <div class="w-16 h-16 bg-gray-200 rounded-lg"></div>
                <div class="w-16 h-16 bg-gray-500 rounded-lg"></div>
                <div class="w-16 h-16 bg-gray-900 rounded-lg"></div>
              </div>
            </div>
          </div>
        </div>
      )}

      {section === 'buttons' && (
        <div>
          <h1 class="text-3xl font-bold mb-6">Кнопки</h1>
          <div class="space-y-8">
            <div>
              <p class="text-sm font-medium text-gray-400 mb-3">Primary</p>
              <div class="flex gap-3 items-center">
                <button class="bg-black text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-gray-800">Запросить демо</button>
                <button class="bg-black text-white px-4 py-2 rounded text-sm font-medium hover:bg-gray-800">Малый</button>
                <button class="bg-black text-white px-8 py-4 rounded-xl font-medium hover:bg-gray-800">Большой</button>
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-400 mb-3">Secondary</p>
              <div class="flex gap-3 items-center">
                <button class="border border-gray-900 text-gray-900 px-6 py-3 rounded-lg text-sm font-medium hover:bg-gray-50">Узнать больше</button>
                <button class="border border-gray-300 text-gray-600 px-4 py-2 rounded text-sm hover:bg-gray-50">Отмена</button>
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-400 mb-3">Ghost / Link</p>
              <div class="flex gap-3 items-center">
                <button class="text-gray-900 text-sm font-medium underline underline-offset-2">Подробнее →</button>
                <button class="text-gray-500 text-sm hover:text-gray-900">← Назад</button>
              </div>
            </div>
          </div>
        </div>
      )}

      {section === 'forms' && (
        <div>
          <h1 class="text-3xl font-bold mb-8">Формы</h1>
          <div class="space-y-12">

            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">stacked (по умолчанию) — лейбл сверху</p>
              <p class="text-xs text-gray-400 mb-4"><code>{'<Form preset="demo" />'}</code></p>
              <div class="max-w-sm border rounded-xl p-6">
                <Form preset="demo" />
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">labels-left — лейбл слева, инпут справа</p>
              <p class="text-xs text-gray-400 mb-4"><code>{'<Form preset="demo" layout="labels-left" />'}</code></p>
              <div class="max-w-lg border rounded-xl p-6">
                <Form preset="demo" layout="labels-left" />
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">Пресеты</p>
              <div class="grid grid-cols-2 gap-6 max-w-2xl">
                <div class="border rounded-xl p-5">
                  <p class="text-xs text-gray-400 mb-3">preset="lead"</p>
                  <Form preset="lead" />
                </div>
                <div class="border rounded-xl p-5">
                  <p class="text-xs text-gray-400 mb-3">preset="subscribe"</p>
                  <Form preset="subscribe" />
                </div>
                <div class="border rounded-xl p-5">
                  <p class="text-xs text-gray-400 mb-3">preset="research"</p>
                  <Form preset="research" />
                </div>
              </div>
            </div>

          </div>
        </div>
      )}

      {section === 'cards' && (
        <div>
          <h1 class="text-3xl font-bold mb-6">Карточки</h1>
          <div class="grid grid-cols-2 gap-6 max-w-2xl">
            <div class="border rounded-xl p-6 hover:shadow-md transition-shadow">
              <h3 class="font-semibold mb-2">Карточка продукта</h3>
              <p class="text-sm text-gray-600">Описание продукта в одну-две строки.</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-6">
              <h3 class="font-semibold mb-2">Карточка на фоне</h3>
              <p class="text-sm text-gray-600">Вариант с серым фоном.</p>
            </div>
            <div class="border rounded-xl overflow-hidden hover:shadow-md transition-shadow col-span-2">
              <div class="bg-gray-100 h-40 w-full"></div>
              <div class="p-5">
                <span class="text-xs text-gray-400 uppercase tracking-wide">Категория</span>
                <h3 class="font-semibold mt-1">Карточка статьи с обложкой</h3>
                <p class="text-sm text-gray-600 mt-1 line-clamp-2">Описание статьи в две строки. Ещё немного текста для примера.</p>
              </div>
            </div>
          </div>
        </div>
      )}
      {section === 'drawer' && (
        <div>
          <h1 class="text-3xl font-bold mb-8">Дровер</h1>
          <div class="space-y-10">

            <div>
              <p class="text-sm font-medium text-gray-400 mb-4">
                Глобальный дровер живёт в SiteLayout. Любая кнопка на странице открывает его через Alpine event:
              </p>
              <pre class="bg-gray-50 rounded-xl p-4 text-sm overflow-x-auto mb-6">{'@click="$dispatch(\'open-drawer\', { preset: \'demo\' })"'}</pre>
            </div>

            <div x-data="{ open: false, preset: 'demo' }">
              <p class="text-sm font-medium text-gray-400 mb-4">Демо — кнопки открывают разные пресеты</p>
              <div class="flex flex-wrap gap-3 mb-8">
                <button
                  @click="preset = 'demo'; open = true"
                  class="bg-black text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-gray-800"
                >
                  Запросить демо
                </button>
                <button
                  @click="preset = 'lead'; open = true"
                  class="border border-gray-900 text-sm font-medium px-4 py-2 rounded-lg hover:bg-gray-50"
                >
                  Связаться с нами
                </button>
                <button
                  @click="preset = 'research'; open = true"
                  class="border border-gray-900 text-sm font-medium px-4 py-2 rounded-lg hover:bg-gray-50"
                >
                  Получить исследование
                </button>
              </div>

              <!-- Inline drawer demo (самостоятельный, не глобальный) -->
              <div x-show="open" class="fixed inset-0 z-40 bg-black/30" @click="open = false" style="display:none"></div>
              <div
                x-show="open"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="translate-x-full"
                x-transition:enter-end="translate-x-0"
                x-transition:leave="transition ease-in duration-200"
                x-transition:leave-start="translate-x-0"
                x-transition:leave-end="translate-x-full"
                class="fixed inset-y-0 right-0 z-50 w-full max-w-md bg-white shadow-xl flex flex-col"
                style="display:none"
              >
                <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100 shrink-0">
                  <div>
                    <h2 x-show="preset === 'demo'" style="display:none" class="font-semibold">Запросить демо</h2>
                    <h2 x-show="preset === 'lead'" style="display:none" class="font-semibold">Связаться с нами</h2>
                    <h2 x-show="preset === 'research'" style="display:none" class="font-semibold">Получить исследование</h2>
                  </div>
                  <button @click="open = false" class="-mr-2 p-2 rounded-md text-gray-400 hover:text-gray-600">
                    <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                <div class="flex-1 overflow-y-auto px-6 py-6">
                  <div x-show="preset === 'demo'" style="display:none"><Form preset="demo" layout="labels-left" /></div>
                  <div x-show="preset === 'lead'" style="display:none"><Form preset="lead" layout="labels-left" /></div>
                  <div x-show="preset === 'research'" style="display:none"><Form preset="research" layout="labels-left" /></div>
                </div>
              </div>
            </div>

          </div>
        </div>
      )}
      {section === 'blocks' && (
        <div>
          <h1 class="text-3xl font-bold mb-2">Блоки статей</h1>
          <p class="text-gray-600 mb-1">
            Добавляются в статью через CMS → BlogPosts → content (поле Rich Text с блоками).
          </p>
          <p class="text-sm text-gray-400 mb-2">
            Конфиги: <code>apps/cms/src/blocks/</code>
          </p>
          <p class="text-sm text-gray-400 mb-10">
            Рендереры: <code>apps/web/src/components/blocks/</code> → <code>BlockRenderer.astro</code>
          </p>

          <div class="space-y-16 max-w-2xl">

            <!-- RichTextBlock -->
            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">RichTextBlock — форматированный текст</p>
              <p class="text-xs text-gray-400 mb-4">
                blockType: <code>richText</code> · поле: <code>content</code> (Lexical JSON)
              </p>
              <div class="border rounded-xl p-6">
                <RichTextBlock block={{
                  content: {
                    root: {
                      children: [
                        { type: 'heading', tag: 'h2', children: [{ type: 'text', text: 'Заголовок внутри статьи', format: 0 }] },
                        { type: 'paragraph', children: [{ type: 'text', text: 'Основной текст. ДВИЖ помогает банкам и девелоперам автоматизировать ипотечный процесс от заявки до регистрации сделки.', format: 0 }] },
                        { type: 'list', listType: 'bullet', children: [
                          { type: 'listitem', children: [{ type: 'text', text: 'Электронная регистрация сделок', format: 0 }] },
                          { type: 'listitem', children: [{ type: 'text', text: 'Цифровая ипотека для банков', format: 0 }] },
                          { type: 'listitem', children: [{ type: 'text', text: 'Ипотечный калькулятор', format: 0 }] },
                        ]},
                      ]
                    }
                  }
                }} />
              </div>
            </div>

            <!-- CTABlock -->
            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">CTABlock — CTA-баннер</p>
              <p class="text-xs text-gray-400 mb-2">
                blockType: <code>cta</code> · поля: <code>heading</code>, <code>description</code>, <code>buttonText</code>, <code>buttonAction</code>, <code>formPreset</code> / <code>link</code>
              </p>
              <p class="text-xs text-gray-400 mb-4">
                buttonAction: <code>sidebarForm</code> — открывает дровер, <code>link</code> — переход по ссылке
              </p>
              <div class="space-y-4">
                <CTABlock block={{
                  heading: 'Попробуйте электронную регистрацию',
                  description: 'Покажем, как это работает для вашего банка или агентства недвижимости.',
                  buttonText: 'Запросить демо',
                  buttonAction: 'sidebarForm',
                  formPreset: 'demo',
                }} />
                <CTABlock block={{
                  heading: 'Читайте наши исследования',
                  buttonText: 'Перейти в блог',
                  buttonAction: 'link',
                  link: '/blog',
                }} />
              </div>
            </div>

            <!-- QuoteBlock -->
            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">QuoteBlock — цитата</p>
              <p class="text-xs text-gray-400 mb-4">
                blockType: <code>quote</code> · поля: <code>text</code>, <code>author</code>, <code>company</code>, <code>photo</code> (upload)
              </p>
              <div class="border rounded-xl px-6">
                <QuoteBlock block={{
                  text: 'ДВИЖ сократил время оформления ипотечной сделки с 14 дней до 2. Это кардинально изменило наш клиентский опыт.',
                  author: 'Иван Петров',
                  company: 'Банк "Надёжный"',
                }} />
              </div>
            </div>

            <!-- ImageBlock -->
            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">ImageBlock — изображение</p>
              <p class="text-xs text-gray-400 mb-4">
                blockType: <code>image</code> · поля: <code>image</code> (upload), <code>caption</code>, <code>alt</code>
              </p>
              <div class="border rounded-xl px-6">
                <ImageBlock block={{
                  image: { url: 'https://placehold.co/800x400/f3f4f6/9ca3af?text=800+x+400' },
                  caption: 'Подпись к изображению',
                  alt: 'Демонстрационное изображение',
                }} />
              </div>
            </div>

            <!-- VideoBlock -->
            <div>
              <p class="text-sm font-medium text-gray-400 mb-1">VideoBlock — видео (YouTube / Vimeo)</p>
              <p class="text-xs text-gray-400 mb-4">
                blockType: <code>video</code> · поля: <code>url</code> (YouTube или Vimeo), <code>caption</code>
              </p>
