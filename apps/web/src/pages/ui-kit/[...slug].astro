import CTA from '../../components/ui/CTA.astro'
import CTABlock from '../../components/blocks/CTABlock.astro'
import ImageBlock from '../../components/blocks/ImageBlock.astro'
import VideoBlock from '../../components/blocks/VideoBlock.astro'
import QuoteBlock from '../../components/blocks/QuoteBlock.astro'
import FormBlock from '../../components/blocks/FormBlock.astro'
import RichTextBlock from '../../components/blocks/RichTextBlock.astro'
import FeaturesGrid from '../../components/ui/FeaturesGrid.astro'
import BentoGrid from '../../components/ui/BentoGrid.astro'
import SuccessStory from '../../components/ui/SuccessStory.astro'
import SuccessStoriesCarousel from '../../components/ui/SuccessStoriesCarousel.astro'
import HeroSection from '../../components/ui/HeroSection.astro'
import MeshGradient from '../../components/ui/MeshGradient.astro'
import StatsSection from '../../components/ui/StatsSection.astro'
import Timeline from '../../components/ui/Timeline.astro'
import BlogCard from '../../components/ui/BlogCard.astro'
import SectionBlock from '../../components/ui/SectionBlock.astro'
import PropsTable from '../../components/ui/PropsTable.astro'

// --- Исходники компонентов для парсинга пропсов (Vite ?raw import) ---
import navBarRaw from '../../components/ui/NavBar.astro?raw'
import personCardRaw from '../../components/ui/PersonCard.astro?raw'
import formRaw from '../../components/ui/Form.astro?raw'
import formClosingRaw from '../../components/ui/FormClosing.astro?raw'
import ctaRaw from '../../components/ui/CTA.astro?raw'
import featuresGridRaw from '../../components/ui/FeaturesGrid.astro?raw'
import successStoryRaw from '../../components/ui/SuccessStory.astro?raw'
import storiesCarouselRaw from '../../components/ui/SuccessStoriesCarousel.astro?raw'
import bentoGridRaw from '../../components/ui/BentoGrid.astro?raw'
import heroSectionRaw from '../../components/ui/HeroSection.astro?raw'
import meshGradientRaw from '../../components/ui/MeshGradient.astro?raw'
import statsSectionRaw from '../../components/ui/StatsSection.astro?raw'
import timelineRaw from '../../components/ui/Timeline.astro?raw'
import blogCardRaw from '../../components/ui/BlogCard.astro?raw'
import sectionBlockRaw from '../../components/ui/SectionBlock.astro?raw'

interface PropMeta {
  name: string
  type: string
  required: boolean
  description: string
  defaultValue?: string
}

function parseSource(source: string): { description: string; props: PropMeta[] } {
  if (!source) return { description: '', props: [] }

  // JSDoc описание (первый блок перед interface Props)
  const jsdocMatch = source.match(/\/\*\*\s*\n([\s\S]*?)\*\//)
  let description = ''
  if (jsdocMatch) {
    description = jsdocMatch[1]
      .replace(/^\s*\*\s?/gm, '')
      .split('\n@')[0]
      .trim()
  }

  // interface Props { ... }
  const propsMatch = source.match(/interface Props\s*\{([\s\S]*?)\n\}/)
  if (!propsMatch) return { description, props: [] }

  const props: PropMeta[] = []
  const lines = propsMatch[1].split('\n')
  let comment = ''

  for (const line of lines) {
    const cmt = line.match(/\/\*\*\s*(.*?)\s*\*\//)
    if (cmt) { comment = cmt[1]; continue }
    const prop = line.match(/^\s*(\w+)(\?)?\s*:\s*(.+)$/)
    if (prop) {
      props.push({
        name: prop[1],
        required: !prop[2],
        type: prop[3].trim().replace(/;?\s*$/, ''),
        description: comment,
      })
      comment = ''
    }
  }

  // Дефолтные значения из деструктуризации
  const destructMatch = source.match(/const\s*\{([\s\S]*?)\}\s*=\s*Astro\.props/)
  if (destructMatch) {
    const block = destructMatch[1]
    const re = /(\w+)(?:\s*:\s*\w+)?\s*=\s*([^,}\n]+)/g
    let m
    while ((m = re.exec(block)) !== null) {
      const p = props.find(x => x.name === m[1])
      if (p) p.defaultValue = m[1] === 'class' ? "''" : m[2].trim()
    }
  }

  return { description, props }
}

// Парсим все компоненты
const navBarMeta = parseSource(navBarRaw)
const personCardMeta = parseSource(personCardRaw)
const formMeta = parseSource(formRaw)
const formClosingMeta = parseSource(formClosingRaw)
const ctaMeta = parseSource(ctaRaw)
const featuresGridMeta = parseSource(featuresGridRaw)
const successStoryMeta = parseSource(successStoryRaw)
const storiesCarouselMeta = parseSource(storiesCarouselRaw)
const bentoGridMeta = parseSource(bentoGridRaw)
const heroSectionMeta = parseSource(heroSectionRaw)
const meshGradientMeta = parseSource(meshGradientRaw)
const statsSectionMeta = parseSource(statsSectionRaw)
const timelineMeta = parseSource(timelineRaw)
const blogCardMeta = parseSource(blogCardRaw)
const sectionBlockMeta = parseSource(sectionBlockRaw)

// В продакшн-билде страница не генерируется
export function getStaticPaths() {
  if (import.meta.env.PROD) return []
  return [
    { params: { slug: undefined }, props: { section: 'overview' } },
    { params: { slug: 'navigation' }, props: { section: 'navigation' } },
    { params: { slug: 'persons' }, props: { section: 'persons' } },
    { params: { slug: 'typography' }, props: { section: 'typography' } },
    { params: { slug: 'colors' }, props: { section: 'colors' } },
    { params: { slug: 'buttons' }, props: { section: 'buttons' } },
    { params: { slug: 'forms' }, props: { section: 'forms' } },
    { params: { slug: 'form-closing' }, props: { section: 'form-closing' } },
    { params: { slug: 'cards' }, props: { section: 'cards' } },
    { params: { slug: 'drawer' }, props: { section: 'drawer' } },
    { params: { slug: 'cta' }, props: { section: 'cta' } },
    { params: { slug: 'blocks' }, props: { section: 'blocks' } },
    { params: { slug: 'features' }, props: { section: 'features' } },
    { params: { slug: 'stories' }, props: { section: 'stories' } },
    { params: { slug: 'stories-carousel' }, props: { section: 'stories-carousel' } },
    { params: { slug: 'bento' }, props: { section: 'bento' } },
    { params: { slug: 'hero' }, props: { section: 'hero' } },
    { params: { slug: 'mesh-gradient' }, props: { section: 'mesh-gradient' } },
    { params: { slug: 'stats' }, props: { section: 'stats' } },
    { params: { slug: 'timeline' }, props: { section: 'timeline' } },
    { params: { slug: 'blogcard' }, props: { section: 'blogcard' } },
    { params: { slug: 'section-block' }, props: { section: 'section-block' } },
  ]
}

const { section } = Astro.props

const sections = [
  { slug: '', label: 'Обзор' },
  { slug: 'navigation', label: 'Навигация' },
  { slug: 'persons', label: 'Персоны' },
  { slug: 'typography', label: 'Типографика' },
  { slug: 'colors', label: 'Цвета' },
  { slug: 'buttons', label: 'Кнопки' },
  { slug: 'forms', label: 'Формы' },
  { slug: 'form-closing', label: 'Form Closing' },
  { slug: 'cards', label: 'Карточки' },
  { slug: 'drawer', label: 'Дровер' },
  { slug: 'cta', label: 'CTA' },
  { slug: 'blocks', label: 'Блоки статей' },
  { slug: 'features', label: 'Features Grid' },
  { slug: 'stories', label: 'Success Story' },
  { slug: 'stories-carousel', label: 'Stories Carousel' },
  { slug: 'bento', label: 'Bento Grid' },
  { slug: 'hero', label: 'Hero Section' },
  { slug: 'mesh-gradient', label: 'Mesh Gradient' },
  { slug: 'stats', label: 'Stats Section' },
  { slug: 'timeline', label: 'Timeline' },
  { slug: 'blogcard', label: 'Blog Card' },
  { slug: 'section-block', label: 'Section Block' },
]
