---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlockRenderer from '../../components/blocks/BlockRenderer.astro'
import { getCases, getCase } from '../../lib/payload'

export async function getStaticPaths() {
  const { docs } = await getCases({ limit: 100 })
  return docs.map((c: any) => ({ params: { slug: c.slug } }))
}

const { slug } = Astro.params
const caseItem = await getCase(slug!)
if (!caseItem) return Astro.redirect('/404')
---

<BaseLayout title={caseItem.meta?.title ?? caseItem.title} description={caseItem.meta?.description ?? caseItem.description}>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/cases" class="hover:underline">Кейсы</a>
    </nav>
    {caseItem.client && <p class="text-sm text-gray-500 uppercase tracking-wide mb-2">{caseItem.client}</p>}
    <h1 class="text-4xl font-bold mb-4">{caseItem.title}</h1>
    {caseItem.description && <p class="text-xl text-gray-600 mb-10">{caseItem.description}</p>}

    <BlockRenderer blocks={caseItem.content ?? []} />
  </div>
</BaseLayout>
