---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getCases } from '../../lib/payload'

const { docs: cases } = await getCases()
---

<SiteLayout title="Кейсы">
  <div class="max-w-[1440px] mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-10">Кейсы</h1>

    {cases.length === 0 ? (
      <p class="text-gray-500">Кейсы скоро появятся.</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-6">
        {cases.map((c: any) => (
          <a href={`/cases/${c.slug}`} class="p-6 border rounded-xl hover:bg-gray-50">
            {c.client && <span class="text-xs text-gray-500 uppercase tracking-wide">{c.client}</span>}
            <h2 class="text-xl font-semibold mt-1 mb-2">{c.title}</h2>
            {c.description && <p class="text-sm text-gray-600">{c.description}</p>}
          </a>
        ))}
      </div>
    )}
  </div>
</SiteLayout>
