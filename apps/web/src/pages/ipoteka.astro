---
/**
 * Ипотечная платформа ДВИЖ
 */
import SiteLayout from '../layouts/SiteLayout.astro'
import Card from '../components/lab-new/Card.astro'
import HeroWithBadge from '../components/lab-new/HeroWithBadge.astro'
import FeatureCard from '../components/lab-new/FeatureCard.astro'
import CTA from '../components/ui/CTA.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import ProductSectionNew from '../components/ui/ProductSectionNew.astro'
import StoryCard from '../components/ui/StoryCard.astro'
---

<SiteLayout title="Цифровая ипотека — ДВИЖ">
  <!-- Hero с бейджем -->
  <HeroWithBadge
    badge="Ипотечная платформа"
    title="Закрывайте до 26% больше сделок на том же трафике"
    description="Повышаем конверсии на каждом этапе работы с заявками: от консультации до одобрения в банке"
    submitLabel="Отправить"
    logos={[
      { name: 'ЛСР', src: '/partners/lsr.svg' },
      { name: 'А101', src: '/partners/a101.svg' },
      { name: 'AVA', src: '/partners/ava.svg' },
      { name: 'Глоракс', src: '/partners/glorax.svg' },
      { name: 'Гранель', src: '/partners/ganel.svg' },
      { name: 'Страна', src: '/partners/strana.svg' },
    ]}
  />

  <!-- Card -->
  <section class="pt-32 pb-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card
          title="Сократили количество
отказов по ипотеке"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/1.jpg"
        />
        <Card
          title="Перестали терять сделки
из-за клиентов с низким КР"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/3.jpg"
        />
        <Card
          title="Ускорили заполнение
анкеты до 10 секунд"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/2.jpg"
        />
        <Card
          title="Стали закрывать больше
сделок без роста штата"
          description="какие-то цифры или показатели"
          image="https://admin.dvizh.cc/api/media/file/4.jpg"
        />
      </div>
    </div>
  </section>

  <!-- ProductSectionNew -->
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <ProductSectionNew
    sections={[
      { number: "01", title: "Подбор банков", active: true },
      { number: "02", title: "Заполнение анкеты" },
      { number: "03", title: "Скоринг клиента" },
      { number: "04", title: "Отправка заявки" },
    ]}
    title={{
      lg: "Заголовок для больших экранов (lg+)",
      md: "Заголовок для средних экранов (md)",
      sm: "Заголовок для мобильных (sm)"
    }}
    descriptions={[
      "Это демонстрация нового компонента ProductSectionNew",
      "С адаптивными заголовками и изображениями в правом блоке"
    ]}
    primaryButton={{ label: "Начать", href: "#" }}
    secondaryButton={{ label: "Подробнее", href: "#" }}
    rightContent={[
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-1.jpg",
            alt: "Цифровая ипотека",
            width: 600,
            height: 400
          }
        ],
        title: "Повышаем конверсию из первичной консультации до 20%",
        description: [
          "Расчет досрочных погашений и рефинансирования",
          "40+ банков-партнеров и большой выбор ипотечных программ"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-2v2.jpg",
            alt: "Ипотечный калькулятор",
            width: 600,
            height: 400
          }
        ],
        title: "Сокращаем время на заполнение анкеты до 10 секунд",
        description: [
          "Распознавание документов от паспорта до справки 2-НДФЛ",
          "Заполнение анкеты через Госуслуги",
          "Одна анкета в 40+ банков"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-3.jpg",
            alt: "Финансовый скоринг",
            width: 600,
            height: 400
          }
        ],
        title: "Проверяем ваших клиентов по банковским стандартам",
        description: [
          "Долговая нагрузка и «красные флаги» клиента",
          "Рекомендации по улучшению рейтинга клиента"
        ]
      },
      {
        images: [
          {
            src: "https://admin.dvizh.cc/api/media/file/product-section-4.jpg",
            alt: "Электронная регистрация",
            width: 600,
            height: 400
          }
        ],
        title: "Увеличиваем процент одобрения до 95%+",
        description: [
          "Прогноз скорости и вероятности одобрения клиента в банках",
          "Отправка заявки сразу в 5+ банков"
        ]
      }
    ]}
    />
  </div>

  <!-- Feature Cards -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          Делаем все для ваших крутых результатов
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <FeatureCard
          title="Готовые интеграции"
          subtitle="с популярными системами"
          color="#202b32"
          image="https://admin.dvizh.cc/api/media/file/5-new.jpg"
          imagePosition="right bottom"
        />
        <FeatureCard
          title="57 секунд"
          subtitle="среднее время ответа в поддержке"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/6-new.jpg"
        />
        <FeatureCard
          title="Все ключевые показатели"
          subtitle="ипотечного отдела"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/7-new.jpg"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-[1440px] mx-auto px-4">
      <CTA
        title="Бонус от ДВИЖа"
        description="Скачайте пример идеального отчета ипотечного отдела"
        buttonText="Посмотреть демо"
        buttonHref="#"
      />
    </div>
  </section>

  <!-- StoryCard -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          70+ историй успеха<br>на рынке девелопмента
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-1 lg:grid-cols-3 gap-6">
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/samolet-bg.jpg"
          title="Помогли начать обрабатывать на 98% больше заявок"
          person={{
            name: "Светлана Корнелюк",
            jobTitle: "Директор отдела продаж",
            photo: { url: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/a101.svg" alt="A101" class="h-6 object-contain" slot="logo" />
        </StoryCard>
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/lsr-bg.jpg"
          title="Дополнительно продали 96 квартир"
          person={{
            name: "Иван Петров",
            jobTitle: "Руководитель отдела ипотеки",
            photo: { url: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/lsr.svg" alt="LSR" class="h-6 object-contain" slot="logo" />
        </StoryCard>
        <StoryCard
          backgroundImage="https://admin.dvizh.cc/api/media/file/glorax-bg.jpg"
          title="Одобрение ипотеки за 15 минут"
          person={{
            name: "Мария Сидорова",
            jobTitle: "Ипотечный брокер",
            photo: { url: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&auto=format&fit=crop" }
          }}
        >
          <img src="/partners/glorax.svg" alt="Глоракс" class="h-6 object-contain" slot="logo" />
        </StoryCard>
      </div>
    </div>
  </section>

  <!-- Form Closing -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <FormClosing
        title="Не оставим вас одних"
        description="За каждым клиентом закреплён менеджер, который обучит вашу команду, подключит все виджеты и ответит на ваши вопросы в течение 57 секунд"
        preset="lead"
        submitLabel="Отправить заявку"
        bgColor="bg-gray-100"
        bgImage="https://admin.dvizh.cc/api/media/file/form-image.jpg"
        showGradient={false}
        privacyText="Нажимая кнопку «Отправить заявку», вы даёте согласие на обработку ваших персональных данных"
      />
    </div>
  </section>
</SiteLayout>
