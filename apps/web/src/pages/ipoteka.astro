---
import SiteLayout from '../layouts/SiteLayout.astro'
import Form from '../components/ui/Form.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import StatsSection from '../components/ui/StatsSection.astro'
import LogoGrid from '../components/ui/LogoGrid.astro'
import CTA from '../components/ui/CTA.astro'
import BentoGrid from '../components/ui/BentoGrid.astro'
import SuccessStoriesCarousel from '../components/ui/SuccessStoriesCarousel.astro'
---

<SiteLayout title="Цифровая ипотека — ДВИЖ">
  <HeroSection
    badge="Ипотечная платформа"
    title="Закрывайте до 26% больше сделок на том же трафике"
    description="Повышаем конверсии на каждом этапе работы с заявками: от консультации до одобрения в банке"
    image=""
  />

  <StatsSection
    title="Девелоперы с ДВИЖом"
    cols={4}
    items={[
      { label: 'Сократили количество отказов по ипотеке' },
      { label: 'Перестали терять сделки из-за клиентов с низким КР' },
      { label: 'Ускорили заполнение анкеты до 10 секунд' },
      { label: 'Стали закрывать больше сделок без роста штата' },
    ]}
  />

  <!-- Logo Grid -->
  <LogoGrid
    logos={[
      { src: '/partners/lsr.svg', alt: 'ЛСР' },
      { src: '/partners/ava.svg', alt: 'AVA' },
      { src: '/partners/ganel.svg', alt: 'Ganel' },
      { src: '/partners/strana.svg', alt: 'Strana' },
      { src: '/partners/glorax.svg', alt: 'Glorax' },
      { src: '/partners/a101.svg', alt: 'A101' },
    ]}
    ctaText="Нам доверяют более 70 застройщиков"
    ctaLabel="Читать истории успеха →"
    ctaLink="/cases"
  />

  <!-- Features Grid 1: подбор банков -->
  <FeaturesGrid
    badge="подбор банков"
    title="Повышаем конверсию из первичной консультации <span class='text-brand'>до 20%</span>"
    features={[
      { icon: 'check', title: 'Расчет досрочных погашений и рефинансирования' },
      { icon: 'check', title: '40+ банков-партнеров и большой выбор ипотечных программ' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 2: заполнение анкеты -->
  <FeaturesGrid
    badge="заполнение анкеты"
    title="Сокращаем время на заполнение анкеты <span class='text-brand'>до 10 секунд</span>"
    features={[
      { icon: 'check', title: 'Распознавание документов от паспорта до справки 2-НДФЛ' },
      { icon: 'check', title: 'Заполнение анкеты через Госуслуги' },
      { icon: 'check', title: 'Одна анкета в 40+ банков' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 3: скоринг клиента -->
  <FeaturesGrid
    badge="скоринг клиента"
    title="Проверяем ваших клиентов <span class='text-brand'>по банковским стандартам</span>"
    features={[
      { icon: 'check', title: 'Долговая нагрузка и «красные флаги» клиента' },
      { icon: 'check', title: 'Рекомендации по улучшению рейтинга клиента' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 4: отправка заявки -->
  <FeaturesGrid
    badge="отправка заявки"
    title="Увеличиваем процент одобрения <span class='text-brand'>до 95%+</span>"
    features={[
      { icon: 'check', title: 'Прогноз скорости и вероятности одобрения клиента в банках' },
      { icon: 'check', title: 'Отправка заявки сразу в 5+ банков' },
    ]}
    image=""
    variant="light"
  />

  <!-- Bento Grid -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <BentoGrid
      columns={3}
      items={[
        { title: "Готовые интеграции с популярными системами", image: "" },
        { title: "57 секунд — среднее время ответа в чате поддержки", image: "" },
        { title: "Все ключевые показатели ипотечного отдела", image: "" }
      ]}
    />
  </div>

  <!-- CTA Бонус -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      title="Бонус от ДВИЖа"
      description="Скачайте пример идеального отчета ипотечного отдела"
      buttonText="Посмотреть демо"
      buttonHref="#"
    />
  </div>

  <!-- Stories Carousel -->
  <div class="max-w-[1440px] mx-auto px-4 py-20">
    <SuccessStoriesCarousel
      title="70+ историй успеха на рынке девелопмента"
      stories={[
        {
          title: "Помогли начать обрабатывать <span class='text-brand'>на 281% заявок больше</span>, чем в среднем на рынке",
          quote: "Раньше клиенты тонули в сборе справок и терялись. С ДВИЖем весь процесс занял минуты — конверсия из консультации в сделку выросла в разы.",
          person: {
            name: "Петрова Надежда",
            jobTitle: "Директор по маркетингу, ЛСР",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "ЛСР",
          logo: "",
          logoAlt: "ЛСР"
        },
        {
          title: "Дополнительно продали <span class='text-brand'>96 квартир</span>",
          quote: "Клиентов с низким КР раньше просто отсеивали. ДВИЖ показал, как с ними работать: подсказать, как закрыть кредитки, предложить другие программы. За год продали на 96 квартир больше.",
          person: {
            name: "Алексей Соколов",
            jobTitle: "Коммерческий директор, Самолет плюс",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "Самолет плюс",
          logo: "",
          logoAlt: "Самолет плюс"
        },
        {
          title: "Увеличили объем закрытых сделок <span class='text-brand'>с 1116 до 3500 за год</span>",
          quote: "Менеджеры физически не успевали обрабатывать заявки. Автоматизировали подбор банков и отправку — теперь один менеджер ведет в три раза больше клиентов.",
          person: {
            name: "Мария Иванова",
            jobTitle: "Руководитель отдела продаж",
          },
          image: "",
          imageAlt: "Компания",
          logo: "",
          logoAlt: "Логотип"
        },
        {
          title: "Сократили время обработки заявки <span class='text-brand'>с 3 дней до 4 часов</span>",
          quote: "Клиенты ждали одобрения банка несколько дней и уходили к конкурентам. Теперь подача идёт одновременно в несколько банков, ответ за пару часов — практически не теряем горячих лидов.",
          person: {
            name: "Дмитрий Козлов",
            jobTitle: "IT-директор, Девелопер",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "Девелопер",
          logo: "",
          logoAlt: "Девелопер"
        }
      ]}
    />
  </div>

  <!-- CTA Split -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      variant="split"
      badge="Бонус от ДВИЖа"
      title="Подберем решение под ваши задачи"
      description="• Найдем потерянные заявки и проанализируем путь клиента<br>• Проверим, не отстаете ли вы от рынка, и сравним ваши показатели с бенчмарками<br>• Составим рекомендации на основе опыта работы с девелоперами из топ-50"
      buttonText="Записаться на аудит"
      buttonHref="#"
    />
  </div>

  <!-- Form Closing -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <FormClosing
      preset="lead"
      title="Попробуйте ДВИЖ в деле"
      description="Оставьте заявку и мы свяжемся с вами в ближайшее время."
      submitLabel="Получить демо"
    />
  </div>
</SiteLayout>
