---
import SiteLayout from '../layouts/SiteLayout.astro'
import Form from '../components/ui/Form.astro'
import FormClosing from '../components/ui/FormClosing.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import StatsSection from '../components/ui/StatsSection.astro'
import CTA from '../components/ui/CTA.astro'
import BentoGrid from '../components/ui/BentoGrid.astro'
import SuccessStoriesCarousel from '../components/ui/SuccessStoriesCarousel.astro'
---

<SiteLayout title="Цифровая ипотека — ДВИЖ">
  <HeroSection
    badge="Ипотечная платформа"
    title="Закрывайте до 26% больше сделок на том же трафике"
    description="Повышаем конверсии на каждом этапе работы с заявками: от консультации до одобрения в банке"
    image=""
  />

  <StatsSection
    cols={4}
    items={[
      { label: 'Сократили количество отказов по ипотеке' },
      { label: 'Перестали терять сделки из-за клиентов с низким КР' },
      { label: 'Ускорили заполнение анкеты до 10 секунд' },
      { label: 'Стали закрывать больше сделок без роста штата' },
    ]}
  />

  <!-- Features Grid 1: подбор банков -->
  <FeaturesGrid
    badge="подбор банков"
    title="Повышаем конверсию из первичной консультации до 20%"
    description="Расчет досрочных погашений и рефинансирования. 40+ банков-партнеров и большой выбор ипотечных программ."
    features={[
      { icon: 'check', title: 'Расчет досрочных погашений', description: 'Автоматический расчет досрочных погашений и рефинансирования' },
      { icon: 'building-bank', title: '40+ банков-партнеров', description: 'Большой выбор ипотечных программ от ведущих банков' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 2: заполнение анкеты -->
  <FeaturesGrid
    badge="заполнение анкеты"
    title="Сокращаем время на заполнение анкеты до 10 секунд"
    description="Распознавание документов от паспорта до справки 2-НДФЛ. Заполнение анкеты через Госуслуги."
    features={[
      { icon: 'document', title: 'Распознавание документов', description: 'От паспорта до справки 2-НДФЛ' },
      { icon: 'globe', title: 'Госуслуги', description: 'Заполнение анкеты через Госуслуги' },
      { icon: 'arrow-path', title: 'Одна анкета в 40+ банков', description: 'Не нужно заполнять отдельно для каждого банка' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 3: скоринг клиента -->
  <FeaturesGrid
    badge="скоринг клиента"
    title="Проверяем ваших клиентов по банковским стандартам"
    description="Долговая нагрузка и «красные флаги» клиента. Рекомендации по улучшению рейтинга клиента."
    features={[
      { icon: 'check', title: 'Долговая нагрузка и «красные флаги»', description: 'Анализ финансового состояния клиента по банковским стандартам' },
      { icon: 'document', title: 'Рекомендации по улучшению рейтинга', description: 'Советы для повышения вероятности одобрения ипотеки' },
    ]}
    image=""
    variant="light"
  />

  <!-- Features Grid 4: отправка заявки -->
  <FeaturesGrid
    badge="отправка заявки"
    title="Увеличиваем процент одобрения до 95%+"
    description="Прогноз скорости и вероятности одобрения клиента в банках. Отправка заявки сразу в 5+ банков."
    features={[
      { icon: 'globe', title: 'Прогноз одобрения', description: 'Прогноз скорости и вероятности одобрения клиента в банках' },
      { icon: 'arrow-path', title: 'Отправка в 5+ банков', description: 'Одновременная отправка заявки в несколько банков' },
    ]}
    image=""
    variant="light"
  />

  <!-- CTA Бонус -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      title="Бонус от ДВИЖа"
      description="Скачайте пример идеального отчета ипотечного отдела"
      buttonText="Посмотреть демо"
      buttonHref="#"
    />
  </div>

  <!-- Bento Grid -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <BentoGrid
      columns={3}
      items={[
        { title: "Готовые интеграции с популярными системами", image: "" },
        { title: "57 секунд — среднее время ответа в чате поддержки", image: "" },
        { title: "Все ключевые показатели ипотечного отдела", image: "" }
      ]}
    />
  </div>

  <!-- Stories Carousel -->
  <div class="max-w-[1440px] mx-auto px-4 py-20">
    <SuccessStoriesCarousel
      title="70+ историй успеха на рынке девелопмента"
      stories={[
        {
          title: "Помогли начать обрабатывать на 281% заявок больше, чем в среднем на рынке",
          quote: "Спасибо ДВИЖ за прескоринг: он помогает точнее оценить финансовое состояние клиента и выбрать шаги, которые повышают шанс одобрения.",
          person: {
            name: "Петрова Надежда",
            jobTitle: "Директор по маркетингу, ЛСР",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "ЛСР",
          logo: "",
          logoAlt: "ЛСР"
        },
        {
          title: "Дополнительно продали 96 квартир",
          quote: "Спасибо ДВИЖ за прескоринг: он помогает точнее оценить финансовое состояние клиента и выбрать шаги, которые повышают шанс одобрения ипотеки.",
          person: {
            name: "Алексей Соколов",
            jobTitle: "Коммерческий директор, Самолет плюс",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "Самолет плюс",
          logo: "",
          logoAlt: "Самолет плюс"
        },
        {
          title: "Увеличили объем закрытых сделок с 1116 до 3500 за год",
          quote: "Спасибо ДВИЖ за прескоринг: он помогает точнее оценить финансовое состояние клиента и выбрать шаги, которые повышают шанс одобрения ипотеки.",
          person: {
            name: "Мария Иванова",
            jobTitle: "Руководитель отдела продаж",
          },
          image: "",
          imageAlt: "Компания",
          logo: "",
          logoAlt: "Логотип"
        },
        {
          title: "Сократили время обработки заявки с 3 дней до 4 часов",
          quote: "Интеграция прошла гладко. API оказался хорошо задокументированным, а поддержка всегда на связи.",
          person: {
            name: "Дмитрий Козлов",
            jobTitle: "IT-директор, Девелопер",
            photo: { url: "" }
          },
          image: "",
          imageAlt: "Девелопер",
          logo: "",
          logoAlt: "Девелопер"
        }
      ]}
    />
  </div>

  <!-- CTA Split -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <CTA
      variant="split"
      badge="Бонус от ДВИЖа"
      title="Подберем решение под ваши задачи"
      description="Проведём бесплатный анализ вашего ипотечного отдела и покажем точки роста"
      buttonText="Записаться на аудит"
      buttonHref="#"
    />
  </div>

  <!-- Form Closing -->
  <div class="max-w-[1440px] mx-auto px-4 py-12">
    <FormClosing
      preset="lead"
      title="Попробуйте ДВИЖ в деле"
      description="Оставьте заявку и мы свяжемся с вами в ближайшее время."
      submitLabel="Получить демо"
    />
  </div>
</SiteLayout>
