---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getVideos, getVideo } from '../../lib/payload'

export async function getStaticPaths() {
  const { docs } = await getVideos({ limit: 100 })
  return docs.map((v: any) => ({ params: { slug: v.slug } }))
}

const { slug } = Astro.params
const video = await getVideo(slug!)
if (!video) return Astro.redirect('/404')

const typeLabels: Record<string, string> = {
  webinar: 'Вебинар', conference: 'Конференция', podcast: 'Подкаст',
}
---

<SiteLayout title={video.meta?.title ?? video.title} description={video.meta?.description ?? video.description}>
  <div class="max-w-4xl mx-auto px-4 py-16">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/video" class="hover:underline">Видео</a>
      {video.type && <><span class="mx-2">›</span><span>{typeLabels[video.type]}</span></>}
    </nav>

    <h1 class="text-4xl font-bold mb-4">{video.title}</h1>
    {video.description && <p class="text-lg text-gray-600 mb-8">{video.description}</p>}

    <!-- Видео-плеер -->
    {video.videoUrl && (
      <div class="aspect-video rounded-xl overflow-hidden bg-gray-100 mb-8">
        <iframe
          src={video.videoUrl}
          class="w-full h-full"
          frameborder="0"
          allowfullscreen
        />
      </div>
    )}
  </div>
</SiteLayout>
