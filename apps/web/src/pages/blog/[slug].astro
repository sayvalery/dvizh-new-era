---
import BlogLayout from '../../layouts/BlogLayout.astro'
import BlockRenderer from '../../components/blocks/BlockRenderer.astro'
import PersonCard from '../../components/ui/PersonCard.astro'
import BlogCard from '../../components/ui/BlogCard.astro'
import { getBlogPosts, getBlogPost, normalizeMediaUrl, normalizeBodyHtml, sanitizeBodyHtml } from '../../lib/payload'

export async function getStaticPaths() {
  const allDocs: any[] = []
  let page = 1
  while (true) {
    const { docs, hasNextPage } = await getBlogPosts({ limit: 100, page })
    allDocs.push(...docs)
    if (!hasNextPage) break
    page++
  }
  return allDocs.map((post: any) => ({
    params: { slug: post.slug },
  }))
}

const { slug } = Astro.params
const post = await getBlogPost(slug!)


if (!post) return Astro.redirect('/404')

const coverUrl = normalizeMediaUrl(post.cover?.url)

// og:image: сначала кастомное из meta, потом обложка статьи
const ogImage = normalizeMediaUrl(post.meta?.image?.url) ?? normalizeMediaUrl(post.cover?.url) ?? undefined

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Блог', item: `${Astro.site}blog` },
    ...(post.category?.title ? [{ '@type': 'ListItem', position: 2, name: post.category.title, item: `${Astro.site}category/${post.category.slug}` }] : []),
    { '@type': 'ListItem', position: post.category ? 3 : 2, name: post.title },
  ],
}

const jsonLd = [
  breadcrumbLd,
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.excerpt ?? post.meta?.description,
    image: ogImage,
    datePublished: post.publishedAt,
    dateModified: post.updatedAt ?? post.publishedAt,
    author: post.primaryAuthor
      ? { '@type': 'Person', name: post.primaryAuthor.name, url: `${Astro.site}person/${post.primaryAuthor.slug}` }
      : undefined,
    publisher: {
      '@type': 'Organization',
      name: 'ДВИЖ',
      url: Astro.site,
    },
  },
]

// Исправляем bodyHtml: ссылки из Webflow + нормализация медиа-URL + санитизация
const bodyHtml = sanitizeBodyHtml(normalizeBodyHtml(
  post.bodyHtml
    ?.replaceAll('href="https://dvizh.webflow.io/', 'href="/')
    .replaceAll('href="https://www.dvizh.io/', 'href="/')
))

// Время чтения
const textContent = post.bodyHtml?.replace(/<[^>]+>/g, '') ?? post.content?.map((b: any) => b.richText?.root?.children?.map((c: any) => c.text || '').join(' ')).join(' ') ?? ''
const wordCount = textContent.split(/\s+/).filter(Boolean).length
const readingTime = Math.max(1, Math.ceil(wordCount / 200))

// Основной автор из relation
const primaryAuthor = post.primaryAuthor ?? null
// Соавторы без дублирования primaryAuthor
const coAuthors = (post.coAuthors ?? []).filter(
  (a: any) => a.id !== primaryAuthor?.id
)

// Связанные посты из той же категории
let relatedPosts: any[] = []
if (post.category?.slug) {
  const { docs } = await getBlogPosts({
    where: {
      _status: { equals: 'published' },
      'category.slug': { equals: post.category.slug },
      slug: { not_equals: post.slug },
    },
    limit: 3,
  })
  relatedPosts = docs
}
---

<BlogLayout
  title={post.meta?.title ?? post.title}
  description={post.meta?.description ?? post.excerpt}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <!-- Хлебные крошки -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/blog" class="hover:underline">Блог</a>
      {post.category?.title && (
        <>
          <span class="mx-2">›</span>
          <a href={`/category/${post.category.slug}`} class="hover:underline">
            {post.category.title}
          </a>
        </>
      )}
    </nav>

    <h1 class="text-4xl font-bold mb-4">{post.title}</h1>

    {post.excerpt && (
      <p class="text-xl text-gray-600 mb-6">{post.excerpt}</p>
    )}

    <!-- Мета: автор + дата + время чтения -->
    <div class="flex flex-wrap items-center gap-4 mb-10">
      {primaryAuthor && (
        <PersonCard person={primaryAuthor} variant="inline" />
      )}

      {post.publishedAt && (
        <time datetime={post.publishedAt} class="text-sm text-gray-400">
          {new Date(post.publishedAt).toLocaleDateString('ru-RU', {
            day: 'numeric', month: 'long', year: 'numeric',
          })}
        </time>
      )}

      <span class="text-sm text-gray-400">{readingTime} мин чтения</span>

      {post.category?.title && (
        <a href={`/category/${post.category.slug}`} class="text-sm text-gray-400 hover:text-gray-600">
          {post.category.title}
        </a>
      )}
    </div>

    {/* Теги */}
    {post.tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {post.tags.map((tag: any) => (
          <span class="px-2.5 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full">
            {tag.title || tag.name || tag}
          </span>
        ))}
      </div>
    )}

    {coverUrl && (
      <img
        src={coverUrl}
        alt={post.cover?.alt ?? post.title}
        class="w-full rounded-xl mb-10 aspect-video object-cover"
        width="768"
        height="432"
        loading="eager"
        decoding="async"
      />
    )}

    {post.content?.length > 0
      ? <BlockRenderer blocks={post.content} />
      : bodyHtml && <div class="prose prose-lg max-w-none" set:html={bodyHtml} />
    }

    <!-- Авторы внизу статьи (полные карточки) -->
    {(primaryAuthor || coAuthors.length > 0) && (
      <div class="mt-16 pt-8 border-t border-gray-200">
        <p class="text-xs uppercase tracking-wide text-gray-400 mb-4">
          {coAuthors.length > 0 ? 'Авторы' : 'Автор'}
        </p>
        <div class="space-y-4">
          {primaryAuthor && <PersonCard person={primaryAuthor} variant="full" />}
          {coAuthors.map((author: any) => (
            <PersonCard person={author} variant="full" />
          ))}
        </div>
      </div>
    )}
    {/* Шаринг */}
    <div class="mt-12 pt-8 border-t border-gray-200">
      <p class="text-xs uppercase tracking-wide text-gray-400 mb-3">Поделиться</p>
      <div class="flex gap-3">
        <a
          href={`https://t.me/share/url?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.title)}`}
          target="_blank"
          rel="noopener"
          class="px-4 py-2 bg-gray-100 rounded-lg text-sm text-gray-700 hover:bg-gray-200 transition-colors"
        >
          Telegram
        </a>
        <a
          href={`https://vk.com/share.php?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(post.title)}`}
          target="_blank"
          rel="noopener"
          class="px-4 py-2 bg-gray-100 rounded-lg text-sm text-gray-700 hover:bg-gray-200 transition-colors"
        >
          VK
        </a>
        <button
          onclick="navigator.clipboard.writeText(window.location.href); this.textContent = 'Скопировано!'; setTimeout(() => this.textContent = 'Копировать ссылку', 2000)"
          class="px-4 py-2 bg-gray-100 rounded-lg text-sm text-gray-700 hover:bg-gray-200 transition-colors"
        >
          Копировать ссылку
        </button>
      </div>
    </div>
  </article>

  {/* Связанные статьи */}
  {relatedPosts.length > 0 && (
    <div class="max-w-[1440px] mx-auto px-4 pb-16">
      <h2 class="text-2xl font-bold mb-6">Читайте также</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {relatedPosts.map((rp: any) => (
          <BlogCard
            title={rp.title}
            slug={rp.slug}
            cover={rp.cover}
            category={rp.category?.title}
            excerpt={rp.excerpt}
          />
        ))}
      </div>
    </div>
  )}
</BlogLayout>
