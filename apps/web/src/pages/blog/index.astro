---
import BlogLayout from '../../layouts/BlogLayout.astro'
import { getBlogPosts, getCategories, normalizeMediaUrl } from '../../lib/payload'

const POSTS_PER_PAGE = 12

// Получаем все посты для подсчёта и первую страницу
const allPostsResult = await getBlogPosts({ limit: 200 })
const allPosts = allPostsResult.docs
const { docs: categories } = await getCategories()

// Считаем статьи по категориям
const categoryCountMap: Record<string, number> = {}
for (const post of allPosts) {
  const catSlug = post.category?.slug
  if (catSlug) {
    categoryCountMap[catSlug] = (categoryCountMap[catSlug] ?? 0) + 1
  }
}

// Первая страница
const posts = allPosts.slice(0, POSTS_PER_PAGE)
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
const hasNextPage = totalPages > 1
---

<BlogLayout title="Блог — ДВИЖ">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-2">Блог</h1>
    <p class="text-gray-400 text-sm mb-8">{allPosts.length} статей</p>

    <!-- Фильтр по категориям -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        <a href="/blog" class="px-3 py-1 rounded-full border border-brand text-brand text-sm">
          Все <span class="text-gray-400 ml-1">{allPosts.length}</span>
        </a>
        {categories.map((cat: any) => (
          <a
            href={`/category/${cat.slug}`}
            class="px-3 py-1 rounded-full border text-sm hover:bg-gray-100"
          >
            {cat.title}
            <span class="text-gray-400 ml-1">{categoryCountMap[cat.slug] ?? 0}</span>
          </a>
        ))}
      </div>
    )}

    <!-- Список постов -->
    {posts.length === 0 ? (
      <p class="text-gray-500">Статьи скоро появятся.</p>
    ) : (
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post: any) => {
          const coverUrl = normalizeMediaUrl(post.cover?.url)
          return (
            <a href={`/blog/${post.slug}`} class="group border rounded-xl overflow-hidden hover:shadow-md transition-shadow">
              {coverUrl ? (
                <img src={coverUrl} alt={post.cover?.alt ?? post.title} class="w-full aspect-video object-cover" loading="lazy" />
              ) : (
                <div class="w-full aspect-video bg-gray-100" />
              )}
              <div class="p-5">
                {post.category?.title && (
                  <span class="text-xs text-gray-500 uppercase tracking-wide">{post.category.title}</span>
                )}
                <h2 class="font-semibold mt-1 group-hover:underline">{post.title}</h2>
                {post.excerpt && <p class="text-sm text-gray-600 mt-2 line-clamp-2">{post.excerpt}</p>}
              </div>
            </a>
          )
        })}
      </div>
    )}

    <!-- Пагинация -->
    {hasNextPage && (
      <div class="flex justify-center mt-12">
        <a
          href="/blog/page/2"
          class="px-6 py-3 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors"
        >
          Загрузить ещё
        </a>
      </div>
    )}
  </div>
</BlogLayout>
