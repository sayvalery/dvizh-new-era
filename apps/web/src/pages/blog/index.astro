---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBlogPosts, getCategories } from '../../lib/payload'

const { docs: posts } = await getBlogPosts({ limit: 20 })
const { docs: categories } = await getCategories()

const CMS_URL = import.meta.env.CMS_URL || 'http://localhost:3002'
---

<BaseLayout title="Блог">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8">Блог</h1>

    <!-- Фильтр по категориям -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        <a href="/blog" class="px-3 py-1 rounded-full border text-sm hover:bg-gray-100">
          Все
        </a>
        {categories.map((cat: any) => (
          <a
            href={`/blog/category/${cat.slug}`}
            class="px-3 py-1 rounded-full border text-sm hover:bg-gray-100"
          >
            {cat.title}
          </a>
        ))}
      </div>
    )}

    <!-- Список постов -->
    {posts.length === 0 ? (
      <p class="text-gray-500">Статьи скоро появятся.</p>
    ) : (
      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post: any) => {
          const coverUrl = post.cover?.url ? `${CMS_URL}${post.cover.url}` : null
          return (
            <a href={`/blog/${post.slug}`} class="group border rounded-xl overflow-hidden hover:shadow-md transition-shadow">
              {coverUrl && (
                <img src={coverUrl} alt={post.cover?.alt ?? post.title} class="w-full aspect-video object-cover" />
              )}
              <div class="p-5">
                {post.category?.title && (
                  <span class="text-xs text-gray-500 uppercase tracking-wide">{post.category.title}</span>
                )}
                <h2 class="font-semibold mt-1 group-hover:underline">{post.title}</h2>
                {post.excerpt && <p class="text-sm text-gray-600 mt-2 line-clamp-2">{post.excerpt}</p>}
              </div>
            </a>
          )
        })}
      </div>
    )}
  </div>
</BaseLayout>
