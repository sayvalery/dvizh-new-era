---
import BlogLayout from '../../layouts/BlogLayout.astro'
import BlogGrid from '../../components/ui/BlogGrid.astro'
import { getBlogPosts, getCategories } from '../../lib/payload'

const POSTS_PER_PAGE = 12

const allPostsResult = await getBlogPosts({ limit: 200 })
const allPosts = allPostsResult.docs
const { docs: categories } = await getCategories()

const categoryCountMap: Record<string, number> = {}
for (const post of allPosts) {
  const catSlug = post.category?.slug
  if (catSlug) {
    categoryCountMap[catSlug] = (categoryCountMap[catSlug] ?? 0) + 1
  }
}

const posts = allPosts.slice(0, POSTS_PER_PAGE)
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
---

<BlogLayout title="Блог — ДВИЖ">
  <div class="max-w-[1440px] mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-2">Блог</h1>
    <p class="text-gray-400 text-sm mb-8">{allPosts.length} статей</p>

    <BlogGrid
      posts={posts}
      allPosts={allPosts}
      categories={categories}
      categoryCountMap={categoryCountMap}
      currentPage={1}
      totalPages={totalPages}
    />
  </div>
</BlogLayout>
