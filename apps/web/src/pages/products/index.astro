---
import BaseLayout from '../../layouts/BaseLayout.astro'

const products = [
  { slug: 'ipoteka', title: 'Ипотека', description: 'Цифровизация ипотечного процесса' },
  { slug: 'registratsiya', title: 'Регистрация', description: 'Электронная регистрация сделок' },
  { slug: 'skoring', title: 'Скоринг', description: 'Оценка заемщиков' },
  { slug: 'kalkulyator', title: 'Калькулятор', description: 'Ипотечный калькулятор' },
  { slug: 'lichnyy-kabinet', title: 'Личный кабинет', description: 'Личный кабинет клиента' },
  { slug: 'vitrina', title: 'Витрина', description: 'Витрина объектов' },
  { slug: 'biznes-revyu', title: 'Бизнес-ревью', description: 'Аналитика и отчеты' },
]
---

<BaseLayout title="Продукты">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-12">Продукты</h1>
    <div class="grid md:grid-cols-3 gap-6">
      {products.map(p => (
        <a href={`/products/${p.slug}`} class="p-6 border rounded-xl hover:bg-gray-50">
          <h2 class="text-xl font-semibold mb-2">{p.title}</h2>
          <p class="text-gray-600 text-sm">{p.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
