---
/**
 * Lab — экспериментальные страницы (только dev)
 *
 * Catch-all роут: в продакшне getStaticPaths возвращает [],
 * поэтому lab-страницы не попадают в статическую сборку.
 * Доступны только через dev-сервер: preview.dvizh.cc/lab/
 */
import LabIndex from '../../components/lab/LabIndex.astro'
import LabProduct from '../../components/lab/LabProduct.astro'
import LabAbout from '../../components/lab/LabAbout.astro'
import LabHome from '../../components/lab/LabHome.astro'
import LabFlutedGlass from '../../components/lab/LabFlutedGlass.astro'
import LabLogoAnimations from '../../components/lab/LabLogoAnimations.astro'
import LabHomepage from '../../pages/lab/homepage.astro'
import LabSales from '../../pages/lab/sales.astro'
import LabIpotekaNew from '../../pages/lab/ipoteka-new.astro'

export function getStaticPaths() {
  if (import.meta.env.PROD) return []
  return [
    { params: { slug: undefined }, props: { page: 'index' } },
    { params: { slug: 'glass' }, props: { page: 'glass' } },
    { params: { slug: 'product' }, props: { page: 'product' } },
    { params: { slug: 'about' }, props: { page: 'about' } },
    { params: { slug: 'home' }, props: { page: 'home' } },
    { params: { slug: 'fluted-glass' }, props: { page: 'fluted-glass' } },
    { params: { slug: 'logo-animations' }, props: { page: 'logo-animations' } },
    { params: { slug: 'homepage' }, props: { page: 'homepage' } },
    { params: { slug: 'sales' }, props: { page: 'sales' } },
    { params: { slug: 'ipoteka-new' }, props: { page: 'ipoteka-new' } },
  ]
}

const { page } = Astro.props
---

{page === 'index' && <LabIndex />}
{page === 'product' && <LabProduct />}
{page === 'about' && <LabAbout />}
{page === 'home' && <LabHome />}
{page === 'fluted-glass' && <LabFlutedGlass />}
{page === 'logo-animations' && <LabLogoAnimations />}
{page === 'homepage' && <LabHomepage />}
{page === 'sales' && <LabSales />}
{page === 'ipoteka-new' && <LabIpotekaNew />}
