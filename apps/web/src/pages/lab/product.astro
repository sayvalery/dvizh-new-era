---
/**
 * Lab: Product page — Linear-inspired layout
 * Адаптация паттернов Linear.app для продуктовой страницы ДВИЖ
 * Светлая тема, split-layout заголовки, serif display typography, generous spacing
 *
 * Доступна только в dev-режиме: preview.dvizh.cc/lab/product
 */
import SiteLayout from '../../layouts/SiteLayout.astro'
import Form from '../../components/ui/Form.astro'

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>`,
    title: 'Все типы сделок',
    description: 'ДДУ, ДКП, ДУПТ, ДС — регистрация любого типа договора за 15 минут. Пакетная отправка нескольких сделок одновременно.'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
    title: 'Бесплатная ЭЦП',
    description: 'Выпуск электронной цифровой подписи для участников сделки без дополнительных затрат. Три способа: удалённо, в офисе или через УЦ.'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>`,
    title: 'Гибкие уведомления',
    description: 'Email, SMS и push-уведомления о статусе регистрации. Настраиваемые каналы для менеджеров и клиентов.'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>`,
    title: 'Интеграции с CRM',
    description: 'AmoCRM и Битрикс24 — запуск регистрации прямо из карточки сделки без переключения между системами.'
  },
]

const stats = [
  { value: 'на 30%', label: 'Сокращение затрат на регистрацию' },
  { value: '15 мин', label: 'Подготовка пакета документов' },
  { value: '0', label: 'Ошибок в документах' },
  { value: '99.9%', label: 'Uptime сервиса' },
]

const steps = [
  { number: '01', title: 'Загрузите документы', description: 'Загрузите пакет документов в систему. Автоматическая проверка на ошибки и комплектность.' },
  { number: '02', title: 'Подпишите ЭЦП', description: 'Участники сделки подписывают документы электронной подписью. Выпуск ЭЦП — бесплатно.' },
  { number: '03', title: 'Отправьте в Росреестр', description: 'Пакет документов уходит в Росреестр. Отслеживайте статус в реальном времени.' },
  { number: '04', title: 'Получите результат', description: 'Выписка из ЕГРН приходит в систему автоматически. Уведомление всем участникам.' },
]
---

<SiteLayout title="Lab: Электронная регистрация — Linear Style">

  <!-- ============================================
       Hero: Split layout (Linear-style)
       Большой заголовок слева, описание справа
       ============================================ -->
  <section class="pt-32 pb-24 lg:pb-32">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Badge -->
      <p class="text-sm font-medium tracking-widest uppercase text-brand mb-8">
        Электронная регистрация
      </p>

      <!-- Split heading -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <h1 class="text-5xl lg:text-7xl font-medium leading-[1.05] tracking-tight text-gray-900" style="font-family: 'Georgia', 'Times New Roman', serif;">
          Регистрация сделок за&nbsp;15&nbsp;минут
        </h1>
        <div class="lg:pt-4">
          <p class="text-xl lg:text-2xl text-gray-500 leading-relaxed max-w-lg">
            Сократите затраты на&nbsp;регистрацию на&nbsp;30%. Электронная подпись бесплатно. Все типы сделок в&nbsp;одной системе.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="#form" class="inline-flex items-center px-8 py-4 bg-brand text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors">
              Запросить демо
            </a>
            <a href="#how" class="inline-flex items-center px-8 py-4 border border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-gray-400 transition-colors">
              Как это работает
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       Stats: большие числа (Linear-style metrics)
       ============================================ -->
  <section class="py-24 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
        {stats.map(stat => (
          <div>
            <p class="text-4xl lg:text-5xl font-medium tracking-tight text-gray-900" style="font-family: 'Georgia', 'Times New Roman', serif;">
              {stat.value}
            </p>
            <p class="mt-3 text-sm text-gray-500 leading-snug">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       Features: карточки с иконками (Linear card grid)
       ============================================ -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Split heading для секции -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start mb-20">
        <h2 class="text-3xl lg:text-5xl font-medium leading-tight tracking-tight text-gray-900" style="font-family: 'Georgia', 'Times New Roman', serif;">
          Всё для электронной регистрации
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed lg:pt-2">
          Один сервис для всех типов сделок. Интеграции с CRM, бесплатная ЭЦП и&nbsp;уведомления на&nbsp;каждом этапе.
        </p>
      </div>

      <!-- Feature cards -->
      <div class="grid md:grid-cols-2 gap-6">
        {features.map(feature => (
          <div class="bg-white rounded-2xl p-8 lg:p-10 border border-gray-100 hover:border-gray-200 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand flex items-center justify-center mb-6">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">
              {feature.title}
            </h3>
            <p class="text-gray-500 leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       How it works: numbered steps (Linear method-style)
       ============================================ -->
  <section id="how" class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Split heading -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start mb-20">
        <h2 class="text-3xl lg:text-5xl font-medium leading-tight tracking-tight text-gray-900" style="font-family: 'Georgia', 'Times New Roman', serif;">
          Как это работает
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed lg:pt-2">
          От загрузки документов до&nbsp;получения выписки из&nbsp;ЕГРН — четыре простых шага.
        </p>
      </div>

      <!-- Steps -->
      <div class="space-y-0">
        {steps.map((step, i) => (
          <div class:list={[
            'grid lg:grid-cols-[120px_1fr] gap-6 lg:gap-12 py-10',
            i < steps.length - 1 ? 'border-b border-gray-100' : ''
          ]}>
            <span class="text-5xl font-light text-gray-200" style="font-family: 'Georgia', 'Times New Roman', serif;">
              {step.number}
            </span>
            <div>
              <h3 class="text-xl lg:text-2xl font-semibold text-gray-900 mb-3">
                {step.title}
              </h3>
              <p class="text-gray-500 leading-relaxed max-w-2xl">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       Pricing callout (Linear-style accent block)
       Dark background block
       ============================================ -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="bg-gray-900 rounded-3xl p-12 lg:p-20">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div>
            <p class="text-brand text-sm font-medium tracking-widest uppercase mb-6">
              Прозрачное ценообразование
            </p>
            <h2 class="text-3xl lg:text-5xl font-medium leading-tight tracking-tight text-white" style="font-family: 'Georgia', 'Times New Roman', serif;">
              Фиксированная стоимость
            </h2>
          </div>
          <div>
            <div class="flex items-baseline gap-4 mb-4">
              <span class="text-5xl lg:text-6xl font-medium text-white" style="font-family: 'Georgia', 'Times New Roman', serif;">
                1 000 ₽
              </span>
              <span class="text-gray-400 text-lg">за регистрацию</span>
            </div>
            <p class="text-gray-400 leading-relaxed mb-8">
              Никаких скрытых комиссий. Госпошлина 200 ₽. Выпуск ЭЦП — бесплатно.
            </p>
            <a href="#form" class="inline-flex items-center px-8 py-4 bg-brand text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors">
              Начать
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       Form: clean minimal form section
       ============================================ -->
  <section id="form" class="py-24 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <h2 class="text-3xl lg:text-5xl font-medium leading-tight tracking-tight text-gray-900 mb-6" style="font-family: 'Georgia', 'Times New Roman', serif;">
            Запросите демо
          </h2>
          <p class="text-lg text-gray-500 leading-relaxed max-w-md">
            Покажем, как электронная регистрация ускорит ваши сделки. Индивидуальная демонстрация для вашей команды.
          </p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8 lg:p-10">
          <Form preset="demo" />
        </div>
      </div>
    </div>
  </section>

</SiteLayout>
