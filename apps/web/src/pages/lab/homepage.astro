---
/**
 * Lab: Homepage page — полная главная страница
 *
 * Доступна только в dev-режиме: preview.dvizh.cc/lab/homepage
 */
import SiteLayout from '../../layouts/SiteLayout.astro'
import HeroSection from '../../components/ui/HeroSection.astro'
import LogoDrum from '../../components/ui/LogoDrum.astro'
import BentoGrid from '../../components/ui/BentoGrid.astro'
import FeaturesGrid from '../../components/ui/FeaturesGrid.astro'
import SectionBlock from '../../components/ui/SectionBlock.astro'
import GradientCTA from '../../components/ui/GradientCTA.astro'
import BlogCards from '../../components/ui/BlogCards.astro'
import ProductSection from '../../components/ui/ProductSection.astro'
import ProductSectionNew from '../../components/ui/ProductSectionNew.astro'
import BentoThreeNew from '../../components/ui/BentoThreeNew.astro'
import FeatureCard from '../../components/lab-new/FeatureCard.astro'
import FormClosing from '../../components/ui/FormClosing.astro'
import CTA from '../../components/ui/CTA.astro'
import StoryCard from '../../components/ui/StoryCard.astro'

const partnerLogos = [
  '/partners/a101.svg',
  '/partners/ava.svg',
  '/partners/ganel.svg',
  '/partners/glorax.svg',
  '/partners/lsr.svg',
  '/partners/strana.svg',
  '/logo-dvizh-white.svg',
]
---

<SiteLayout
  title="Lab: Homepage — ДВИЖ"
  description="Лаборатория дизайна: главная страница сайта ДВИЖ"
  transparentHeader
>
  <!-- Hero -->
  <HeroSection
    title={"Лучшие отделы\u00A0продаж застройщиков используют ДВИЖ"}
    description="Единая платформа для увеличения продаж. Закрываем весь цикл сделки: от подбора квартиры до одобрения ипотеки и регистрации в Росреестре"
    formPreset="lead"
    formSubmitLabel="Получить демо"
    withGradient
    gradientColors={['#ff4d00', '#ff6b2c', '#ffb347', '#ffd866']}
  >
    <div slot="right" class="w-full h-[700px]">
      <LogoDrum logos={partnerLogos} duration={55} />
    </div>
  </HeroSection>

  <!-- ProductSectionNew Demo -->
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <ProductSectionNew
    sections={[
      { number: "01", title: "Цифровая ипотека", active: true },
      { number: "02", title: "Ипотечный калькулятор" },
      { number: "03", title: "Финансовый скоринг" },
      { number: "04", title: "Электронная регистрация" },
      { number: "05", title: "Движ AI" },
    ]}
    title={{
      lg: "Заголовок для больших экранов (lg+)",
      md: "Заголовок для средних экранов (md)",
      sm: "Заголовок для мобильных (sm)"
    }}
    descriptions={[
      "Это демонстрация нового компонента ProductSectionNew",
      "С адаптивными заголовками и изображениями в правом блоке"
    ]}
    primaryButton={{ label: "Начать", href: "#" }}
    secondaryButton={{ label: "Подробнее", href: "#" }}
    rightContent={{
      images: [
        {
          src: "/partners/dvizh.svg",
          alt: "Логотип ДВИЖ",
          width: 400,
          height: 200
        }
      ],
      description: "Пример изображения в правом блоке"
    }}
    />
  </div>

  <!-- BentoThreeNew Demo -->
  <div class="max-w-[1440px] mx-auto px-4 mt-[50px]">
    <BentoThreeNew
      title={{
        lg: "Закрывайте до 26% больше сделок на таком же трафике",
        md: "Закрывайте до 26% больше сделок на таком же трафике",
        sm: "Закрывайте до 26% больше сделок на таком же трафике"
      }}
      bigCard={{
        title: "Получайте больше выручки",
        description: "на одного менеджера"
      }}
      smallCards={[
        {
          title: "Снижайте количество отказов",
          description: "по ипотеке"
        },
        {
          title: "Сокращайте количество расходов",
          description: "на электронную регистрацию"
        }
      ]}
  />
  </div>

  <!-- Feature Cards (70+ историй успеха) -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-4">
      <div class="mb-12">
        <h2 class="text-[42.5px] font-semibold text-gray-900 tracking-tight leading-none">
          70+ историй успеха<br>на рынке девелопмента
        </h2>
        <p class="mt-4 text-base text-gray-600">
          Текст про преимущества и всякое такое
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <FeatureCard
          title="Готовые интеграции"
          subtitle="с популярными системами"
          color="#202b32"
          image="https://admin.dvizh.cc/api/media/file/5-new.jpg"
          imagePosition="right bottom"
        />
        <FeatureCard
          title="57 секунд"
          subtitle="среднее время ответа в поддержке"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/6-new.jpg"
        />
        <FeatureCard
          title="Все ключевые показатели"
          subtitle="ипотечного отдела"
          color="#F2F2F2"
          image="https://admin.dvizh.cc/api/media/file/7-new.jpg"
        />
      </div>
    </div>
  </section>
</SiteLayout>
