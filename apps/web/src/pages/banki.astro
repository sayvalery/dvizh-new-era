---
import SiteLayout from '../layouts/SiteLayout.astro'
import Form from '../components/ui/Form.astro'
import FeaturesGrid from '../components/ui/FeaturesGrid.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import StatsSection from '../components/ui/StatsSection.astro'
import CTA from '../components/ui/CTA.astro'
---

<SiteLayout title="Для банков — ДВИЖ">
  <HeroSection
    badge="Решение для банков"
    title="Прямая API-интеграция для банков"
    description="В 20 раз быстрее обрабатывайте ипотечные заявки. Получайте заявки напрямую от крупнейших застройщиков России через единую платформу."
    formPreset="demo"
  />

  <StatsSection
    cols={2}
    items={[
      { value: '79', label: 'Крупнейших застройщиков подключены к платформе' },
      { value: '36', label: 'Банков получают заявки через ДВИЖ' },
    ]}
  />

  <!-- Прямая интеграция -->
  <FeaturesGrid
    badge="Интеграция"
    title="Прямая интеграция с 79 застройщиками"
    description="Единый API для получения ипотечных заявок от крупнейших застройщиков. Без посредников, без ручной обработки, без потерь данных."
    features={[
      { icon: 'database', title: 'Единый API', description: 'Одна интеграция вместо десятков отдельных подключений к каждому застройщику' },
      { icon: 'arrow-path', title: 'Автоматическая маршрутизация', description: 'Заявки автоматически направляются в нужные отделы банка по заданным правилам' },
      { icon: 'lock', title: 'Безопасность данных', description: 'Шифрование и защита персональных данных на каждом этапе передачи' },
    ]}
    variant="light"
  />

  <!-- Больше заявок -->
  <FeaturesGrid
    badge="Рост объемов"
    title="В 2 раза больше заявок"
    description="Подключение к ДВИЖ открывает доступ к потоку заявок от всех застройщиков на платформе. Больше заявок — больше выдач."
    features={[
      { icon: 'building-bank', title: '79 застройщиков из ТОП-100', description: 'Доступ к заявкам от крупнейших застройщиков России' },
      { icon: 'globe', title: 'Покрытие по всей России', description: 'Заявки из всех регионов присутствия застройщиков-партнеров' },
      { icon: 'check', title: 'Качественные заявки', description: 'Предварительная проверка заемщиков через прескоринг ДВИЖ' },
    ]}
    variant="light"
  />

  <!-- Ноль потерь -->
  <FeaturesGrid
    badge="Надежность"
    title="До 0 потерянных заявок"
    description="Полная прозрачность на каждом этапе обработки. Отслеживание статусов в реальном времени, уведомления и автоматические повторы при сбоях."
    features={[
      { icon: 'check', title: 'Гарантия доставки', description: 'Каждая заявка гарантированно доставлена — автоматические повторы при сбоях связи' },
      { icon: 'document', title: 'Полный аудит', description: 'История всех действий по каждой заявке для контроля и отчетности' },
    ]}
    variant="light"
  />

  <!-- Экономия -->
  <FeaturesGrid
    badge="Эффективность"
    title="Экономия на сопровождении"
    description="Автоматизация рутинных операций позволяет сократить расходы на обработку заявок и сопровождение сделок."
    features={[
      { icon: 'arrow-path', title: 'Автоматизация процессов', description: 'Заявки обрабатываются автоматически — меньше ручного труда и ошибок' },
      { icon: 'document', title: 'Единый формат данных', description: 'Стандартизированные анкеты — не нужно переформатировать данные из разных источников' },
    ]}
    variant="light"
  />

  <!-- CTA -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <CTA
      title="Запросить демо"
      description="Узнайте, как ДВИЖ поможет вашему банку увеличить поток качественных ипотечных заявок"
      buttonText="Запросить демо"
      buttonHref="#form"
    />
  </div>

  <!-- Форма захвата -->
  <div id="form" class="bg-gray-50 py-24">
    <div class="max-w-5xl mx-auto px-4">
      <div class="bg-white rounded-xl shadow-lg p-8 max-w-md">
        <h2 class="text-xl font-semibold mb-4">Запросить демо</h2>
        <Form preset="demo" />
      </div>
    </div>
  </div>
</SiteLayout>
