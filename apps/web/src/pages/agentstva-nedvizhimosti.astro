---
import BaseLayout from '../layouts/BaseLayout.astro'
import Form from '../components/ui/Form.astro'
---

<BaseLayout title="Для агентств недвижимости — ДВИЖ">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-4">Для агентств недвижимости</h1>
    <p class="text-xl text-gray-600 mb-12">Платформа для риелторов и агентств недвижимости.</p>

    <div class="prose max-w-none mb-12">
      <p>Контент страницы наполняется командой дизайна.</p>
    </div>

    <div class="bg-gray-50 rounded-xl p-8 max-w-md">
      <h2 class="text-xl font-semibold mb-4">Обсудить с нами</h2>
      <Form preset="lead" />
    </div>
  </div>
</BaseLayout>
